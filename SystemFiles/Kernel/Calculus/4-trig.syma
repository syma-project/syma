Integrate[x_^m_*(a_.+b_*Csc[c_.+d_*x_^n_])^p_.,x_] := Unintegrable[x^m*(a+b*Csc[c+d*x^n])^p,x] /;
FreeQ[{a,b,c,d,m,n,p},x]

Integrate[(e_*x_)^m_*(a_.+b_*Sec[c_.+d_*x_^n_])^p_.,x_] := e^IntPart[m]*(e*x)^FracPart[m]/x^FracPart[m]*Integrate[x^m*(a+b*Sec[c+d*x^n])^p,x] /;
FreeQ[{a,b,c,d,e,m,n,p},x]

Integrate[(e_*x_)^m_*(a_.+b_*Csc[c_.+d_*x_^n_])^p_.,x_] := e^IntPart[m]*(e*x)^FracPart[m]/x^FracPart[m]*Integrate[x^m*(a+b*Csc[c+d*x^n])^p,x] /;
FreeQ[{a,b,c,d,e,m,n,p},x]

Integrate[(e_*x_)^m_*(a_.+b_*Sec[u_])^p_.,x_] := Integrate[(e*x)^m*(a+b*Sec[ExpandToSum[u,x]])^p,x] /;
FreeQ[{a,b,e,m,p},x] && BinomialQ[u,x] && Not[BinomialMatchQ[u,x]]

Integrate[(e_*x_)^m_*(a_.+b_*Csc[u_])^p_.,x_] := Integrate[(e*x)^m*(a+b*Csc[ExpandToSum[u,x]])^p,x] /;
FreeQ[{a,b,e,m,p},x] && BinomialQ[u,x] && Not[BinomialMatchQ[u,x]]

