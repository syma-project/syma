FreeQ[{a,b,p},x] && IntegerQ[n] && GeQ[m-n,0] && NeQ[p,1]

Integrate[x_^m_*Csc[a_.+b_*x_^n_.]^p_*Cos[a_.+b_*x_^n_.],x_] := -x^(m-n+1)*Csc[a+b*x^n]^(p-1)/(b*n*(p-1)) + (m-n+1)/(b*n*(p-1))*Integrate[x^(m-n)*Csc[a+b*x^n]^(p-1),x] /;
FreeQ[{a,b,p},x] && IntegerQ[n] && GeQ[m-n,0] && NeQ[p,1]

