Integrate[(a_+b_*Csc[e_.+f_*x_])^m_*(c_+d_*Csc[e_.+f_*x_]),x_] := c*Integrate[(a+b*Csc[e+f*x])^m,x] + d*Integrate[(a+b*Csc[e+f*x])^m*Csc[e+f*x],x] /;
