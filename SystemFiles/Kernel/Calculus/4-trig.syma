FreeQ[{a,b,c,d,n},x]

Integrate[Cos[e_.+f_*x_]^p_*(a_+b_*Sin[e_.+f_*x_])^m_.,x_] := 1/(b^p*f)*Subst[Integrate[(a+x)^(m+(p-1)/2)*(a-x)^((p-1)/2),x],x,b*Sin[e+f*x]] /;
FreeQ[{a,b,e,f,m},x] && IntegerQ[(p-1)/2] && EqQ[a^2-b^2,0] && (GeQ[p,-1] || Not[IntegerQ[m+1/2]])

Integrate[Cos[e_.+f_*x_]^p_*(a_+b_*Sin[e_.+f_*x_])^m_.,x_] := 1/(b^p*f)*Subst[Integrate[(a+x)^m*(b^2-x^2)^((p-1)/2),x],x,b*Sin[e+f*x]] /;
FreeQ[{a,b,e,f,m},x] && IntegerQ[(p-1)/2] && NeQ[a^2-b^2,0]

Integrate[(g_*Cos[e_.+f_*x_])^p_*(a_+b_*Sin[e_.+f_*x_]),x_] := -b*(g*Cos[e+f*x])^(p+1)/(f*g*(p+1)) + a*Integrate[(g*Cos[e+f*x])^p,x] /;
FreeQ[{a,b,e,f,g,p},x] && (IntegerQ[2*p] || NeQ[a^2-b^2,0])

Integrate[(g_*Cos[e_.+f_*x_])^p_*(a_+b_*Sin[e_.+f_*x_])^m_,x_] := (a/g)^(2*m)*Integrate[(g*Cos[e+f*x])^(2*m+p)/(a-b*Sin[e+f*x])^m,x] /;
FreeQ[{a,b,e,f,g},x] && EqQ[a^2-b^2,0] && IntegerQ[m] && LtQ[p,-1] && GeQ[2*m+p,0]

