Integrate[Cos[d_.+e_*x_]^n_*(a_.+b_*Sec[d_.+e_*x_]+c_*Tan[d_.+e_*x_])^n_.,x_] := Integrate[(b+a*Cos[d+e*x]+c*Sin[d+e*x])^n,x] /;
