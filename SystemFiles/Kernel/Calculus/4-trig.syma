Integrate[(a_+b_*Csc[e_.+f_*x_])^m_*(c_+d_*Csc[e_.+f_*x_])^n_,x_] := -a*c*Cot[e+f*x]/(f*Sqrt[a+b*Csc[e+f*x]]*Sqrt[c+d*Csc[e+f*x]])* Subst[Integrate[(b+a*x)^(m-1/2)*(d+c*x)^(n-1/2)/x^(m+n),x],x,Sin[e+f*x]] /;
FreeQ[{a,b,c,d,e,f},x] && EqQ[b*c+a*d,0] && EqQ[a^2-b^2,0] && IntegerQ[m-1/2] && EqQ[m+n,0]

Integrate[(a_+b_*Csc[e_.+f_*x_])^m_*(c_+d_*Csc[e_.+f_*x_])^n_.,x_] := a*c*Cot[e+f*x]/(f*Sqrt[a+b*Csc[e+f*x]]*Sqrt[c+d*Csc[e+f*x]])*Subst[Integrate[(a+b*x)^(m-1/2)*(c+d*x)^(n-1/2)/x,x],x,Csc[e+f*x]] /;
FreeQ[{a,b,c,d,e,f,m,n},x] && EqQ[b*c+a*d,0] && EqQ[a^2-b^2,0]

Integrate[(a_+b_*Csc[e_.+f_*x_])*(c_+d_*Csc[e_.+f_*x_]),x_] := a*c*x + b*d*Integrate[Csc[e+f*x]^2,x] /;
FreeQ[{a,b,c,d,e,f},x] && EqQ[b*c+a*d,0]

