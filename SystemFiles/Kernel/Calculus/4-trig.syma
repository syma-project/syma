Integrate[1/(a_+b_*Sin[c_.+d_*x_]),x_] := -Cos[c+d*x]/(d*(b+a*Sin[c+d*x])) /;
FreeQ[{a,b,c,d},x] && EqQ[a^2-b^2,0]

Integrate[1/Sqrt[a_+b_*Sin[c_.+d_*x_]],x_] := -2/d*Subst[Integrate[1/(2*a-x^2),x],x,b*Cos[c+d*x]/Sqrt[a+b*Sin[c+d*x]]] /;
FreeQ[{a,b,c,d},x] && EqQ[a^2-b^2,0]

Integrate[(a_+b_*Sin[c_.+d_*x_])^n_,x_] := b*Cos[c+d*x]*(a+b*Sin[c+d*x])^n/(a*d*(2*n+1)) + (n+1)/(a*(2*n+1))*Integrate[(a+b*Sin[c+d*x])^(n+1),x] /;
FreeQ[{a,b,c,d},x] && EqQ[a^2-b^2,0] && LtQ[n,-1] && IntegerQ[2*n] (* Integrate[(a_+b_*Sin[c_.+d_*x_])^n_,x_] := a^2*Cos[c+d*x]/(d*Sqrt[a+b*Sin[c+d*x]]*Sqrt[a-b*Sin[c+d*x]])*Subst[Integrate[(a+b*x)^(n-1/2)/Sqrt[a-b*x],x],x,Sin[c+d*x]] /; FreeQ[{a,b,c,d,n},x] && EqQ[a^2-b^2,0] && Not[IntegerQ[2*n]] *)

Integrate[(a_+b_*Sin[c_.+d_*x_])^n_,x_] := -2^(n+1/2)*a^(n-1/2)*b*Cos[c+d*x]/(d*Sqrt[a+b*Sin[c+d*x]])*Hypergeometric2F1[1/2,1/2-n,3/2,1/2*(1-b*Sin[c+d*x]/a)] /;
FreeQ[{a,b,c,d,n},x] && EqQ[a^2-b^2,0] && Not[IntegerQ[2*n]] && GtQ[a,0]

