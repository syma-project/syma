Integrate[(a_.+b_*Csc[c_.+d_*u_^n_])^p_.,x_] := 1/Coefficient[u,x,1]*Subst[Integrate[(a+b*Csc[c+d*x^n])^p,x],x,u] /;
FreeQ[{a,b,c,d,n,p},x] && LinearQ[u,x] && NeQ[u,x]

