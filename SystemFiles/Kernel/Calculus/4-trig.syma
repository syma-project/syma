Integrate[(c_.+d_*x_)^m_*Csc[e_.+f_*x_]^2,x_] := -(c+d*x)^m*Cot[e+f*x]/f + d*m/f*Integrate[(c+d*x)^(m-1)*Cot[e+f*x],x] /;
FreeQ[{c,d,e,f},x] && GtQ[m,0]

Integrate[(c_.+d_*x_)*(b_*Csc[e_.+f_*x_])^n_,x_] := -b^2*(c+d*x)*Cot[e+f*x]*(b*Csc[e+f*x])^(n-2)/(f*(n-1)) - b^2*d*(b*Csc[e+f*x])^(n-2)/(f^2*(n-1)*(n-2)) + b^2*(n-2)/(n-1)*Integrate[(c+d*x)*(b*Csc[e+f*x])^(n-2),x] /;
FreeQ[{b,c,d,e,f},x] && GtQ[n,1] && NeQ[n,2]

Integrate[(c_.+d_*x_)^m_*(b_*Csc[e_.+f_*x_])^n_,x_] := -b^2*(c+d*x)^m*Cot[e+f*x]*(b*Csc[e+f*x])^(n-2)/(f*(n-1)) - b^2*d*m*(c+d*x)^(m-1)*(b*Csc[e+f*x])^(n-2)/(f^2*(n-1)*(n-2)) + b^2*(n-2)/(n-1)*Integrate[(c+d*x)^m*(b*Csc[e+f*x])^(n-2),x] + b^2*d^2*m*(m-1)/(f^2*(n-1)*(n-2))*Integrate[(c+d*x)^(m-2)*(b*Csc[e+f*x])^(n-2),x] /;
FreeQ[{b,c,d,e,f},x] && GtQ[n,1] && NeQ[n,2] && GtQ[m,1]

Integrate[(c_.+d_*x_)*(b_*Csc[e_.+f_*x_])^n_,x_] := d*(b*Csc[e+f*x])^n/(f^2*n^2) + (c+d*x)*Cos[e+f*x]*(b*Csc[e+f*x])^(n+1)/(b*f*n) + (n+1)/(b^2*n)*Integrate[(c+d*x)*(b*Csc[e+f*x])^(n+2),x] /;
FreeQ[{b,c,d,e,f},x] && LtQ[n,-1]

