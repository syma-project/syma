Integrate[(A_+B_*Cot[d_.+e_*x_])/(a_.+b_*Cot[d_.+e_*x_]+c_*Cot[d_.+e_*x_]^2),x_] := Module[{q=Rt[b^2-4*a*c,2]}, (B+(b*B-2*A*c)/q)*Integrate[1/Simp[b+q+2*c*Cot[d+e*x],x],x] + (B-(b*B-2*A*c)/q)*Integrate[1/Simp[b-q+2*c*Cot[d+e*x],x],x]] /;
FreeQ[{a,b,c,d,e,A,B},x] && NeQ[b^2-4*a*c,0]

Integrate[(A_+B_*Tan[d_.+e_*x_])*(a_.+b_*Tan[d_.+e_*x_]+c_*Tan[d_.+e_*x_]^2)^n_,x_] := Integrate[ExpandTrig[(A+B*Tan[d+e*x])*(a+b*Tan[d+e*x]+c*Tan[d+e*x]^2)^n,x],x] /;
FreeQ[{a,b,c,d,e,A,B},x] && NeQ[b^2-4*a*c,0] && IntegerQ[n]

Integrate[(A_+B_*Cot[d_.+e_*x_])*(a_.+b_*Cot[d_.+e_*x_]+c_*Cot[d_.+e_*x_]^2)^n_,x_] := Integrate[ExpandTrig[(A+B*Cot[d+e*x])*(a+b*Cot[d+e*x]+c*Cot[d+e*x]^2)^n,x],x] /;
FreeQ[{a,b,c,d,e,A,B},x] && NeQ[b^2-4*a*c,0] && IntegerQ[n]

