FreeQ[{b,c,d,e,f},x] && LtQ[n,-1] && GtQ[m,1]

Integrate[(c_.+d_*x_)^m_*(b_*Csc[e_.+f_*x_])^n_,x_] := (b*Sin[e+f*x])^n*(b*Csc[e+f*x])^n*Integrate[(c+d*x)^m/(b*Sin[e+f*x])^n,x] /;
FreeQ[{b,c,d,e,f,m,n},x] && Not[IntegerQ[n]]

Integrate[(c_.+d_*x_)^m_*(a_+b_*Csc[e_.+f_*x_])^n_.,x_] := Integrate[ExpandIntegrand[(c+d*x)^m,(a+b*Csc[e+f*x])^n,x],x] /;
FreeQ[{a,b,c,d,e,f,m},x] && IGtQ[m,0] && IGtQ[n,0]

Integrate[(c_.+d_*x_)^m_*(a_+b_*Csc[e_.+f_*x_])^n_.,x_] := Integrate[ExpandIntegrand[(c+d*x)^m,Sin[e+f*x]^(-n)/(b+a*Sin[e+f*x])^(-n),x],x] /;
FreeQ[{a,b,c,d,e,f},x] && ILtQ[n,0] && IGtQ[m,0]

Integrate[(c_.+d_*x_)^m_*Csc[e_.+f_*x_]^n_.,x_] := If[MatchQ[f,f1_*Complex[0,j_]], If[MatchQ[e,e1_.+Pi/2], Unintegrable[(c+d*x)^m*Sech[I*(e-Pi/2)+I*f*x]^n,x], (-I)^n*Unintegrable[(c+d*x)^m*Csch[-I*e-I*f*x]^n,x]], If[MatchQ[e,e1_.+Pi/2], Unintegrable[(c+d*x)^m*Sec[e-Pi/2+f*x]^n,x], Unintegrable[(c+d*x)^m*Csc[e+f*x]^n,x]]] /;
