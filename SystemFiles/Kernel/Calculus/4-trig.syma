Integrate[(A_.+B_*Cos[d_.+e_*x_])*(a_.+b_*Cos[d_.+e_*x_]+c_*Sin[d_.+e_*x_])^n_,x_] := -(c*B+c*A*Cos[d+e*x]+(a*B-b*A)*Sin[d+e*x])*(a+b*Cos[d+e*x]+c*Sin[d+e*x])^(n+1)/ (e*(n+1)*(a^2-b^2-c^2)) + 1/((n+1)*(a^2-b^2-c^2))*Integrate[(a+b*Cos[d+e*x]+c*Sin[d+e*x])^(n+1)* Simp[(n+1)*(a*A-b*B)+(n+2)*(a*B-b*A)*Cos[d+e*x]-(n+2)*c*A*Sin[d+e*x],x],x] /;
FreeQ[{a,b,c,d,e,A,B},x] && LtQ[n,-1] && NeQ[a^2-b^2-c^2,0] && NeQ[n,-2]

