FreeQ[{a,b,e,m,p},x] && BinomialQ[u,x] && Not[BinomialMatchQ[u,x]]

Integrate[x_^m_*Sec[a_.+b_*x_^n_.]^p_*Tan[a_.+b_*x_^n_.]^q_.,x_] := x^(m-n+1)*Sec[a+b*x^n]^p/(b*n*p) - (m-n+1)/(b*n*p)*Integrate[x^(m-n)*Sec[a+b*x^n]^p,x] /;
FreeQ[{a,b,p},x] && IntegerQ[n] && GeQ[m,n] && EqQ[q,1]

