FreeQ[{a,b,c,d},x] && NeQ[b^2-d^2,0]

Integrate[Sin[a_./(c_.+d_*x_)]^n_.,x_] := -1/d*Subst[Integrate[Sin[a*x]^n/x^2,x],x,1/(c+d*x)] /;
FreeQ[{a,c,d},x] && IGtQ[n,0]

Integrate[Cos[a_./(c_.+d_*x_)]^n_.,x_] := -1/d*Subst[Integrate[Cos[a*x]^n/x^2,x],x,1/(c+d*x)] /;
FreeQ[{a,c,d},x] && IGtQ[n,0]

