Integrate[Csc[e_.+f_*x_]^3/(a_+b_*Csc[e_.+f_*x_]),x_] := -Cot[e+f*x]/(b*f) - a/b*Integrate[Csc[e+f*x]^2/(a+b*Csc[e+f*x]),x] /;
