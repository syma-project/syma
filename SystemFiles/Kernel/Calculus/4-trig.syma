Integrate[(g_*Cos[e_.+f_*x_])^p_*(a_+b_*Sin[e_.+f_*x_])^m_,x_] := b*(g*Cos[e+f*x])^(p+1)*(a+b*Sin[e+f*x])^m/(a*f*g*(2*m+p+1)) +    (m+p+1)/(a*(2*m+p+1))*Integrate[(g*Cos[e+f*x])^p*(a+b*Sin[e+f*x])^(m+1),x] /;
