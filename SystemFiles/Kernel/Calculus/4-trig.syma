FreeQ[{a,b,c,d},x] && NeQ[a^2-b^2,0]

Integrate[1/(a_+b_*Sin[c_.+d_*x_]),x_] := With[{e=FreeFactors[Tan[(c+d*x)/2],x]}, 2*e/d*Subst[Integrate[1/(a+2*b*e*x+a*e^2*x^2),x],x,Tan[(c+d*x)/2]/e]] /;
FreeQ[{a,b,c,d},x] && NeQ[a^2-b^2,0]

Integrate[1/Sqrt[a_+b_*Sin[c_.+d_*x_]],x_] := 2/(d*Sqrt[a+b])*EllipticF[1/2*(c-Pi/2+d*x),2*b/(a+b)] /;
FreeQ[{a,b,c,d},x] && NeQ[a^2-b^2,0] && GtQ[a+b,0]

Integrate[1/Sqrt[a_+b_*Sin[c_.+d_*x_]],x_] := 2/(d*Sqrt[a-b])*EllipticF[1/2*(c+Pi/2+d*x),-2*b/(a-b)] /;
FreeQ[{a,b,c,d},x] && NeQ[a^2-b^2,0] && GtQ[a-b,0]

Integrate[1/Sqrt[a_+b_*Sin[c_.+d_*x_]],x_] := Sqrt[(a+b*Sin[c+d*x])/(a+b)]/Sqrt[a+b*Sin[c+d*x]]*Integrate[1/Sqrt[a/(a+b)+b/(a+b)*Sin[c+d*x]],x] /;
FreeQ[{a,b,c,d},x] && NeQ[a^2-b^2,0] && Not[GtQ[a+b,0]]

Integrate[(a_+b_*Sin[c_.+d_*x_])^n_,x_] := -b*Cos[c+d*x]*(a+b*Sin[c+d*x])^(n+1)/(d*(n+1)*(a^2-b^2)) + 1/((n+1)*(a^2-b^2))*Integrate[(a+b*Sin[c+d*x])^(n+1)*Simp[a*(n+1)-b*(n+2)*Sin[c+d*x],x],x] /;
FreeQ[{a,b,c,d},x] && NeQ[a^2-b^2,0] && LtQ[n,-1] && IntegerQ[2*n]

