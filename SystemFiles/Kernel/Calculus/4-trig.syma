FreeQ[{a,b,e,f,g},x] && EqQ[a^2-b^2,0]

Integrate[(g_*Cos[e_.+f_*x_])^p_*(a_+b_*Sin[e_.+f_*x_])^m_,x_] := -b*(g*Cos[e+f*x])^(p+1)*(a+b*Sin[e+f*x])^(m-1)/(f*g*(m+p)) + a*(2*m+p-1)/(m+p)*Integrate[(g*Cos[e+f*x])^p*(a+b*Sin[e+f*x])^(m-1),x] /;
FreeQ[{a,b,e,f,g,m,p},x] && EqQ[a^2-b^2,0] && GtQ[m,0] && NeQ[m+p,0] && IntegersQ[2*m,2*p]

Integrate[(g_*Cos[e_.+f_*x_])^p_*(a_+b_*Sin[e_.+f_*x_])^m_,x_] := g*(g*Cos[e+f*x])^(p-1)*(a+b*Sin[e+f*x])^(m+1)/(b*f*(m+p)) + g^2*(p-1)/(a*(m+p))*Integrate[(g*Cos[e+f*x])^(p-2)*(a+b*Sin[e+f*x])^(m+1),x] /;
FreeQ[{a,b,e,f,g},x] && EqQ[a^2-b^2,0] && LtQ[m,-1] && GtQ[p,1] && (GtQ[m,-2] || EqQ[2*m+p+1,0] || EqQ[m,-2] && IntegerQ[p]) && NeQ[m+p,0] && IntegersQ[2*m,2*p]

