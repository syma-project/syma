FreeQ[{a,b,c,d,e,f,m,n},x]

Integrate[u_^m_*(a_.+b_*Sec[v_])^n_.,x_] := Integrate[ExpandToSum[u,x]^m*(a+b*Sec[ExpandToSum[v,x]])^n,x] /;
FreeQ[{a,b,m,n},x] && LinearQ[{u,v},x] && Not[LinearMatchQ[{u,v},x]]

Integrate[u_^m_*(a_.+b_*Csc[v_])^n_.,x_] := Integrate[ExpandToSum[u,x]^m*(a+b*Csc[ExpandToSum[v,x]])^n,x] /;
FreeQ[{a,b,m,n},x] && LinearQ[{u,v},x] && Not[LinearMatchQ[{u,v},x]]

