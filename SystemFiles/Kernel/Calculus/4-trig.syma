Integrate[(a_+b_*Csc[e_.+f_*x_])*(d_*Csc[e_.+f_*x_])^n_.,x_] := a*Integrate[(d*Csc[e+f*x])^n,x] + b/d*Integrate[(d*Csc[e+f*x])^(n+1),x] /;
FreeQ[{a,b,d,e,f,n},x]

Integrate[(a_+b_*Csc[e_.+f_*x_])^2*(d_*Csc[e_.+f_*x_])^n_.,x_] := 2*a*b/d*Integrate[(d*Csc[e+f*x])^(n+1),x] + Integrate[(d*Csc[e+f*x])^n*(a^2+b^2*Csc[e+f*x]^2),x] /;
