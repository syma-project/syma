FreeQ[{a,b,c,d,e},x] && NeQ[2*c*d-b*e,0] (* Integrate[x_^m_*Tan[a_.+b_*x_+c_*x_^2],x_] := -x^(m-1)*Log[Cos[a+b*x+c*x^2]]/(2*c) - b/(2*c)*Integrate[x^(m-1)*Tan[a+b*x+c*x^2],x] + (m-1)/(2*c)*Integrate[x^(m-2)*Log[Cos[a+b*x+c*x^2]],x] /; FreeQ[{a,b,c},x] && GtQ[m,1] *) (* Integrate[x_^m_*Cot[a_.+b_*x_+c_*x_^2],x_] := x^(m-1)*Log[Sin[a+b*x+c*x^2]]/(2*c) - b/(2*c)*Integrate[x^(m-1)*Cot[a+b*x+c*x^2],x] - (m-1)/(2*c)*Integrate[x^(m-2)*Log[Sin[a+b*x+c*x^2]],x] /; FreeQ[{a,b,c},x] && GtQ[m,1]*)

