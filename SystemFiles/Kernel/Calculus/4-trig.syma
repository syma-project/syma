FreeQ[{a,b,c,d},x] && NeQ[b^2-d^2,0]

Integrate[Sin[a_.+b_*x_]*Cot[c_.+d_*x_],x_] := Integrate[-E^(-I*(a+b*x))/2 + E^(I*(a+b*x))/2 + E^(-I*(a+b*x))/(1-E^(2*I*(c+d*x))) - E^(I*(a+b*x))/(1-E^(2*I*(c+d*x))),x] /;
FreeQ[{a,b,c,d},x] && NeQ[b^2-d^2,0]

