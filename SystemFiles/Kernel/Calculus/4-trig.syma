FreeQ[{a,c,d},x] && EqQ[a*c+d,0]

Integrate[x_^2/(c_*Cos[a_*x_]+d_*x_*Sin[a_*x_])^2,x_] := -x/(a*d*Cos[a*x]*(c*Cos[a*x]+d*x*Sin[a*x])) + 1/d^2*Integrate[1/Cos[a*x]^2,x] /;
FreeQ[{a,c,d},x] && EqQ[a*c-d,0]

