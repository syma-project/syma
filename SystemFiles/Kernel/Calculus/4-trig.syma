Integrate[(a_+b_*Sin[c_.+d_*x_])^n_,x_] := -b*Cos[c+d*x]*(a+b*Sin[c+d*x])^(n-1)/(d*n) + a*(2*n-1)/n*Integrate[(a+b*Sin[c+d*x])^(n-1),x] /;
