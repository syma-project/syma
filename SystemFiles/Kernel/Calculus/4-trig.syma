Integrate[(a_.+b_*Csc[c_.+d_*x_^n_])^p_.,x_] := 1/n*Subst[Integrate[x^(1/n-1)*(a+b*Csc[c+d*x])^p,x],x,x^n] /;
FreeQ[{a,b,c,d,p},x] && IGtQ[1/n,0] && IntegerQ[p]

