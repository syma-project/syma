Integrate[(c_+d_*Csc[e_.+f_*x_])/(a_+b_*Csc[e_.+f_*x_]),x_] := c*x/a - (b*c-a*d)/a*Integrate[Csc[e+f*x]/(a+b*Csc[e+f*x]),x] /;
FreeQ[{a,b,c,d,e,f},x] && NeQ[b*c-a*d,0]

Integrate[(c_+d_*Csc[e_.+f_*x_])/Sqrt[a_+b_*Csc[e_.+f_*x_]],x_] := c/a*Integrate[Sqrt[a+b*Csc[e+f*x]],x] - (b*c-a*d)/a*Integrate[Csc[e+f*x]/Sqrt[a+b*Csc[e+f*x]],x] /;
FreeQ[{a,b,c,d,e,f},x] && NeQ[b*c-a*d,0] && EqQ[a^2-b^2,0]

