FreeQ[{a,b,c,d},x] && GtQ[a^2-b^2,0] && PosQ[a]

Integrate[1/(a_+b_*Sin[c_.+d_*x_]),x_] := With[{q=Rt[a^2-b^2,2]}, -x/q - 2/(d*q)*ArcTan[b*Cos[c+d*x]/(a-q+b*Sin[c+d*x])]] /;
FreeQ[{a,b,c,d},x] && GtQ[a^2-b^2,0] && NegQ[a]

