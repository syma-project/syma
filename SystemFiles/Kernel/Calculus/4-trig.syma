Integrate[(a_.+b_*Tan[c_.+d_*u_^n_])^p_.,x_] := 1/Coefficient[u,x,1]*Subst[Integrate[(a+b*Tan[c+d*x^n])^p,x],x,u] /;
FreeQ[{a,b,c,d,n,p},x] && LinearQ[u,x] && NeQ[u,x]

Integrate[(a_.+b_*Cot[c_.+d_*u_^n_])^p_.,x_] := 1/Coefficient[u,x,1]*Subst[Integrate[(a+b*Cot[c+d*x^n])^p,x],x,u] /;
FreeQ[{a,b,c,d,n,p},x] && LinearQ[u,x] && NeQ[u,x]

Integrate[(a_.+b_*Tan[u_])^p_.,x_] := Integrate[(a+b*Tan[ExpandToSum[u,x]])^p,x] /;
FreeQ[{a,b,p},x] && BinomialQ[u,x] && Not[BinomialMatchQ[u,x]]

Integrate[(a_.+b_*Cot[u_])^p_.,x_] := Integrate[(a+b*Cot[ExpandToSum[u,x]])^p,x] /;
FreeQ[{a,b,p},x] && BinomialQ[u,x] && Not[BinomialMatchQ[u,x]]

Integrate[x_^m_*(a_.+b_*Tan[c_.+d_*x_^n_])^p_.,x_] := 1/n*Subst[Integrate[x^(Simplify[(m+1)/n]-1)*(a+b*Tan[c+d*x])^p,x],x,x^n] /;
FreeQ[{a,b,c,d,m,n,p},x] && IGtQ[Simplify[(m+1)/n],0] && IntegerQ[p]

