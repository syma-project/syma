FreeQ[{a,b,c,d,e,A,B,C},x] && LtQ[n,-1] && NeQ[a^2-b^2-c^2,0] && NeQ[n,-2]

Integrate[(A_.+C_*Sin[d_.+e_*x_])*(a_.+b_*Cos[d_.+e_*x_]+c_*Sin[d_.+e_*x_])^n_,x_] := (b*C+(a*C-c*A)*Cos[d+e*x]+b*A*Sin[d+e*x])*(a+b*Cos[d+e*x]+c*Sin[d+e*x])^(n+1)/ (e*(n+1)*(a^2-b^2-c^2)) + 1/((n+1)*(a^2-b^2-c^2))*Integrate[(a+b*Cos[d+e*x]+c*Sin[d+e*x])^(n+1)* Simp[(n+1)*(a*A-c*C)-(n+2)*b*A*Cos[d+e*x]+(n+2)*(a*C-c*A)*Sin[d+e*x],x],x] /;
