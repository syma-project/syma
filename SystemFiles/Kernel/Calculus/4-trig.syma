(* Integrate rules: 4 Trig functions *)
(* Source: Rubi-4.16.1.0, 2087 rules from 56 files *)

Integrate[Csc[c_.+d_*x_]^n_,x_] := -1/d*Subst[Integrate[ExpandIntegrand[(1+x^2)^(n/2-1),x],x],x,Cot[c+d*x]] /;
FreeQ[{c,d},x] && IGtQ[n/2,0]

Integrate[(b_*Csc[c_.+d_*x_])^n_,x_] := -b*Cos[c+d*x]*(b*Csc[c+d*x])^(n-1)/(d*(n-1)) + b^2*(n-2)/(n-1)*Integrate[(b*Csc[c+d*x])^(n-2),x] /;
FreeQ[{b,c,d},x] && GtQ[n,1] && IntegerQ[2*n]

Integrate[(b_*Csc[c_.+d_*x_])^n_,x_] := Cos[c+d*x]*(b*Csc[c+d*x])^(n+1)/(b*d*n) + (n+1)/(b^2*n)*Integrate[(b*Csc[c+d*x])^(n+2),x] /;
FreeQ[{b,c,d},x] && LtQ[n,-1] && IntegerQ[2*n]

Integrate[(b_*Csc[c_.+d_*x_])^n_,x_] := (b*Csc[c+d*x])^n*Sin[c+d*x]^n*Integrate[1/Sin[c+d*x]^n,x] /;
FreeQ[{b,c,d},x] && EqQ[n^2,1/4]

Integrate[(b_*Csc[c_.+d_*x_])^n_,x_] := (b*Csc[c+d*x])^(n-1)*((Sin[c+d*x]/b)^(n-1)*Integrate[1/(Sin[c+d*x]/b)^n,x]) /;
FreeQ[{b,c,d,n},x] && Not[IntegerQ[n]]

Integrate[(a_+b_*Csc[c_.+d_*x_])^2,x_] := a^2*x + 2*a*b*Integrate[Csc[c+d*x],x] + b^2*Integrate[Csc[c+d*x]^2,x] /;
FreeQ[{a,b,c,d},x]

Integrate[Sqrt[a_+b_*Csc[c_.+d_*x_]],x_] := -2*b/d*Subst[Integrate[1/(a+x^2),x],x,b*Cot[c+d*x]/Sqrt[a+b*Csc[c+d*x]]] /;
FreeQ[{a,b,c,d},x] && EqQ[a^2-b^2,0]

Integrate[(a_+b_*Csc[c_.+d_*x_])^n_,x_] := -b^2*Cot[c+d*x]*(a+b*Csc[c+d*x])^(n-2)/(d*(n-1)) + a/(n-1)*Integrate[(a+b*Csc[c+d*x])^(n-2)*(a*(n-1)+b*(3*n-4)*Csc[c+d*x]),x] /;
FreeQ[{a,b,c,d},x] && EqQ[a^2-b^2,0] && GtQ[n,1] && IntegerQ[2*n]

Integrate[1/Sqrt[a_+b_*Csc[c_.+d_*x_]],x_] := 1/a*Integrate[Sqrt[a+b*Csc[c+d*x]],x] -    b/a*Integrate[Csc[c+d*x]/Sqrt[a+b*Csc[c+d*x]],x] /;
FreeQ[{a,b,c,d},x] && EqQ[a^2-b^2,0]

Integrate[(a_+b_*Csc[c_.+d_*x_])^n_,x_] := -Cot[c+d*x]*(a+b*Csc[c+d*x])^n/(d*(2*n+1)) + 1/(a^2*(2*n+1))*Integrate[(a+b*Csc[c+d*x])^(n+1)*(a*(2*n+1)-b*(n+1)*Csc[c+d*x]),x] /;
FreeQ[{a,b,c,d},x] && EqQ[a^2-b^2,0] && LeQ[n,-1] && IntegerQ[2*n]

