Integrate[u_,x_] := With[{lst=FunctionOfLog[Cancel[x*u],x]}, 1/lst[[3]]*Subst[Integrate[lst[[1]],x],x,Log[lst[[2]]]] /; Not[FalseQ[lst]]] /;
NonsumQ[u]]

Integrate[u_*Log[Gamma[v_]],x_] := (Log[Gamma[v]]-LogGamma[v])*Integrate[u,x] + Integrate[u*LogGamma[v],x]

Integrate[u_*(a_*x_^m_.+b_*x_^r_*Log[c_*x_^n_.]^q_.)^p_.,x_] := Integrate[u*x^(p*r)*(a*x^(m-r)+b*Log[c*x^n]^q)^p,x] /;
FreeQ[{a,b,c,m,n,p,q,r},x] && IntegerQ[p]

