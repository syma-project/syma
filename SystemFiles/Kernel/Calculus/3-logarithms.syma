Integrate[Log[c_*x_^n_.],x_] := x*Log[c*x^n] - n*x /;
FreeQ[{c,n},x]

Integrate[(a_.+b_*Log[c_*x_^n_.])^p_.,x_] := x*(a+b*Log[c*x^n])^p - b*n*p*Integrate[(a+b*Log[c*x^n])^(p-1),x] /;
FreeQ[{a,b,c,n},x] && GtQ[p,0] && IntegerQ[2*p]

Integrate[(a_.+b_*Log[c_*x_^n_.])^p_,x_] := x*(a+b*Log[c*x^n])^(p+1)/(b*n*(p+1)) - 1/(b*n*(p+1))*Integrate[(a+b*Log[c*x^n])^(p+1),x] /;
