Integrate[(e_.+f_*x_)^m_*(a_.+b_*ArcTan[c_+d_*x_])^p_.,x_] := 1/d*Subst[Integrate[(f*x/d)^m*(a+b*ArcTan[x])^p,x],x,c+d*x] /;
FreeQ[{a,b,c,d,e,f,m},x] && EqQ[d*e-c*f,0] && IGtQ[p,0]

Integrate[(e_.+f_*x_)^m_*(a_.+b_*ArcCot[c_+d_*x_])^p_.,x_] := 1/d*Subst[Integrate[(f*x/d)^m*(a+b*ArcCot[x])^p,x],x,c+d*x] /;
FreeQ[{a,b,c,d,e,f,m},x] && EqQ[d*e-c*f,0] && IGtQ[p,0]

