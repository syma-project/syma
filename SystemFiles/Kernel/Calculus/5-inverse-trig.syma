FreeQ[{a,b,c,d,e,f},x] && IGtQ[p,0] && ILtQ[m,-1]

Integrate[(e_.+f_*x_)^m_*(a_.+b_*ArcCot[c_+d_*x_])^p_.,x_] := (e+f*x)^(m+1)*(a+b*ArcCot[c+d*x])^p/(f*(m+1)) + b*d*p/(f*(m+1))*Integrate[(e+f*x)^(m+1)*(a+b*ArcCot[c+d*x])^(p-1)/(1+(c+d*x)^2),x] /;
FreeQ[{a,b,c,d,e,f},x] && IGtQ[p,0] && ILtQ[m,-1]

Integrate[(e_.+f_*x_)^m_*(a_.+b_*ArcTan[c_+d_*x_])^p_.,x_] := 1/d*Subst[Integrate[((d*e-c*f)/d+f*x/d)^m*(a+b*ArcTan[x])^p,x],x,c+d*x] /;
FreeQ[{a,b,c,d,e,f,m,p},x] && IGtQ[p,0]

Integrate[(e_.+f_*x_)^m_*(a_.+b_*ArcCot[c_+d_*x_])^p_.,x_] := 1/d*Subst[Integrate[((d*e-c*f)/d+f*x/d)^m*(a+b*ArcCot[x])^p,x],x,c+d*x] /;
FreeQ[{a,b,c,d,e,f,m,p},x] && IGtQ[p,0]

Integrate[(e_.+f_*x_)^m_*(a_.+b_*ArcTan[c_+d_*x_])^p_,x_] := Unintegrable[(e+f*x)^m*(a+b*ArcTan[c+d*x])^p,x] /;
FreeQ[{a,b,c,d,e,f,m,p},x] && Not[IGtQ[p,0]]

Integrate[(e_.+f_*x_)^m_*(a_.+b_*ArcCot[c_+d_*x_])^p_,x_] := Unintegrable[(e+f*x)^m*(a+b*ArcCot[c+d*x])^p,x] /;
FreeQ[{a,b,c,d,e,f,m,p},x] && Not[IGtQ[p,0]]

Integrate[ArcTan[a_+b_*x_]/(c_+d_*x_^n_.),x_] := I/2*Integrate[Log[1-I*a-I*b*x]/(c+d*x^n),x] - I/2*Integrate[Log[1+I*a+I*b*x]/(c+d*x^n),x] /;
FreeQ[{a,b,c,d},x] && RationalQ[n]

Integrate[ArcCot[a_+b_*x_]/(c_+d_*x_^n_.),x_] := I/2*Integrate[Log[(-I+a+b*x)/(a+b*x)]/(c+d*x^n),x] - I/2*Integrate[Log[(I+a+b*x)/(a+b*x)]/(c+d*x^n),x] /;
FreeQ[{a,b,c,d},x] && RationalQ[n]

Integrate[ArcTan[a_+b_*x_]/(c_+d_*x_^n_),x_] := Unintegrable[ArcTan[a+b*x]/(c+d*x^n),x] /;
FreeQ[{a,b,c,d,n},x] && Not[RationalQ[n]]

Integrate[ArcCot[a_+b_*x_]/(c_+d_*x_^n_),x_] := Unintegrable[ArcCot[a+b*x]/(c+d*x^n),x] /;
FreeQ[{a,b,c,d,n},x] && Not[RationalQ[n]]

Integrate[(A_.+B_*x_+C_*x_^2)^q_*(a_.+b_*ArcTan[c_+d_*x_])^p_.,x_] := 1/d*Subst[Integrate[(C/d^2+C/d^2*x^2)^q*(a+b*ArcTan[x])^p,x],x,c+d*x] /;
FreeQ[{a,b,c,d,A,B,C,p,q},x] && EqQ[B*(1+c^2)-2*A*c*d,0] && EqQ[2*c*C-B*d,0]

Integrate[(A_.+B_*x_+C_*x_^2)^q_*(a_.+b_*ArcCot[c_+d_*x_])^p_.,x_] := 1/d*Subst[Integrate[(C/d^2+C/d^2*x^2)^q*(a+b*ArcCot[x])^p,x],x,c+d*x] /;
FreeQ[{a,b,c,d,A,B,C,p,q},x] && EqQ[B*(1+c^2)-2*A*c*d,0] && EqQ[2*c*C-B*d,0]

Integrate[(e_.+f_*x_)^m_*(A_.+B_*x_+C_*x_^2)^q_*(a_.+b_*ArcTan[c_+d_*x_])^p_.,x_] := 1/d*Subst[Integrate[((d*e-c*f)/d+f*x/d)^m*(C/d^2+C/d^2*x^2)^q*(a+b*ArcTan[x])^p,x],x,c+d*x] /;
FreeQ[{a,b,c,d,e,f,A,B,C,m,p,q},x] && EqQ[B*(1+c^2)-2*A*c*d,0] && EqQ[2*c*C-B*d,0]

Integrate[(e_.+f_*x_)^m_*(A_.+B_*x_+C_*x_^2)^q_*(a_.+b_*ArcCot[c_+d_*x_])^p_.,x_] := 1/d*Subst[Integrate[((d*e-c*f)/d+f*x/d)^m*(C/d^2+C/d^2*x^2)^q*(a+b*ArcCot[x])^p,x],x,c+d*x] /;
FreeQ[{a,b,c,d,e,f,A,B,C,m,p,q},x] && EqQ[B*(1+c^2)-2*A*c*d,0] && EqQ[2*c*C-B*d,0]

Integrate[E^(n_*ArcTan[a_*x_]),x_] := Integrate[((1-I*a*x)^((I*n+1)/2)/((1+I*a*x)^((I*n-1)/2)*Sqrt[1+a^2*x^2])),x] /;
FreeQ[a,x] && IntegerQ[(I*n-1)/2]

