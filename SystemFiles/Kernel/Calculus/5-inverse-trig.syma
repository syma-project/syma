FreeQ[{a,m},x] && IntegerQ[(I*n-1)/2]

Integrate[E^(n_*ArcTan[a_*x_]),x_] := Integrate[(1-I*a*x)^(I*n/2)/(1+I*a*x)^(I*n/2),x] /;
FreeQ[{a,n},x] && Not[IntegerQ[(I*n-1)/2]]

Integrate[x_^m_*E^(n_*ArcTan[a_*x_]),x_] := Integrate[x^m*(1-I*a*x)^(I*n/2)/(1+I*a*x)^(I*n/2),x] /;
FreeQ[{a,m,n},x] && Not[IntegerQ[(I*n-1)/2]]

Integrate[u_*(c_+d_*x_)^p_*E^(n_*ArcTan[a_*x_]),x_] := c^p*Integrate[u*(1+d*x/c)^p*(1-I*a*x)^(I*n/2)/(1+I*a*x)^(I*n/2),x] /;
FreeQ[{a,c,d,n,p},x] && EqQ[a^2*c^2+d^2,0] && (IntegerQ[p] || GtQ[c,0])

Integrate[u_*(c_+d_*x_)^p_*E^(n_*ArcTan[a_*x_]),x_] := Integrate[u*(c+d*x)^p*(1-I*a*x)^(I*n/2)/(1+I*a*x)^(I*n/2),x] /;
FreeQ[{a,c,d,n,p},x] && EqQ[a^2*c^2+d^2,0] && Not[IntegerQ[p] || GtQ[c,0]]

Integrate[u_*(c_+d_./x_)^p_*E^(n_*ArcTan[a_*x_]),x_] := d^p*Integrate[u/x^p*(1+c*x/d)^p*E^(n*ArcTan[a*x]),x] /;
FreeQ[{a,c,d,n},x] && EqQ[c^2+a^2*d^2,0] && IntegerQ[p]

Integrate[u_*(c_+d_./x_)^p_*E^(n_*ArcTanh[a_*x_]),x_] := (-1)^(n/2)*c^p*Integrate[u*(1+d/(c*x))^p*(1-1/(I*a*x))^(I*n/2)/(1+1/(I*a*x))^(I*n/2),x] /;
