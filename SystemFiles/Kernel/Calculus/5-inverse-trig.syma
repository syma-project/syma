Integrate[(a_.+b_*ArcTan[c_*x_])^p_/(x_*Sqrt[d_+e_*x_^2]),x_] := 1/Sqrt[d]*Subst[Integrate[(a+b*x)^p*Csc[x],x],x,ArcTan[c*x]] /;
FreeQ[{a,b,c,d,e},x] && EqQ[e,c^2*d] && IGtQ[p,0] && GtQ[d,0]

