Integrate[(a_.+b_*ArcCot[c_*x_])^p_*PolyLog[k_,u_]/(d_+e_*x_^2),x_] := I*(a+b*ArcCot[c*x])^p*PolyLog[k+1,u]/(2*c*d) + b*p*I/2*Integrate[(a+b*ArcCot[c*x])^(p-1)*PolyLog[k+1,u]/(d+e*x^2),x] /;
FreeQ[{a,b,c,d,e,k},x] && IGtQ[p,0] && EqQ[e,c^2*d] && EqQ[u^2-(1-2*I/(I-c*x))^2,0]

Integrate[1/((d_+e_*x_^2)*(a_.+b_*ArcCot[c_*x_])*(a_.+b_*ArcTan[c_*x_])),x_] := (-Log[a+b*ArcCot[c*x]]+Log[a+b*ArcTan[c*x]])/(b*c*d*(2*a+b*ArcCot[c*x]+b*ArcTan[c*x])) /;
FreeQ[{a,b,c,d,e},x] && EqQ[e,c^2*d]

Integrate[(a_.+b_*ArcCot[c_*x_])^q_*(a_.+b_*ArcTan[c_*x_])^p_./(d_+e_*x_^2),x_] := -(a+b*ArcCot[c*x])^(q+1)*(a+b*ArcTan[c*x])^p/(b*c*d*(q+1)) + p/(q+1)*Integrate[(a+b*ArcCot[c*x])^(q+1)*(a+b*ArcTan[c*x])^(p-1)/(d+e*x^2),x] /;
FreeQ[{a,b,c,d,e},x] && EqQ[e,c^2*d] && IGtQ[p,0] && IGeQ[q,p]

Integrate[(a_.+b_*ArcTan[c_*x_])^q_*(a_.+b_*ArcCot[c_*x_])^p_./(d_+e_*x_^2),x_] := (a+b*ArcTan[c*x])^(q+1)*(a+b*ArcCot[c*x])^p/(b*c*d*(q+1)) + p/(q+1)*Integrate[(a+b*ArcTan[c*x])^(q+1)*(a+b*ArcCot[c*x])^(p-1)/(d+e*x^2),x] /;
FreeQ[{a,b,c,d,e},x] && EqQ[e,c^2*d] && IGtQ[p,0] && IGeQ[q,p]

Integrate[ArcTan[a_*x_]/(c_+d_*x_^n_.),x_] := I/2*Integrate[Log[1-I*a*x]/(c+d*x^n),x] - I/2*Integrate[Log[1+I*a*x]/(c+d*x^n),x] /;
FreeQ[{a,c,d},x] && IntegerQ[n] && Not[EqQ[n,2] && EqQ[d,a^2*c]]

Integrate[ArcCot[a_*x_]/(c_+d_*x_^n_.),x_] := I/2*Integrate[Log[1-I/(a*x)]/(c+d*x^n),x] - I/2*Integrate[Log[1+I/(a*x)]/(c+d*x^n),x] /;
FreeQ[{a,c,d},x] && IntegerQ[n] && Not[EqQ[n,2] && EqQ[d,a^2*c]]

Integrate[Log[d_*x_^m_.]*ArcTan[c_*x_^n_.]/x_,x_] := I/2*Integrate[Log[d*x^m]*Log[1-I*c*x^n]/x,x] - I/2*Integrate[Log[d*x^m]*Log[1+I*c*x^n]/x,x] /;
FreeQ[{c,d,m,n},x]

Integrate[Log[d_*x_^m_.]*ArcCot[c_*x_^n_.]/x_,x_] := I/2*Integrate[Log[d*x^m]*Log[1-I/(c*x^n)]/x,x] - I/2*Integrate[Log[d*x^m]*Log[1+I/(c*x^n)]/x,x] /;
FreeQ[{c,d,m,n},x]

Integrate[Log[d_*x_^m_.]*(a_+b_*ArcTan[c_*x_^n_.])/x_,x_] := a*Integrate[Log[d*x^m]/x,x] + b*Integrate[(Log[d*x^m]*ArcTan[c*x^n])/x,x] /;
FreeQ[{a,b,c,d,m,n},x]

Integrate[Log[d_*x_^m_.]*(a_+b_*ArcCot[c_*x_^n_.])/x_,x_] := a*Integrate[Log[d*x^m]/x,x] + b*Integrate[(Log[d*x^m]*ArcCot[c*x^n])/x,x] /;
FreeQ[{a,b,c,d,m,n},x]

Integrate[(d_.+e_*Log[f_.+g_*x_^2])*(a_.+b_*ArcTan[c_*x_]),x_] := x*(d+e*Log[f+g*x^2])*(a+b*ArcTan[c*x]) - 2*e*g*Integrate[x^2*(a+b*ArcTan[c*x])/(f+g*x^2),x] - b*c*Integrate[x*(d+e*Log[f+g*x^2])/(1+c^2*x^2),x] /;
FreeQ[{a,b,c,d,e,f,g},x]

Integrate[(d_.+e_*Log[f_.+g_*x_^2])*(a_.+b_*ArcCot[c_*x_]),x_] := x*(d+e*Log[f+g*x^2])*(a+b*ArcCot[c*x]) - 2*e*g*Integrate[x^2*(a+b*ArcCot[c*x])/(f+g*x^2),x] + b*c*Integrate[x*(d+e*Log[f+g*x^2])/(1+c^2*x^2),x] /;
FreeQ[{a,b,c,d,e,f,g},x]

Integrate[Log[f_.+g_*x_^2]*ArcTan[c_*x_]/x_,x_] := (Log[f+g*x^2]-Log[1-I*c*x]-Log[1+I*c*x])*Integrate[ArcTan[c*x]/x,x] + I/2*Integrate[Log[1-I*c*x]^2/x,x] - I/2*Integrate[Log[1+I*c*x]^2/x,x] /;
FreeQ[{c,f,g},x] && EqQ[g,c^2*f]

Integrate[Log[f_.+g_*x_^2]*ArcCot[c_*x_]/x_,x_] := (Log[f+g*x^2]-Log[c^2*x^2]-Log[1-I/(c*x)]-Log[1+I/(c*x)])*Integrate[ArcCot[c*x]/x,x] + Integrate[Log[c^2*x^2]*ArcCot[c*x]/x,x] + I/2*Integrate[Log[1-I/(c*x)]^2/x,x] - I/2*Integrate[Log[1+I/(c*x)]^2/x,x] /;
FreeQ[{c,f,g},x] && EqQ[g,c^2*f]

Integrate[Log[f_.+g_*x_^2]*(a_+b_*ArcTan[c_*x_])/x_,x_] := a*Integrate[Log[f+g*x^2]/x,x] + b*Integrate[Log[f+g*x^2]*ArcTan[c*x]/x,x] /;
FreeQ[{a,b,c,f,g},x]

Integrate[Log[f_.+g_*x_^2]*(a_+b_*ArcCot[c_*x_])/x_,x_] := a*Integrate[Log[f+g*x^2]/x,x] + b*Integrate[Log[f+g*x^2]*ArcCot[c*x]/x,x] /;
FreeQ[{a,b,c,f,g},x]

Integrate[(d_+e_*Log[f_.+g_*x_^2])*(a_.+b_*ArcTan[c_*x_])/x_,x_] := d*Integrate[(a+b*ArcTan[c*x])/x,x] + e*Integrate[Log[f+g*x^2]*(a+b*ArcTan[c*x])/x,x] /;
FreeQ[{a,b,c,d,e,f,g},x]

Integrate[(d_+e_*Log[f_.+g_*x_^2])*(a_.+b_*ArcCot[c_*x_])/x_,x_] := d*Integrate[(a+b*ArcCot[c*x])/x,x] + e*Integrate[Log[f+g*x^2]*(a+b*ArcCot[c*x])/x,x] /;
FreeQ[{a,b,c,d,e,f,g},x]

Integrate[x_^m_*(d_.+e_*Log[f_.+g_*x_^2])*(a_.+b_*ArcTan[c_*x_]),x_] := x^(m+1)*(d+e*Log[f+g*x^2])*(a+b*ArcTan[c*x])/(m+1) - 2*e*g/(m+1)*Integrate[x^(m+2)*(a+b*ArcTan[c*x])/(f+g*x^2),x] - b*c/(m+1)*Integrate[x^(m+1)*(d+e*Log[f+g*x^2])/(1+c^2*x^2),x] /;
FreeQ[{a,b,c,d,e,f,g},x] && ILtQ[m/2,0]

Integrate[x_^m_*(d_.+e_*Log[f_.+g_*x_^2])*(a_.+b_*ArcCot[c_*x_]),x_] := x^(m+1)*(d+e*Log[f+g*x^2])*(a+b*ArcCot[c*x])/(m+1) - 2*e*g/(m+1)*Integrate[x^(m+2)*(a+b*ArcCot[c*x])/(f+g*x^2),x] + b*c/(m+1)*Integrate[x^(m+1)*(d+e*Log[f+g*x^2])/(1+c^2*x^2),x] /;
FreeQ[{a,b,c,d,e,f,g},x] && ILtQ[m/2,0]

Integrate[x_^m_*(d_.+e_*Log[f_.+g_*x_^2])*(a_.+b_*ArcTan[c_*x_]),x_] := With[{u=IntHide[x^m*(d+e*Log[f+g*x^2]),x]}, Dist[a+b*ArcTan[c*x],u,x] - b*c*Integrate[ExpandIntegrand[u/(1+c^2*x^2),x],x]] /;
FreeQ[{a,b,c,d,e,f,g},x] && IGtQ[(m+1)/2,0]

Integrate[x_^m_*(d_.+e_*Log[f_.+g_*x_^2])*(a_.+b_*ArcCot[c_*x_]),x_] := With[{u=IntHide[x^m*(d+e*Log[f+g*x^2]),x]}, Dist[a+b*ArcCot[c*x],u,x] + b*c*Integrate[ExpandIntegrand[u/(1+c^2*x^2),x],x]] /;
FreeQ[{a,b,c,d,e,f,g},x] && IGtQ[(m+1)/2,0]

Integrate[x_^m_*(d_.+e_*Log[f_.+g_*x_^2])*(a_.+b_*ArcTan[c_*x_]),x_] := With[{u=IntHide[x^m*(a+b*ArcTan[c*x]),x]}, Dist[d+e*Log[f+g*x^2],u,x] - 2*e*g*Integrate[ExpandIntegrand[x*u/(f+g*x^2),x],x]] /;
FreeQ[{a,b,c,d,e,f,g},x] && IntegerQ[m] && NeQ[m,-1]

Integrate[x_^m_*(d_.+e_*Log[f_.+g_*x_^2])*(a_.+b_*ArcCot[c_*x_]),x_] := With[{u=IntHide[x^m*(a+b*ArcCot[c*x]),x]}, Dist[d+e*Log[f+g*x^2],u,x] - 2*e*g*Integrate[ExpandIntegrand[x*u/(f+g*x^2),x],x]] /;
FreeQ[{a,b,c,d,e,f,g},x] && IntegerQ[m] && NeQ[m,-1]

Integrate[x_*(d_.+e_*Log[f_+g_*x_^2])*(a_.+b_*ArcTan[c_*x_])^2,x_] := (f+g*x^2)*(d+e*Log[f+g*x^2])*(a+b*ArcTan[c*x])^2/(2*g) -    e*x^2*(a+b*ArcTan[c*x])^2/2 - b/c*Integrate[(d+e*Log[f+g*x^2])*(a+b*ArcTan[c*x]),x] + b*c*e*Integrate[x^2*(a+b*ArcTan[c*x])/(1+c^2*x^2),x] /;
FreeQ[{a,b,c,d,e,f,g},x] && EqQ[g,c^2*f]

Integrate[x_*(d_.+e_*Log[f_+g_*x_^2])*(a_.+b_*ArcCot[c_*x_])^2,x_] := (f+g*x^2)*(d+e*Log[f+g*x^2])*(a+b*ArcCot[c*x])^2/(2*g) -    e*x^2*(a+b*ArcCot[c*x])^2/2 + b/c*Integrate[(d+e*Log[f+g*x^2])*(a+b*ArcCot[c*x]),x] - b*c*e*Integrate[x^2*(a+b*ArcCot[c*x])/(1+c^2*x^2),x] /;
FreeQ[{a,b,c,d,e,f,g},x] && EqQ[g,c^2*f]

Integrate[u_*(a_.+b_*ArcTan[c_*x_])^p_.,x_] := Unintegrable[u*(a+b*ArcTan[c*x])^p,x] /;
FreeQ[{a,b,c,p},x] && (EqQ[u,1] || MatchQ[u,(d_.+e_*x)^q_./; FreeQ[{d,e,q},x]] || MatchQ[u,(f_*x)^m_*(d_.+e_*x)^q_./; FreeQ[{d,e,f,m,q},x]] || MatchQ[u,(d_.+e_*x^2)^q_./; FreeQ[{d,e,q},x]] || MatchQ[u,(f_*x)^m_*(d_.+e_*x^2)^q_./; FreeQ[{d,e,f,m,q},x]])

Integrate[u_*(a_.+b_*ArcCot[c_*x_])^p_.,x_] := Unintegrable[u*(a+b*ArcCot[c*x])^p,x] /;
FreeQ[{a,b,c,p},x] && (EqQ[u,1] || MatchQ[u,(d_.+e_*x)^q_./; FreeQ[{d,e,q},x]] || MatchQ[u,(f_*x)^m_*(d_.+e_*x)^q_./; FreeQ[{d,e,f,m,q},x]] || MatchQ[u,(d_.+e_*x^2)^q_./; FreeQ[{d,e,q},x]] || MatchQ[u,(f_*x)^m_*(d_.+e_*x^2)^q_./; FreeQ[{d,e,f,m,q},x]])

Integrate[(a_.+b_*ArcTan[c_+d_*x_])^p_.,x_] := 1/d*Subst[Integrate[(a+b*ArcTan[x])^p,x],x,c+d*x] /;
FreeQ[{a,b,c,d},x] && IGtQ[p,0]

Integrate[(a_.+b_*ArcCot[c_+d_*x_])^p_.,x_] := 1/d*Subst[Integrate[(a+b*ArcCot[x])^p,x],x,c+d*x] /;
FreeQ[{a,b,c,d},x] && IGtQ[p,0]

Integrate[(a_.+b_*ArcTan[c_+d_*x_])^p_,x_] := Unintegrable[(a+b*ArcTan[c+d*x])^p,x] /;
