Integrate[(a_.+b_*ArcTan[c_*x_])^p_*PolyLog[k_,u_]/(d_+e_*x_^2),x_] := I*(a+b*ArcTan[c*x])^p*PolyLog[k+1,u]/(2*c*d) - b*p*I/2*Integrate[(a+b*ArcTan[c*x])^(p-1)*PolyLog[k+1,u]/(d+e*x^2),x] /;
