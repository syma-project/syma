FreeQ[{a,b,c,d,e},x] && EqQ[e,c^2*d] && IGtQ[p,0] && GtQ[d,0]

Integrate[(a_.+b_*ArcTan[c_*x_])^p_./(x_*Sqrt[d_+e_*x_^2]),x_] := Sqrt[1+c^2*x^2]/Sqrt[d+e*x^2]*Integrate[(a+b*ArcTan[c*x])^p/(x*Sqrt[1+c^2*x^2]),x] /;
FreeQ[{a,b,c,d,e},x] && EqQ[e,c^2*d] && IGtQ[p,0] && Not[GtQ[d,0]]

Integrate[(a_.+b_*ArcCot[c_*x_])^p_./(x_*Sqrt[d_+e_*x_^2]),x_] := Sqrt[1+c^2*x^2]/Sqrt[d+e*x^2]*Integrate[(a+b*ArcCot[c*x])^p/(x*Sqrt[1+c^2*x^2]),x] /;
FreeQ[{a,b,c,d,e},x] && EqQ[e,c^2*d] && IGtQ[p,0] && Not[GtQ[d,0]]

