FreeQ[{a,b,c,m,n},x] && IGtQ[p,0] && (EqQ[p,1] || EqQ[n,1] && IntegerQ[m])  && NeQ[m,-1]

Integrate[x_^m_*(a_.+b_*ArcTanh[c_*x_^n_])^p_.,x_] := 1/n*Subst[Integrate[x^(Simplify[(m+1)/n]-1)*(a+b*ArcTanh[c*x])^p,x],x,x^n] /;
FreeQ[{a,b,c,m,n},x] && IGtQ[p,1] && IntegerQ[Simplify[(m+1)/n]]

Integrate[x_^m_*(a_.+b_*ArcCoth[c_*x_^n_])^p_.,x_] := 1/n*Subst[Integrate[x^(Simplify[(m+1)/n]-1)*(a+b*ArcCoth[c*x])^p,x],x,x^n] /;
FreeQ[{a,b,c,m,n},x] && IGtQ[p,1] && IntegerQ[Simplify[(m+1)/n]]

Integrate[x_^m_*(a_.+b_*ArcTanh[c_*x_^n_])^p_,x_] := Integrate[ExpandIntegrand[x^m*(a+b*Log[1+c*x^n]/2-b*Log[1-c*x^n]/2)^p,x],x] /;
FreeQ[{a,b,c},x] && IGtQ[p,1] && IGtQ[n,0] && IntegerQ[m]

