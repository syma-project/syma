Integrate[(a_.+b_*ArcCoth[c_*x_])^p_/x_,x_] := 2*(a+b*ArcCoth[c*x])^p*ArcCoth[1-2/(1-c*x)] - 2*b*c*p*Integrate[(a+b*ArcCoth[c*x])^(p-1)*ArcCoth[1-2/(1-c*x)]/(1-c^2*x^2),x] /;
FreeQ[{a,b,c},x] && IGtQ[p,1]

Integrate[(a_.+b_*ArcTanh[c_*x_^n_])^p_./x_,x_] := 1/n*Subst[Integrate[(a+b*ArcTanh[c*x])^p/x,x],x,x^n] /;
FreeQ[{a,b,c,n},x] && IGtQ[p,0]

Integrate[(a_.+b_*ArcCoth[c_*x_^n_])^p_./x_,x_] := 1/n*Subst[Integrate[(a+b*ArcCoth[c*x])^p/x,x],x,x^n] /;
FreeQ[{a,b,c,n},x] && IGtQ[p,0]

Integrate[x_^m_*(a_.+b_*ArcTanh[c_*x_^n_.])^p_.,x_] := x^(m+1)*(a+b*ArcTanh[c*x^n])^p/(m+1) -    b*c*n*p/(m+1)*Integrate[x^(m+n)*(a+b*ArcTanh[c*x^n])^(p-1)/(1-c^2*x^(2*n)),x] /;
FreeQ[{a,b,c,m,n},x] && IGtQ[p,0] && (EqQ[p,1] || EqQ[n,1] && IntegerQ[m])  && NeQ[m,-1]

