FreeQ[{a,b,c,d,m},x] && NeQ[m,-1] && InverseFunctionFreeQ[u,x] && Not[FunctionOfQ[(c+d*x)^(m+1),u,x]] && Not[FunctionOfExponentialQ[u,x]]

Integrate[v_*(a_.+b_*ArcSinh[u_]),x_] := With[{w=IntHide[v,x]}, Dist[(a+b*ArcSinh[u]),w,x] - b*Integrate[SimplifyIntegrand[w*D[u,x]/Sqrt[1+u^2],x],x] /; InverseFunctionFreeQ[w,x]] /;
FreeQ[{a,b},x] && InverseFunctionFreeQ[u,x] && Not[MatchQ[v, (c_.+d_*x)^m_. /; FreeQ[{c,d,m},x]]]

Integrate[E^(n_*ArcSinh[u_]), x_] := Integrate[(u+Sqrt[1+u^2])^n,x] /;
IntegerQ[n] && PolyQ[u,x]

