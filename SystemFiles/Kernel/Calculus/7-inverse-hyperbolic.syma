Integrate[(a_.+b_*ArcTanh[c_*x_^n_.])^p_.,x_] := x*(a+b*ArcTanh[c*x^n])^p - b*c*n*p*Integrate[x^n*(a+b*ArcTanh[c*x^n])^(p-1)/(1-c^2*x^(2*n)),x] /;
FreeQ[{a,b,c,n},x] && IGtQ[p,0] && (EqQ[n,1] || EqQ[p,1])

