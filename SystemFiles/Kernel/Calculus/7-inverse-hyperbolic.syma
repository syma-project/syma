Integrate[Sqrt[d1_+e1_*x_]*Sqrt[d2_+e2_*x_]*(a_.+b_*ArcCosh[c_*x_])^n_.,x_] := x*Sqrt[d1+e1*x]*Sqrt[d2+e2*x]*(a+b*ArcCosh[c*x])^n/2 - b*c*n/2*Simp[Sqrt[d1+e1*x]/Sqrt[1+c*x]]*Simp[Sqrt[d2+e2*x]/Sqrt[-1+c*x]]* Integrate[x*(a+b*ArcCosh[c*x])^(n-1),x] - 1/2*Simp[Sqrt[d1+e1*x]/Sqrt[1+c*x]]*Simp[Sqrt[d2+e2*x]/Sqrt[-1+c*x]]* Integrate[(a+b*ArcCosh[c*x])^n/(Sqrt[1+c*x]*Sqrt[-1+c*x]),x] /;
FreeQ[{a,b,c,d1,e1,d2,e2},x] && EqQ[e1,c*d1] && EqQ[e2,-c*d2] && GtQ[n,0]

Integrate[(d_+e_*x_^2)^p_*(a_.+b_*ArcCosh[c_*x_])^n_.,x_] := x*(d+e*x^2)^p*(a+b*ArcCosh[c*x])^n/(2*p+1) + 2*d*p/(2*p+1)*Integrate[(d+e*x^2)^(p-1)*(a+b*ArcCosh[c*x])^n,x] - b*c*n/(2*p+1)*Simp[(d+e*x^2)^p/((1+c*x)^p*(-1+c*x)^p)]* Integrate[x*(1+c*x)^(p-1/2)*(-1+c*x)^(p-1/2)*(a+b*ArcCosh[c*x])^(n-1),x] /;
