Integrate[(a_.+b_*ArcCoth[c_*x_^n_.])^p_,x_] := Unintegrable[(a+b*ArcCoth[c*x^n])^p,x] /;
FreeQ[{a,b,c,n,p},x]

Integrate[(a_.+b_*ArcTanh[c_*x_])/x_,x_] := a*Log[x] - b/2*PolyLog[2,-c*x] + b/2*PolyLog[2,c*x] /;
FreeQ[{a,b,c},x]

Integrate[(a_.+b_*ArcCoth[c_*x_])/x_,x_] := a*Log[x] + b/2*PolyLog[2,-1/(c*x)] - b/2*PolyLog[2,1/(c*x)] /;
FreeQ[{a,b,c},x]

Integrate[(a_.+b_*ArcTanh[c_*x_])^p_/x_,x_] := 2*(a+b*ArcTanh[c*x])^p*ArcTanh[1-2/(1-c*x)] - 2*b*c*p*Integrate[(a+b*ArcTanh[c*x])^(p-1)*ArcTanh[1-2/(1-c*x)]/(1-c^2*x^2),x] /;
