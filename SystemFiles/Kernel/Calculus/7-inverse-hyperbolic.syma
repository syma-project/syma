FreeQ[{a,b,c,d1,e1,d2,e2,f,g,h,m},x] && EqQ[e1-c*d1,0] && EqQ[e2+c*d2,0] && GtQ[d1,0] && LtQ[d2,0] && IGtQ[n,0]

Integrate[Log[h_*(f_.+g_*x_)^m_.]*(d1_+e1_*x_)^p_*(d2_+e2_*x_)^p_*(a_.+b_*ArcCosh[c_*x_])^n_.,x_] := (-d1*d2)^IntPart[p]*(d1+e1*x)^FracPart[p]*(d2+e2*x)^FracPart[p]/((-1+c*x)^FracPart[p]*(1+c*x)^FracPart[p])* Integrate[Log[h*(f+g*x)^m]*(-1+c*x)^p*(1+c*x)^p*(a+b*ArcCosh[c*x])^n,x] /;
FreeQ[{a,b,c,d1,e1,d2,e2,f,g,h,m,n},x] && EqQ[e1-c*d1,0] && EqQ[e2+c*d2,0] && IntegerQ[p-1/2] && Not[GtQ[d1,0] && LtQ[d2,0]]

Integrate[(d_+e_*x_)^m_*(f_+g_*x_)^m_*(a_.+b_*ArcCosh[c_*x_]),x_] := With[{u=IntHide[(d+e*x)^m*(f+g*x)^m,x]}, Dist[a+b*ArcCosh[c*x],u,x] - b*c*Integrate[Dist[1/(Sqrt[-1+c*x]*Sqrt[1+c*x]),u,x],x]] /;
FreeQ[{a,b,c,d,e,f,g},x] && ILtQ[m+1/2,0]

Integrate[(d_+e_*x_)^m_*(f_+g_*x_)^m_*(a_.+b_*ArcCosh[c_*x_])^n_.,x_] := Integrate[ExpandIntegrand[(a+b*ArcCosh[c*x])^n,(d+e*x)^m*(f+g*x)^m,x],x] /;
FreeQ[{a,b,c,d,e,f,g,n},x] && IntegerQ[m]

Integrate[u_*(a_.+b_*ArcCosh[c_*x_]),x_] := With[{v=IntHide[u,x]}, Dist[a+b*ArcCosh[c*x],v,x] - b*c*Sqrt[1-c^2*x^2]/(Sqrt[-1+c*x]*Sqrt[1+c*x])*Integrate[SimplifyIntegrand[v/Sqrt[1-c^2*x^2],x],x] /; InverseFunctionFreeQ[v,x]] /;
FreeQ[{a,b,c},x]

Integrate[Px_*(d1_+e1_*x_)^p_*(d2_+e2_*x_)^p_*(a_.+b_*ArcCosh[c_*x_])^n_,x_] := With[{u=ExpandIntegrand[Px*(d1+e1*x)^p*(d2+e2*x)^p*(a+b*ArcCosh[c*x])^n,x]}, Integrate[u,x] /; SumQ[u]] /;
FreeQ[{a,b,c,d1,e1,d2,e2,n},x] && PolyQ[Px,x] && EqQ[e1-c*d1,0] && EqQ[e2+c*d2,0] && IntegerQ[p-1/2]

Integrate[Px_*(f_+g_*(d1_+e1_*x_)^p_*(d2_+e2_*x_)^p_)^m_*(a_.+b_*ArcCosh[c_*x_])^n_.,x_] := With[{u=ExpandIntegrand[Px*(f+g*(d1+e1*x)^p*(d2+e2*x)^p)^m*(a+b*ArcCosh[c*x])^n,x]}, Integrate[u,x] /; SumQ[u]] /;
FreeQ[{a,b,c,d1,e1,d2,e2,f,g},x] && PolyQ[Px,x] && EqQ[e1-c*d1,0] && EqQ[e2+c*d2,0] && IGtQ[p+1/2,0] && IntegersQ[m,n]

Integrate[RFx_*ArcCosh[c_*x_]^n_.,x_] := With[{u=ExpandIntegrand[ArcCosh[c*x]^n,RFx,x]}, Integrate[u,x] /; SumQ[u]] /;
FreeQ[c,x] && RationalFunctionQ[RFx,x] && IGtQ[n,0]

Integrate[RFx_*(a_+b_*ArcCosh[c_*x_])^n_.,x_] := Integrate[ExpandIntegrand[RFx*(a+b*ArcCosh[c*x])^n,x],x] /;
FreeQ[{a,b,c},x] && RationalFunctionQ[RFx,x] && IGtQ[n,0]

Integrate[RFx_*(d1_+e1_*x_)^p_*(d2_+e2_*x_)^p_*ArcCosh[c_*x_]^n_.,x_] := With[{u=ExpandIntegrand[(d1+e1*x)^p*(d2+e2*x)^p*ArcCosh[c*x]^n,RFx,x]}, Integrate[u,x] /; SumQ[u]] /;
FreeQ[{c,d1,e1,d2,e2},x] && RationalFunctionQ[RFx,x] && IGtQ[n,0] && EqQ[e1-c*d1,0] && EqQ[e2+c*d2,0] && IntegerQ[p-1/2]

Integrate[RFx_*(d1_+e1_*x_)^p_*(d2_+e2_*x_)^p_*(a_+b_*ArcCosh[c_*x_])^n_.,x_] := Integrate[ExpandIntegrand[(d1+e1*x)^p*(d2+e2*x)^p,RFx*(a+b*ArcCosh[c*x])^n,x],x] /;
FreeQ[{a,b,c,d1,e1,d2,e2},x] && RationalFunctionQ[RFx,x] && IGtQ[n,0] && EqQ[e1-c*d1,0] && EqQ[e2+c*d2,0] && IntegerQ[p-1/2]

Integrate[u_*(a_.+b_*ArcCosh[c_*x_])^n_.,x_] := Unintegrable[u*(a+b*ArcCosh[c*x])^n,x] /;
FreeQ[{a,b,c,n},x]

Integrate[(a_.+b_*ArcCosh[c_+d_*x_])^n_.,x_] := 1/d*Subst[Integrate[(a+b*ArcCosh[x])^n,x],x,c+d*x] /;
FreeQ[{a,b,c,d,n},x]

Integrate[(e_.+f_*x_)^m_*(a_.+b_*ArcCosh[c_+d_*x_])^n_.,x_] := 1/d*Subst[Integrate[((d*e-c*f)/d+f*x/d)^m*(a+b*ArcCosh[x])^n,x],x,c+d*x] /;
FreeQ[{a,b,c,d,e,f,m,n},x]

Integrate[(A_.+B_*x_+C_*x_^2)^p_*(a_.+b_*ArcCosh[c_+d_*x_])^n_.,x_] := 1/d*Subst[Integrate[(-C/d^2+C/d^2*x^2)^p*(a+b*ArcCosh[x])^n,x],x,c+d*x] /;
FreeQ[{a,b,c,d,A,B,C,n,p},x] && EqQ[B*(1-c^2)+2*A*c*d,0] && EqQ[2*c*C-B*d,0]

Integrate[(e_.+f_*x_)^m_*(A_.+B_*x_+C_*x_^2)^p_*(a_.+b_*ArcCosh[c_+d_*x_])^n_.,x_] := 1/d*Subst[Integrate[((d*e-c*f)/d+f*x/d)^m*(-C/d^2+C/d^2*x^2)^p*(a+b*ArcCosh[x])^n,x],x,c+d*x] /;
FreeQ[{a,b,c,d,e,f,A,B,C,m,n,p},x] && EqQ[B*(1-c^2)+2*A*c*d,0] && EqQ[2*c*C-B*d,0]

Integrate[Sqrt[a_.+b_*ArcCosh[1+d_*x_^2]],x_] := 2*Sqrt[a+b*ArcCosh[1+d*x^2]]*Sinh[(1/2)*ArcCosh[1+d*x^2]]^2/(d*x) - Sqrt[b]*Sqrt[Pi/2]*(Cosh[a/(2*b)]-Sinh[a/(2*b)])*Sinh[(1/2)*ArcCosh[1+d*x^2]]* Erfi[(1/Sqrt[2*b])*Sqrt[a+b*ArcCosh[1+d*x^2]]]/(d*x) + Sqrt[b]*Sqrt[Pi/2]*(Cosh[a/(2*b)]+Sinh[a/(2*b)])*Sinh[(1/2)*ArcCosh[1+d*x^2]]* Erf[(1/Sqrt[2*b])*Sqrt[a+b*ArcCosh[1+d*x^2]]]/(d*x) /;
FreeQ[{a,b,d},x]

Integrate[Sqrt[a_.+b_*ArcCosh[-1+d_*x_^2]],x_] := 2*Sqrt[a+b*ArcCosh[-1+d*x^2]]*Cosh[(1/2)*ArcCosh[-1+d*x^2]]^2/(d*x) - Sqrt[b]*Sqrt[Pi/2]*(Cosh[a/(2*b)]-Sinh[a/(2*b)])*Cosh[(1/2)*ArcCosh[-1+d*x^2]]* Erfi[(1/Sqrt[2*b])*Sqrt[a+b*ArcCosh[-1+d*x^2]]]/(d*x) - Sqrt[b]*Sqrt[Pi/2]*(Cosh[a/(2*b)]+Sinh[a/(2*b)])*Cosh[(1/2)*ArcCosh[-1+d*x^2]]* Erf[(1/Sqrt[2*b])*Sqrt[a+b*ArcCosh[-1+d*x^2]]]/(d*x) /;
FreeQ[{a,b,d},x]

Integrate[(a_.+b_*ArcCosh[c_+d_*x_^2])^n_,x_] := x*(a+b*ArcCosh[c+d*x^2])^n -    2*b*n*(2*c*d*x^2+d^2*x^4)*(a+b*ArcCosh[c+d*x^2])^(n-1)/(d*x*Sqrt[-1+c+d*x^2]*Sqrt[1+c+d*x^2]) +    4*b^2*n*(n-1)*Integrate[(a+b*ArcCosh[c+d*x^2])^(n-2),x] /;
FreeQ[{a,b,c,d},x] && EqQ[c^2,1] && GtQ[n,1]

Integrate[1/(a_.+b_*ArcCosh[1+d_*x_^2]),x_] := x*Cosh[a/(2*b)]*CoshIntegral[(a+b*ArcCosh[1+d*x^2])/(2*b)]/(Sqrt[2]*b*Sqrt[d*x^2]) - x*Sinh[a/(2*b)]*SinhIntegral[(a+b*ArcCosh[1+d*x^2])/(2*b)]/(Sqrt[2]*b*Sqrt[d*x^2]) /;
FreeQ[{a,b,d},x]

Integrate[1/(a_.+b_*ArcCosh[-1+d_*x_^2]),x_] := -x*Sinh[a/(2*b)]*CoshIntegral[(a+b*ArcCosh[-1+d*x^2])/(2*b)]/(Sqrt[2]*b*Sqrt[d*x^2]) + x*Cosh[a/(2*b)]*SinhIntegral[(a+b*ArcCosh[-1+d*x^2])/(2*b)]/(Sqrt[2]*b*Sqrt[d*x^2]) /;
FreeQ[{a,b,d},x]

Integrate[1/Sqrt[a_.+b_*ArcCosh[1+d_*x_^2]],x_] := Sqrt[Pi/2]*(Cosh[a/(2*b)]-Sinh[a/(2*b)])*Sinh[ArcCosh[1+d*x^2]/2]*Erfi[Sqrt[a+b*ArcCosh[1+d*x^2]]/Sqrt[2*b]]/(Sqrt[b]*d*x) + Sqrt[Pi/2]*(Cosh[a/(2*b)]+Sinh[a/(2*b)])*Sinh[ArcCosh[1+d*x^2]/2]*Erf[Sqrt[a+b*ArcCosh[1+d*x^2]]/Sqrt[2*b]]/(Sqrt[b]*d*x) /;
FreeQ[{a,b,d},x]

Integrate[1/Sqrt[a_.+b_*ArcCosh[-1+d_*x_^2]],x_] := Sqrt[Pi/2]*(Cosh[a/(2*b)]-Sinh[a/(2*b)])*Cosh[ArcCosh[-1+d*x^2]/2]*Erfi[Sqrt[a+b*ArcCosh[-1+d*x^2]]/Sqrt[2*b]]/(Sqrt[b]*d*x) - Sqrt[Pi/2]*(Cosh[a/(2*b)]+Sinh[a/(2*b)])*Cosh[ArcCosh[-1+d*x^2]/2]*Erf[Sqrt[a+b*ArcCosh[-1+d*x^2]]/Sqrt[2*b]]/(Sqrt[b]*d*x) /;
FreeQ[{a,b,d},x]

Integrate[1/(a_.+b_*ArcCosh[1+d_*x_^2])^(3/2),x_] := -Sqrt[d*x^2]*Sqrt[2+d*x^2]/(b*d*x*Sqrt[a+b*ArcCosh[1+d*x^2]]) + Sqrt[Pi/2]*(Cosh[a/(2*b)]-Sinh[a/(2*b)])*Sinh[ArcCosh[1+d*x^2]/2]*Erfi[Sqrt[a+b*ArcCosh[1+d*x^2]]/Sqrt[2*b]]/(b^(3/2)*d*x)- Sqrt[Pi/2]*(Cosh[a/(2*b)]+Sinh[a/(2*b)])*Sinh[ArcCosh[1+d*x^2]/2]*Erf[Sqrt[a+b*ArcCosh[1+d*x^2]]/Sqrt[2*b]]/(b^(3/2)*d*x) /;
FreeQ[{a,b,d},x]

Integrate[1/(a_.+b_*ArcCosh[-1+d_*x_^2])^(3/2),x_] := -Sqrt[d*x^2]*Sqrt[-2+d*x^2]/(b*d*x*Sqrt[a+b*ArcCosh[-1+d*x^2]]) + Sqrt[Pi/2]*(Cosh[a/(2*b)]-Sinh[a/(2*b)])*Cosh[ArcCosh[-1+d*x^2]/2]*Erfi[Sqrt[a+b*ArcCosh[-1+d*x^2]]/Sqrt[2*b]]/(b^(3/2)*d*x) + Sqrt[Pi/2]*(Cosh[a/(2*b)]+Sinh[a/(2*b)])*Cosh[ArcCosh[-1+d*x^2]/2]*Erf[Sqrt[a+b*ArcCosh[-1+d*x^2]]/Sqrt[2*b]]/(b^(3/2)*d*x) /;
FreeQ[{a,b,d},x]

Integrate[1/(a_.+b_*ArcCosh[1+d_*x_^2])^2,x_] := -Sqrt[d*x^2]*Sqrt[2+d*x^2]/(2*b*d*x*(a+b*ArcCosh[1+d*x^2])) - x*Sinh[a/(2*b)]*CoshIntegral[(a+b*ArcCosh[1+d*x^2])/(2*b)]/(2*Sqrt[2]*b^2*Sqrt[d*x^2]) + x*Cosh[a/(2*b)]*SinhIntegral[(a+b*ArcCosh[1+d*x^2])/(2*b)]/(2*Sqrt[2]*b^2*Sqrt[d*x^2]) /;
FreeQ[{a,b,d},x]

Integrate[1/(a_.+b_*ArcCosh[-1+d_*x_^2])^2,x_] := -Sqrt[d*x^2]*Sqrt[-2+d*x^2]/(2*b*d*x*(a+b*ArcCosh[-1+d*x^2])) + x*Cosh[a/(2*b)]*CoshIntegral[(a+b*ArcCosh[-1+d*x^2])/(2*b)]/(2*Sqrt[2]*b^2*Sqrt[d*x^2]) - x*Sinh[a/(2*b)]*SinhIntegral[(a+b*ArcCosh[-1+d*x^2])/(2*b)]/(2*Sqrt[2]*b^2*Sqrt[d*x^2]) /;
FreeQ[{a,b,d},x]

Integrate[(a_.+b_*ArcCosh[c_+d_*x_^2])^n_,x_] := -x*(a+b*ArcCosh[c+d*x^2])^(n+2)/(4*b^2*(n+1)*(n+2)) +    (2*c*x^2 +d*x^4)*(a+b*ArcCosh[c+d*x^2])^(n+1)/(2*b*(n+1)*x*Sqrt[-1+c+d*x^2]*Sqrt[1+c+d*x^2]) +    1/(4*b^2*(n+1)*(n+2))*Integrate[(a+b*ArcCosh[c+d*x^2])^(n+2),x] /;
FreeQ[{a,b,c,d},x] && EqQ[c^2,1] && LtQ[n,-1] && NeQ[n,-2]

Integrate[ArcCosh[a_*x_^p_]^n_./x_,x_] := 1/p*Subst[Integrate[x^n*Tanh[x],x],x,ArcCosh[a*x^p]] /;
FreeQ[{a,p},x] && IGtQ[n,0]

Integrate[u_*ArcCosh[c_./(a_.+b_*x_^n_.)]^m_.,x_] := Integrate[u*ArcSech[a/c+b*x^n/c]^m,x] /;
FreeQ[{a,b,c,n,m},x]

Integrate[ArcCosh[Sqrt[1+b_*x_^2]]^n_./Sqrt[1+b_*x_^2],x_] := Sqrt[-1+Sqrt[1+b*x^2]]*Sqrt[1+Sqrt[1+b*x^2]]/(b*x)*Subst[Integrate[ArcCosh[x]^n/(Sqrt[-1+x]*Sqrt[1+x]),x],x,Sqrt[1+b*x^2]] /;
FreeQ[{b,n},x]

Integrate[f_^(c_*ArcCosh[a_.+b_*x_]^n_.),x_] := 1/b*Subst[Integrate[f^(c*x^n)*Sinh[x],x],x,ArcCosh[a+b*x]] /;
FreeQ[{a,b,c,f},x] && IGtQ[n,0]

Integrate[x_^m_*f_^(c_*ArcCosh[a_.+b_*x_]^n_.),x_] := 1/b*Subst[Integrate[(-a/b+Cosh[x]/b)^m*f^(c*x^n)*Sinh[x],x],x,ArcCosh[a+b*x]] /;
FreeQ[{a,b,c,f},x] && IGtQ[m,0] && IGtQ[n,0]

Integrate[ArcCosh[u_],x_] := x*ArcCosh[u] - Integrate[SimplifyIntegrand[x*D[u,x]/(Sqrt[-1+u]*Sqrt[1+u]),x],x] /;
InverseFunctionFreeQ[u,x] && Not[FunctionOfExponentialQ[u,x]]

Integrate[(c_.+d_*x_)^m_*(a_.+b_*ArcCosh[u_]),x_] := (c+d*x)^(m+1)*(a+b*ArcCosh[u])/(d*(m+1)) - b/(d*(m+1))*Integrate[SimplifyIntegrand[(c+d*x)^(m+1)*D[u,x]/(Sqrt[-1+u]*Sqrt[1+u]),x],x] /;
FreeQ[{a,b,c,d,m},x] && NeQ[m,-1] && InverseFunctionFreeQ[u,x] && Not[FunctionOfQ[(c+d*x)^(m+1),u,x]] && Not[FunctionOfExponentialQ[u,x]]

Integrate[v_*(a_.+b_*ArcCosh[u_]),x_] := With[{w=IntHide[v,x]}, Dist[(a+b*ArcCosh[u]),w,x] - b*Integrate[SimplifyIntegrand[w*D[u,x]/(Sqrt[-1+u]*Sqrt[1+u]),x],x] /; InverseFunctionFreeQ[w,x]] /;
FreeQ[{a,b},x] && InverseFunctionFreeQ[u,x] && Not[MatchQ[v, (c_.+d_*x)^m_. /; FreeQ[{c,d,m},x]]]

Integrate[E^(n_*ArcCosh[u_]), x_] := Integrate[(u+Sqrt[-1+u]*Sqrt[1+u])^n,x] /;
IntegerQ[n] && PolyQ[u,x]

Integrate[x_^m_*E^(n_*ArcCosh[u_]), x_] := Integrate[x^m*(u+Sqrt[-1+u]*Sqrt[1+u])^n,x] /;
RationalQ[m] && IntegerQ[n] && PolyQ[u,x]

