FreeQ[{a,b,c},x] && IGtQ[p,1] && ILtQ[n,0]

Integrate[(a_.+b_*ArcTanh[c_*x_^n_])^p_,x_] := With[{k=Denominator[n]}, k*Subst[Integrate[x^(k-1)*(a+b*ArcTanh[c*x^(k*n)])^p,x],x,x^(1/k)]] /;
