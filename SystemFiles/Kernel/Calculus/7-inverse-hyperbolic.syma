FreeQ[{a,b,c},x] && IGtQ[p,1] && IGtQ[n,0] && IntegerQ[m]

Integrate[x_^m_*(a_.+b_*ArcTanh[c_*x_^n_])^p_,x_] := With[{k=Denominator[m]}, k*Subst[Integrate[x^(k*(m+1)-1)*(a+b*ArcTanh[c*x^(k*n)])^p,x],x,x^(1/k)]] /;
