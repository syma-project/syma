FreeQ[{a,b,c,m},x] && IGtQ[p,1] && ILtQ[n,0]

Integrate[x_^m_*(a_.+b_*ArcCoth[c_*x_^n_])^p_,x_] := Integrate[x^m*(a+b*ArcTanh[x^(-n)/c])^p,x] /;
FreeQ[{a,b,c,m},x] && IGtQ[p,1] && ILtQ[n,0]

Integrate[x_^m_*(a_.+b_*ArcTanh[c_*x_^n_])^p_,x_] := With[{k=Denominator[n]}, k*Subst[Integrate[x^(k*(m+1)-1)*(a+b*ArcTanh[c*x^(k*n)])^p,x],x,x^(1/k)]] /;
FreeQ[{a,b,c,m},x] && IGtQ[p,1] && FractionQ[n]

Integrate[x_^m_*(a_.+b_*ArcCoth[c_*x_^n_])^p_,x_] := With[{k=Denominator[n]}, k*Subst[Integrate[x^(k*(m+1)-1)*(a+b*ArcCoth[c*x^(k*n)])^p,x],x,x^(1/k)]] /;
FreeQ[{a,b,c,m},x] && IGtQ[p,1] && FractionQ[n]

Integrate[(d_*x_)^m_*(a_.+b_*ArcTanh[c_*x_^n_.]),x_] := (d*x)^(m+1)*(a+b*ArcTanh[c*x^n])/(d*(m+1)) -    b*c*n/(d^n*(m+1))*Integrate[(d*x)^(m+n)/(1-c^2*x^(2*n)),x] /;
FreeQ[{a,b,c,d,m,n},x] && IntegerQ[n] && NeQ[m,-1]

Integrate[(d_*x_)^m_*(a_.+b_*ArcCoth[c_*x_^n_.]),x_] := (d*x)^(m+1)*(a+b*ArcCoth[c*x^n])/(d*(m+1)) -    b*c*n/(d^n*(m+1))*Integrate[(d*x)^(m+n)/(1-c^2*x^(2*n)),x] /;
FreeQ[{a,b,c,d,m,n},x] && IntegerQ[n] && NeQ[m,-1]

Integrate[(d_*x_)^m_*(a_.+b_*ArcTanh[c_*x_^n_.])^p_.,x_] := d^IntPart[m]*(d*x)^FracPart[m]/x^FracPart[m]*Integrate[x^m*(a+b*ArcTanh[c*x^n])^p,x] /;
FreeQ[{a,b,c,d,m,n},x] && IGtQ[p,0] && (EqQ[p,1] || RationalQ[m,n])

Integrate[(d_*x_)^m_*(a_.+b_*ArcCoth[c_*x_^n_.])^p_.,x_] := d^IntPart[m]*(d*x)^FracPart[m]/x^FracPart[m]*Integrate[x^m*(a+b*ArcCoth[c*x^n])^p,x] /;
FreeQ[{a,b,c,d,m,n},x] && IGtQ[p,0] && (EqQ[p,1] || RationalQ[m,n])

Integrate[(d_*x_)^m_*(a_.+b_*ArcTanh[c_*x_^n_.])^p_.,x_] := Unintegrable[(d*x)^m*(a+b*ArcTanh[c*x^n])^p,x] /;
FreeQ[{a,b,c,d,m,n,p},x]

