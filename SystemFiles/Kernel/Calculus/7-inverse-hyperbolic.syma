Integrate[(d1_+e1_*x_)^p_*(d2_+e2_*x_)^p_*(a_.+b_*ArcCosh[c_*x_])^n_.,x_] := x*(d1+e1*x)^p*(d2+e2*x)^p*(a+b*ArcCosh[c*x])^n/(2*p+1) + 2*d1*d2*p/(2*p+1)*Integrate[(d1+e1*x)^(p-1)*(d2+e2*x)^(p-1)*(a+b*ArcCosh[c*x])^n,x] - b*c*n/(2*p+1)*Simp[(d1+e1*x)^p/(1+c*x)^p]*Simp[(d2+e2*x)^p/(-1+c*x)^p]* Integrate[x*(1+c*x)^(p-1/2)*(-1+c*x)^(p-1/2)*(a+b*ArcCosh[c*x])^(n-1),x] /;
