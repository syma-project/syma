FreeQ[{a,b,c,d,e},x] && EqQ[c^2*d+e,0] && IGtQ[p,0] && GtQ[d,0]

Integrate[(a_.+b_*ArcCoth[c_*x_])^p_./Sqrt[d_+e_*x_^2],x_] := -x*Sqrt[1-1/(c^2*x^2)]/Sqrt[d+e*x^2]*Subst[Integrate[(a+b*x)^p*Csch[x],x],x,ArcCoth[c*x]] /;
FreeQ[{a,b,c,d,e},x] && EqQ[c^2*d+e,0] && IGtQ[p,0] && GtQ[d,0]

