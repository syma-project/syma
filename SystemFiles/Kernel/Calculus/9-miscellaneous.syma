Integrate[u_/(a_.+b_*x_^n_.+c_*x_^n2_.),x_] := With[{v=RationalFunctionExpand[u/(a+b*x^n+c*x^(2*n)),x]}, Integrate[v,x] /; SumQ[v]] /;
FreeQ[{a,b,c},x] && EqQ[n2,2*n] && IGtQ[n,0]

Integrate[u_./(a_*x_^m_.+b_*Sqrt[c_*x_^n_]),x_] := Integrate[u*(a*x^m-b*Sqrt[c*x^n])/(a^2*x^(2*m)-b^2*c*x^n),x] /;
FreeQ[{a,b,c,m,n},x] If[TrueQ[$LoadShowSteps],

Integrate[u_,x_] := With[{lst=FunctionOfLinear[u,x]}, ShowStep["\<\>","\<Integrate[F[a+b*x],x]\>","\<Subst[Integrate[F[x],x],x,a+b*x]/b\>",Hold[ Dist[1/lst[[3]],Subst[Integrate[lst[[1]],x],x,lst[[2]]+lst[[3]]*x],x]]] /; Not[FalseQ[lst]]] /;
SimplifyFlag,

Integrate[u_,x_] := With[{lst=FunctionOfLinear[u,x]}, Dist[1/lst[[3]],Subst[Integrate[lst[[1]],x],x,lst[[2]]+lst[[3]]*x],x] /; Not[FalseQ[lst]]]] If[TrueQ[$LoadShowSteps],

Integrate[u_/x_,x_] := With[{lst=PowerVariableExpn[u,0,x]}, ShowStep["\<\>","\<Integrate[F[(c*x)^n]/x,x]\>","\<Subst[Integrate[F[x]/x,x],x,(c*x)^n]/n\>",Hold[ 1/lst[[2]]*Subst[Integrate[NormalizeIntegrand[Simplify[lst[[1]]/x],x],x],x,(lst[[3]]*x)^lst[[2]]]]] /; Not[FalseQ[lst]] && NeQ[lst[[2]],0]] /;
SimplifyFlag && NonsumQ[u] && Not[RationalFunctionQ[u,x]],

Integrate[u_/x_,x_] := With[{lst=PowerVariableExpn[u,0,x]}, 1/lst[[2]]*Subst[Integrate[NormalizeIntegrand[Simplify[lst[[1]]/x],x],x],x,(lst[[3]]*x)^lst[[2]]] /; Not[FalseQ[lst]] && NeQ[lst[[2]],0]] /;
NonsumQ[u] && Not[RationalFunctionQ[u,x]]] If[TrueQ[$LoadShowSteps],

Integrate[u_*x_^m_.,x_] := With[{lst=PowerVariableExpn[u,m+1,x]}, ShowStep["\<If g=GCD[m+1,n]>1,\>","\<Integrate[x^m*F[x^n],x]\>", "\<1/g*Subst[Integrate[x^((m+1)/g-1)*F[x^(n/g)],x],x,x^g]\>",Hold[ 1/lst[[2]]*Subst[Integrate[NormalizeIntegrand[Simplify[lst[[1]]/x],x],x],x,(lst[[3]]*x)^lst[[2]]]]] /; Not[FalseQ[lst]] && NeQ[lst[[2]],m+1]] /;
SimplifyFlag && IntegerQ[m] && NeQ[m,-1] && NonsumQ[u] && (GtQ[m,0] || Not[AlgebraicFunctionQ[u,x]]),

Integrate[u_*x_^m_.,x_] := With[{lst=PowerVariableExpn[u,m+1,x]}, 1/lst[[2]]*Subst[Integrate[NormalizeIntegrand[Simplify[lst[[1]]/x],x],x],x,(lst[[3]]*x)^lst[[2]]] /; Not[FalseQ[lst]] && NeQ[lst[[2]],m+1]] /;
IntegerQ[m] && NeQ[m,-1] && NonsumQ[u] && (GtQ[m,0] || Not[AlgebraicFunctionQ[u,x]])]

Integrate[x_^m_*u_,x_] := With[{k=Denominator[m]}, k*Subst[Integrate[x^(k*(m+1)-1)*ReplaceAll[u,xRulex^k],x],x,x^(1/k)]] /;
FractionQ[m] If[TrueQ[$LoadShowSteps],

Integrate[u_,x_] := With[{lst=FunctionOfSquareRootOfQuadratic[u,x]}, ShowStep["\<\>","\<Integrate[F[Sqrt[a+b*x+c*x^2],x],x]\>", "\<2*Subst[Integrate[F[(c*Sqrt[a]-b*x+Sqrt[a]*x^2)/(c-x^2),(-b+2*Sqrt[a]\

Integrate[u_,x_] := With[{lst=FunctionOfSquareRootOfQuadratic[u,x]}, 2*Subst[Integrate[lst[[1]],x],x,lst[[2]]] /; Not[FalseQ[lst]] && EqQ[lst[[3]],1]] /;
EulerIntegrandQ[u,x]] If[TrueQ[$LoadShowSteps],

Integrate[u_,x_] := With[{lst=FunctionOfSquareRootOfQuadratic[u,x]}, ShowStep["\<\>","\<Integrate[F[Sqrt[a+b*x+c*x^2],x],x]\>", "\<2*Subst[Integrate[F[(a*Sqrt[c]+b*x+Sqrt[c]*x^2)/(b+2*Sqrt[c]*x),(-a+\

Integrate[u_,x_] := With[{lst=FunctionOfSquareRootOfQuadratic[u,x]}, 2*Subst[Integrate[lst[[1]],x],x,lst[[2]]] /; Not[FalseQ[lst]] && EqQ[lst[[3]],2]] /;
EulerIntegrandQ[u,x]] If[TrueQ[$LoadShowSteps],

Integrate[u_,x_] := With[{lst=FunctionOfSquareRootOfQuadratic[u,x]}, ShowStep["\<\>","\<Integrate[F[Sqrt[a+b*x+c*x^2],x],x]\>", "\<-2*Sqrt[b^2-4*a*c]*Subst[Integrate[F[-Sqrt[b^2-4*a*c]*x/(c-x^2), \ (b*c+c*Sqrt[b^2-4*a*c]+(-b+Sqrt[b^2-4*a*c])*x^2)/(-2*c*(c-x^2))]*x/(c-x^\

Integrate[u_,x_] := With[{lst=FunctionOfSquareRootOfQuadratic[u,x]}, 2*Subst[Integrate[lst[[1]],x],x,lst[[2]]] /; Not[FalseQ[lst]] && EqQ[lst[[3]],3]] /;
EulerIntegrandQ[u,x]]

Integrate[1/(a_+b_*v_^n_),x_] := Dist[2/(a*n),Sum[Integrate[Together[1/(1-v^2/((-1)^(4*k/n)*Rt[-a/b,n/2]))],x],{k,1,n/2}],x] /;
FreeQ[{a,b},x] && IGtQ[n/2,1]

Integrate[1/(a_+b_*v_^n_),x_] := Dist[1/(a*n),Sum[Integrate[Together[1/(1-v/((-1)^(2*k/n)*Rt[-a/b,n]))],x],{k,1,n}],x] /;
FreeQ[{a,b},x] && IGtQ[(n-1)/2,0]

Integrate[v_/(a_+b_*u_^n_.),x_] := Integrate[ReplaceAll[ExpandIntegrand[PolynomialInSubst[v,u,x]/(a+b*x^n),x],xRuleu],x] /;
FreeQ[{a,b},x] && IGtQ[n,0] && PolynomialInQ[v,u,x]

Integrate[u_,x_] := With[{v=NormalizeIntegrand[u,x]}, Integrate[v,x] /; v=!=u]

Integrate[u_,x_] := With[{v=ExpandIntegrand[u,x]}, Integrate[v,x] /; SumQ[v]]

Integrate[u_*(a_.+b_*x_^m_.)^p_*(c_.+d_*x_^n_.)^q_., x_] := (a+b*x^m)^p*(c+d*x^n)^q/x^(m*p)*Integrate[u*x^(m*p),x] /;
FreeQ[{a,b,c,d,m,n,p,q},x] && EqQ[a+d,0] && EqQ[b+c,0] && EqQ[m+n,0] && EqQ[p+q,0]

Integrate[u_*(a_+b_*x_^n_.+c_*x_^n2_.)^p_, x_] := Sqrt[a+b*x^n+c*x^(2*n)]/((4*c)^(p-1/2)*(b+2*c*x^n))*Integrate[u*(b+2*c*x^n)^(2*p),x] /;
FreeQ[{a,b,c,n,p},x] && EqQ[n2,2*n] && EqQ[b^2-4*a*c,0] && IntegerQ[p-1/2] If[TrueQ[$LoadShowSteps],

Integrate[u_,x_] := With[{lst=SubstForFractionalPowerOfLinear[u,x]}, ShowStep["\<\>","\<Integrate[F[(a+b*x)^(1/n),x],x]\>", "\<n/b*Subst[Integrate[x^(n-1)*F[x,-a/b+x^n/b],x],x,(a+b*x)^(1/n)]\>",Hold[ lst[[2]]*lst[[4]]*Subst[Integrate[lst[[1]],x],x,lst[[3]]^(1/lst[[2]])]]] /; Not[FalseQ[lst]]] /;
SimplifyFlag,

Integrate[u_,x_] := With[{lst=SubstForFractionalPowerOfLinear[u,x]}, lst[[2]]*lst[[4]]*Subst[Integrate[lst[[1]],x],x,lst[[3]]^(1/lst[[2]])] /; Not[FalseQ[lst]]]]

Integrate[u_,x_] := CannotIntegrate[u,x]

