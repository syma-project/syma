FreeQ[{a,c,A,B,n,p},x] && EqQ[n2,2*n] && EqQ[w,y]

Integrate[u_*v_^m_*(a_.+b_*y_^n_+c_*w_^n2_.)^p_.,x_] := Module[{q,r}, q*r*Subst[Integrate[x^m*(a+b*x^n+c*x^(2*n))^p,x],x,y] /; Not[FalseQ[r=Divides[y^m,v^m,x]]] && Not[FalseQ[q=DerivativeDivides[y,u,x]]]] /;
FreeQ[{a,b,c,m,n,p},x] && EqQ[n2,2*n] && EqQ[w,y]

