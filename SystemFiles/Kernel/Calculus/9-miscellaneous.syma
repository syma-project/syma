FreeQ[{a,b,c,d,e,f,m,n,p},x] && EqQ[v,y] && EqQ[w,y]

Integrate[u_*(a_.+b_*y_)^m_*(c_.+d_*v_)^n_*(e_.+f_*w_)^p_*(g_.+h_*z_)^q_.,x_] := With[{r=DerivativeDivides[y,u,x]}, r*Subst[Integrate[(a+b*x)^m*(c+d*x)^n*(e+f*x)^p*(g+h*x)^q,x],x,y] /; Not[FalseQ[r]]] /;
