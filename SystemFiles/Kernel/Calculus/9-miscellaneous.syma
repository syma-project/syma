FreeQ[{a,m,n},x] && Not[IntegerQ[m]]

Integrate[u_*v_^m_*(b_*v_)^n_,x_] := 1/b^m*Integrate[u*(b*v)^(m+n),x] /;
FreeQ[{b,n},x] && IntegerQ[m]

Integrate[u_*(a_*v_)^m_*(b_*v_)^n_,x_] := a^(m+1/2)*b^(n-1/2)*Sqrt[b*v]/Sqrt[a*v]*Integrate[u*v^(m+n),x] /;
