Integrate[u_*(a_.+b_*v_^n_)^p_,x_] := (a+b*v^n)^FracPart[p]/(v^(n*FracPart[p])*(b+a*v^(-n))^FracPart[p])*Integrate[u*v^(n*p)*(b+a*v^(-n))^p,x] /;
FreeQ[{a,b,p},x] && Not[IntegerQ[p]] && ILtQ[n,0] && BinomialQ[v,x] && Not[LinearQ[v,x]]

Integrate[u_*(a_.+b_*x_^m_*v_^n_)^p_,x_] := (a+b*x^m*v^n)^FracPart[p]/(v^(n*FracPart[p])*(b*x^m+a*v^(-n))^FracPart[p])*Integrate[u*v^(n*p)*(b*x^m+a*v^(-n))^p,x] /;
FreeQ[{a,b,m,p},x] && Not[IntegerQ[p]] && ILtQ[n,0] && BinomialQ[v,x]

Integrate[u_*(a_*x_^r_.+b_*x_^s_.)^m_,x_] := With[{v=(a*x^r+b*x^s)^FracPart[m]/(x^(r*FracPart[m])*(a+b*x^(s-r))^FracPart[m])}, v*Integrate[u*x^(m*r)*(a+b*x^(s-r))^m,x] /; NeQ[Simplify[v],1]] /;
FreeQ[{a,b,m,r,s},x] && Not[IntegerQ[m]] && PosQ[s-r]

Integrate[u_/(a_+b_*x_^n_),x_] := With[{v=RationalFunctionExpand[u/(a+b*x^n),x]}, Integrate[v,x] /; SumQ[v]] /;
FreeQ[{a,b},x] && IGtQ[n,0]

Integrate[u_*(a_.+b_*x_^n_.+c_*x_^n2_.)^p_.,x_] := 1/(4^p*c^p)*Integrate[u*(b+2*c*x^n)^(2*p),x] /;
