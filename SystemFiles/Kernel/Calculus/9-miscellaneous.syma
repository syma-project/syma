FreeQ[{a,b,c,d,m,n,p},x] && EqQ[v,y]

Integrate[u_*(a_.+b_*y_^n_)^m_*(c_.+d_*v_^n_)^p_*(e_.+f_*w_^n_)^q_.,x_] := With[{r=DerivativeDivides[y,u,x]}, r*Subst[Integrate[(a+b*x^n)^m*(c+d*x^n)^p*(e+f*x^n)^q,x],x,y] /; Not[FalseQ[r]]] /;
FreeQ[{a,b,c,d,e,f,m,n,p,q},x] && EqQ[v,y] && EqQ[w,y]

