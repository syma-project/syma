FreeQ[{a,b,m,p},x] && IntegerQ[p]

Integrate[u_*(a_+b_*v_^p_*w_^q_.)^m_*v_^r_.,x_] := With[{c=Simplify[u/(p*w*D[v,x]+q*v*D[w,x])]}, c*p/(r+1)*Subst[Integrate[(a+b*x^(p/(r+1)))^m,x],x,v^(r+1)*w] /; FreeQ[c,x]] /;
