FreeQ[{a,m,n,p,q},x] && Not[IntegerQ[p]] && Not[FreeQ[v,x]] && Not[FreeQ[w,x]] && Not[FreeQ[z,x]]

Integrate[u_*(a_*v_^m_*w_^n_.)^p_,x_] := a^IntPart[p]*(a*v^m*w^n)^FracPart[p]/(v^(m*FracPart[p])*w^(n*FracPart[p]))*Integrate[u*v^(m*p)*w^(n*p),x] /;
FreeQ[{a,m,n,p},x] && Not[IntegerQ[p]] && Not[FreeQ[v,x]] && Not[FreeQ[w,x]]

Integrate[u_*(a_*v_^m_.)^p_,x_] := a^IntPart[p]*(a*v^m)^FracPart[p]/v^(m*FracPart[p])*Integrate[u*v^(m*p),x] /;
FreeQ[{a,m,p},x] && Not[IntegerQ[p]] && Not[FreeQ[v,x]] && Not[EqQ[a,1] && EqQ[m,1]] && Not[EqQ[v,x] && EqQ[m,1]]

Integrate[u_*(a_.+b_*x_^n_)^p_,x_] := b^IntPart[p]*(a+b*x^n)^FracPart[p]/(x^(n*FracPart[p])*(1+a*x^(-n)/b)^FracPart[p])*Integrate[u*x^(n*p)*(1+a*x^(-n)/b)^p,x] /;
