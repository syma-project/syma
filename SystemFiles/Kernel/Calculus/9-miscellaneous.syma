FreeQ[{a,b,n,p},x]

Integrate[u_*v_^m_*(a_.+b_*y_^n_)^p_.,x_] := Module[{q,r}, q*r*Subst[Integrate[x^m*(a+b*x^n)^p,x],x,y] /; Not[FalseQ[r=Divides[y^m,v^m,x]]] && Not[FalseQ[q=DerivativeDivides[y,u,x]]]] /;
