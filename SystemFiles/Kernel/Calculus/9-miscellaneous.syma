Integrate[u_*(a_+b_*x_^n_.)^p_.,x_] := Integrate[u*(b*x^n)^p,x] /;
FreeQ[{a,b,n,p},x] && EqQ[a,0]

Integrate[u_*(a_.+b_*x_^n_.)^p_.,x_] := Integrate[u*a^p,x] /;
FreeQ[{a,b,n,p},x] && EqQ[b,0]

Integrate[u_*(a_+b_*x_^n_.+c_*x_^j_.)^p_.,x_] := Integrate[u*(b*x^n+c*x^(2*n))^p,x] /;
FreeQ[{a,b,c,n,p},x] && EqQ[j,2*n] && EqQ[a,0]

Integrate[u_*(a_.+b_*x_^n_.+c_*x_^j_.)^p_.,x_] := Integrate[u*(a+c*x^(2*n))^p,x] /;
FreeQ[{a,b,c,n,p},x] && EqQ[j,2*n] && EqQ[b,0]

Integrate[u_*(a_.+b_*x_^n_.+c_*x_^j_.)^p_.,x_] := Integrate[u*(a+b*x^n)^p,x] /;
FreeQ[{a,b,c,n,p},x] && EqQ[j,2*n] && EqQ[c,0]

Integrate[u_*(a_*v_+b_*v_+w_.)^p_.,x_] := Integrate[u*((a+b)*v+w)^p,x] /;
FreeQ[{a,b},x] && Not[FreeQ[v,x]]

Integrate[u_*Px_^p_,x_] := Integrate[u*Px^Simplify[p],x] /;
PolyQ[Px,x] && Not[RationalQ[p]] && FreeQ[p,x] && RationalQ[Simplify[p]]

Integrate[a_,x_] := a*x /;
FreeQ[a,x]

Integrate[a_*(b_+c_*x_),x_] := a*(b+c*x)^2/(2*c) /;
FreeQ[{a,b,c},x]

Integrate[-u_,x_] := Identity[-1]*Integrate[u,x]

Integrate[Complex[0,a_]*u_,x_] := Complex[Identity[0],a]*Integrate[u,x] /;
FreeQ[a,x] && EqQ[a^2,1]

Integrate[a_*u_,x_] := a*Integrate[u,x] /;
FreeQ[a,x] && Not[MatchQ[u, b_*v_ /; FreeQ[b,x]]] If[TrueQ[$LoadShowSteps],

Integrate[u_,x_] := ShowStep["\<\>","\<Integrate[a*u + b*v + CenterEllipsis,x]\>","\<a*Integrate[u,x] + b*Integrate[v,x] + CenterEllipsis\>",Hold[ IntSum[u,x]]] /;
SimplifyFlag && SumQ[u],

Integrate[u_,x_] := IntSum[u,x] /;
SumQ[u]]

Integrate[(c_*x_)^m_*u_,x_] := Integrate[ExpandIntegrand[(c*x)^m*u,x],x] /;
FreeQ[{c,m},x] && SumQ[u] && Not[LinearQ[u,x]] && Not[MatchQ[u,a_+b_*v_ /; FreeQ[{a,b},x] && InverseFunctionQ[v]]]

