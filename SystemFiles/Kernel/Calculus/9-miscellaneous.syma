Integrate[u_*(a_.+b_*x_^n_.+c_*x_^n2_.)^p_,x_] := (a+b*x^n+c*x^(2*n))^p/(b+2*c*x^n)^(2*p)*Integrate[u*(b+2*c*x^n)^(2*p),x] /;
