Integrate[u_,x_] := With[{lst=SubstForFractionalPowerOfQuotientOfLinears[u,x]}, lst[[2]]*lst[[4]]*Subst[Integrate[lst[[1]],x],x,lst[[3]]^(1/lst[[2]])] /; Not[FalseQ[lst]]]]

