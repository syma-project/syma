FreeQ[{a,b,m,p,q,r},x] && EqQ[p+q*(m*p+r+1),0] && IntegerQ[q] && IntegerQ[m]

Integrate[u_*(a_*v_^p_.+b_*w_^q_.)^m_*w_^s_.,x_] := With[{c=Simplify[u/(p*w*D[v,x]-q*v*D[w,x])]}, -c*q/(s+1)*Subst[Integrate[(a+b*x^(q/(s+1)))^m,x],x,v^(m*p+1)*w^(s+1)] /; FreeQ[c,x]] /;
FreeQ[{a,b,m,p,q,s},x] && EqQ[p*(s+1)+q*(m*p+1),0] && NeQ[s,-1] && IntegerQ[q/(s+1)] && IntegerQ[m]

Integrate[u_*(a_*v_^p_.+b_*w_^q_.)^m_*v_^r_*w_^s_.,x_] := With[{c=Simplify[u/(p*w*D[v,x]-q*v*D[w,x])]}, -c*q/(s+1)*Subst[Integrate[(a+b*x^(q/(s+1)))^m,x],x,v^(m*p+r+1)*w^(s+1)] /; FreeQ[c,x]] /;
FreeQ[{a,b,m,p,q,r,s},x] && EqQ[p*(s+1)+q*(m*p+r+1),0] && NeQ[s,-1] && IntegerQ[q/(s+1)] && IntegerQ[m]

Integrate[u_*x_^m_.,x_] := 1/(m+1)*Subst[Integrate[SubstFor[x^(m+1),u,x],x],x,x^(m+1)] /;
