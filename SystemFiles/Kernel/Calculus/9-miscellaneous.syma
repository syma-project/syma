Integrate[u_*(a_+b_*x_^n_.)^m_*(c_+d_*x_^q_.)^p_.,x_] := (d/a)^p*Integrate[u*(a+b*x^n)^(m+p)/x^(n*p),x] /;
FreeQ[{a,b,c,d,m,n},x] && EqQ[q,-n] && IntegerQ[p] && EqQ[a*c-b*d,0] && Not[IntegerQ[m] && NegQ[n]]

Integrate[u_*(a_+b_*x_^n_.)^m_*(c_+d_*x_^j_)^p_.,x_] := (-b^2/d)^m*Integrate[u*(a-b*x^n)^(-m),x] /;
FreeQ[{a,b,c,d,m,n,p},x] && EqQ[j,2*n] && EqQ[p,-m] && EqQ[b^2*c+a^2*d,0] && GtQ[a,0] && LtQ[d,0]

Integrate[u_*(a_+b_*x_+c_*x_^2)^p_.,x_] := Integrate[u*Cancel[(b/2+c*x)^(2*p)/c^p],x] /;
FreeQ[{a,b,c},x] && EqQ[b^2-4*a*c,0] && IntegerQ[p]

Integrate[u_*(a_+b_*x_^n_+c_*x_^n2_.)^p_.,x_] := 1/c^p*Integrate[u*(b/2+c*x^n)^(2*p),x] /;
FreeQ[{a,b,c,n},x] && EqQ[n2,2*n] && EqQ[b^2-4*a*c,0] && IntegerQ[p]

Integrate[Derivative[n_][f_][x_],x_] := Derivative[n-1][f][x] /;
FreeQ[{f,n},x]

Integrate[(c_*F_^(a_.+b_*x_))^p_*Derivative[n_][f_][x_],x_] := (c*F^(a+b*x))^p*Derivative[n-1][f][x] - b*p*Log[F]*Integrate[(c*F^(a+b*x))^p*Derivative[n-1][f][x],x] /;
FreeQ[{a,b,c,f,F,p},x] && IGtQ[n,0]

Integrate[(c_*F_^(a_.+b_*x_))^p_*Derivative[n_][f_][x_],x_] := (c*F^(a+b*x))^p*Derivative[n][f][x]/(b*p*Log[F]) - 1/(b*p*Log[F])*Integrate[(c*F^(a+b*x))^p*Derivative[n+1][f][x],x] /;
FreeQ[{a,b,c,f,F,p},x] && ILtQ[n,0]

Integrate[Sin[a_.+b_*x_]*Derivative[n_][f_][x_],x_] := Sin[a+b*x]*Derivative[n-1][f][x] - b*Integrate[Cos[a+b*x]*Derivative[n-1][f][x],x] /;
FreeQ[{a,b,f},x] && IGtQ[n,0]

Integrate[Cos[a_.+b_*x_]*Derivative[n_][f_][x_],x_] := Cos[a+b*x]*Derivative[n-1][f][x] + b*Integrate[Sin[a+b*x]*Derivative[n-1][f][x],x] /;
FreeQ[{a,b,f},x] && IGtQ[n,0]

Integrate[Sin[a_.+b_*x_]*Derivative[n_][f_][x_],x_] := -Cos[a+b*x]*Derivative[n][f][x]/b + 1/b*Integrate[Cos[a+b*x]*Derivative[n+1][f][x],x] /;
FreeQ[{a,b,f},x] && ILtQ[n,0]

Integrate[Cos[a_.+b_*x_]*Derivative[n_][f_][x_],x_] := Sin[a+b*x]*Derivative[n][f][x]/b - 1/b*Integrate[Sin[a+b*x]*Derivative[n+1][f][x],x] /;
FreeQ[{a,b,f},x] && ILtQ[n,0]

Integrate[u_*Derivative[n_][f_][x_],x_] := Subst[Integrate[SimplifyIntegrand[SubstFor[Derivative[n-1][f][x],u,x],x],x],x,Derivative[n-1][f][x]] /;
FreeQ[{f,n},x] && FunctionOfQ[Derivative[n-1][f][x],u,x]

Integrate[u_*(a_*Derivative[1][f_][x_]*g_[x_]+a_*f_[x_]*Derivative[1][g_][x_]),x_] := a*Subst[Integrate[SimplifyIntegrand[SubstFor[f[x]*g[x],u,x],x],x],x,f[x]*g[x]] /;
FreeQ[{a,f,g},x] && FunctionOfQ[f[x]*g[x],u,x]

Integrate[u_*(a_*Derivative[m_][f_][x_]*g_[x_]+a_*Derivative[m1_][f_][x_]*Derivative[1][g_][x_]),x_] := a*Subst[Integrate[SimplifyIntegrand[SubstFor[Derivative[m-1][f][x]*g[x],u,x],x],x],x,Derivative[m-1][f][x]*g[x]] /;
FreeQ[{a,f,g,m},x] && EqQ[m1,m-1] && FunctionOfQ[Derivative[m-1][f][x]*g[x],u,x]

Integrate[u_*(a_*Derivative[m_][f_][x_]*Derivative[n1_][g_][x_]+a_*Derivative[m1_][f_][x_]*Derivative[n_][g_][x_]),x_] := a*Subst[Integrate[SimplifyIntegrand[SubstFor[Derivative[m-1][f][x]*Derivative[n-1][g][x],u,x],x],x],x,Derivative[m-1][f][x]*Derivative[n-1][g][x]] /;
FreeQ[{a,f,g,m,n},x] && EqQ[m1,m-1] && EqQ[n1,n-1] && FunctionOfQ[Derivative[m-1][f][x]*Derivative[n-1][g][x],u,x]

Integrate[u_*f_[x_]^p_*(a_*Derivative[1][f_][x_]*g_[x_]+b_*f_[x_]*Derivative[1][g_][x_]),x_] := b*Subst[Integrate[SimplifyIntegrand[SubstFor[f[x]^(p+1)*g[x],u,x],x],x],x,f[x]^(p+1)*g[x]] /;
FreeQ[{a,b,f,g,p},x] && EqQ[a,b*(p+1)] && FunctionOfQ[f[x]^(p+1)*g[x],u,x]

Integrate[u_*Derivative[m1_][f_][x_]^p_* (a_*Derivative[m_][f_][x_]*g_[x_]+b_*Derivative[m1_][f_][x_]*Derivative[1][g_][x_]),x_] := b*Subst[Integrate[SimplifyIntegrand[SubstFor[Derivative[m-1][f][x]^(p+1)*g[x],u,x],x],x],x, Derivative[m-1][f][x]^(p+1)*g[x]] /;
FreeQ[{a,b,f,g,m,p},x] && EqQ[m1,m-1] && EqQ[a,b*(p+1)] && FunctionOfQ[Derivative[m-1][f][x]^(p+1)*g[x],u,x]

Integrate[u_*g_[x_]^q_* (a_*Derivative[m_][f_][x_]*g_[x_]+b_*Derivative[m1_][f_][x_]*Derivative[1][g_][x_]),x_] := a*Subst[Integrate[SimplifyIntegrand[SubstFor[Derivative[m-1][f][x]*g[x]^(q+1),u,x],x],x],x, Derivative[m-1][f][x]*g[x]^(q+1)] /;
FreeQ[{a,b,f,g,m,q},x] && EqQ[m1,m-1] && EqQ[a*(q+1),b] && FunctionOfQ[Derivative[m-1][f][x]*g[x]^(q+1),u,x]

Integrate[u_*Derivative[m1_][f_][x_]^p_* (a_*Derivative[m_][f_][x_]*Derivative[n1_][g_][x_]+b_*Derivative[m1_][f_][x_]*Derivative[n_][g_][x_]),x_] := b*Subst[Integrate[SimplifyIntegrand[SubstFor[Derivative[m-1][f][x]^(p+1)*Derivative[n-1][g][x],u,x],x],x],x, Derivative[m-1][f][x]^(p+1)*Derivative[n-1][g][x]] /;
FreeQ[{a,b,f,g,m,n,p},x] && EqQ[m1,m-1] && EqQ[n1,n-1] && EqQ[a,b*(p+1)] && FunctionOfQ[Derivative[m-1][f][x]^(p+1)*Derivative[n-1][g][x],u,x]

Integrate[u_*f_[x_]^p_*g_[x_]^q_*(a_*Derivative[1][f_][x_]*g_[x_]+b_*f_[x_]*Derivative[1][g_][x_]),x_] := a/(p+1)*Subst[Integrate[SimplifyIntegrand[SubstFor[f[x]^(p+1)*g[x]^(q+1),u,x],x],x],x,f[x]^(p+1)*g[x]^(q+1)] /;
FreeQ[{a,b,f,g,p,q},x] && EqQ[a*(q+1),b*(p+1)] && FunctionOfQ[f[x]^(p+1)*g[x]^(q+1),u,x]

Integrate[u_*Derivative[m1_][f_][x_]^p_*g_[x_]^q_* (a_*Derivative[m_][f_][x_]*g_[x_]+b_*Derivative[m1_][f_][x_]*Derivative[1][g_][x_]),x_] := a/(p+1)*Subst[Integrate[SimplifyIntegrand[SubstFor[Derivative[m-1][f][x]^(p+1)*g[x]^(q+1),u,x],x],x],x, Derivative[m-1][f][x]^(p+1)*g[x]^(q+1)] /;
FreeQ[{a,b,f,g,m,p,q},x] && EqQ[m1,m-1] && EqQ[a*(q+1),b*(p+1)] && FunctionOfQ[Derivative[m-1][f][x]^(p+1)*g[x]^(q+1),u,x]

Integrate[u_*Derivative[m1_][f_][x_]^p_*Derivative[n1_][g_][x_]^q_* (a_*Derivative[m_][f_][x_]*Derivative[n1_][g_][x_]+b_*Derivative[m1_][f_][x_]*Derivative[n_][g_][x_]),x_] := a/(p+1)*Subst[Integrate[SimplifyIntegrand[SubstFor[Derivative[m-1][f][x]^(p+1)*Derivative[n-1][g][x]^(q+1),u,x],x],x],x, Derivative[m-1][f][x]^(p+1)*Derivative[n-1][g][x]^(q+1)] /;
FreeQ[{a,b,f,g,m,n,p,q},x] && EqQ[m1,m-1] && EqQ[n1,n-1] && EqQ[a*(q+1),b*(p+1)] && FunctionOfQ[Derivative[m-1][f][x]^(p+1)*Derivative[n-1][g][x]^(q+1),u,x]

Integrate[f_'[x_]*g_[x_] + f_[x_]*g_'[x_],x_] := f[x]*g[x] /;
FreeQ[{f,g},x]

Integrate[(f_'[x_]*g_[x_] - f_[x_]*g_'[x_])/g_[x_]^2,x_] := f[x]/g[x] /;
FreeQ[{f,g},x]

Integrate[(f_'[x_]*g_[x_] - f_[x_]*g_'[x_])/(f_[x_]*g_[x_]),x_] := Log[f[x]/g[x]] /;
FreeQ[{f,g},x]

Integrate[u_^m_.,x_] := With[{c=Simplify[D[u,x]]}, 1/c*Subst[Integrate[x^m,x],x,u]] /;
FreeQ[m,x] && PiecewiseLinearQ[u,x]

Integrate[v_/u_,x_] := With[{a=Simplify[D[u,x]],b=Simplify[D[v,x]]}, b*x/a - (b*u-a*v)/a*Integrate[1/u,x] /; NeQ[b*u-a*v,0]] /;
PiecewiseLinearQ[u,v,x]

Integrate[v_^n_/u_,x_] := With[{a=Simplify[D[u,x]],b=Simplify[D[v,x]]}, v^n/(a*n) - (b*u-a*v)/a*Integrate[v^(n-1)/u,x] /; NeQ[b*u-a*v,0]] /;
PiecewiseLinearQ[u,v,x] && GtQ[n,0] && NeQ[n,1]

Integrate[1/(u_*v_),x_] := With[{a=Simplify[D[u,x]],b=Simplify[D[v,x]]}, b/(b*u-a*v)*Integrate[1/v,x] - a/(b*u-a*v)*Integrate[1/u,x] /; NeQ[b*u-a*v,0]] /;
PiecewiseLinearQ[u,v,x]

Integrate[1/(u_*Sqrt[v_]),x_] := With[{a=Simplify[D[u,x]],b=Simplify[D[v,x]]}, 2*ArcTan[Sqrt[v]/Rt[(b*u-a*v)/a,2]]/(a*Rt[(b*u-a*v)/a,2]) /; NeQ[b*u-a*v,0] && PosQ[(b*u-a*v)/a]] /;
PiecewiseLinearQ[u,v,x]

Integrate[1/(u_*Sqrt[v_]),x_] := With[{a=Simplify[D[u,x]],b=Simplify[D[v,x]]}, -2*ArcTanh[Sqrt[v]/Rt[-(b*u-a*v)/a,2]]/(a*Rt[-(b*u-a*v)/a,2]) /; NeQ[b*u-a*v,0] && NegQ[(b*u-a*v)/a]] /;
PiecewiseLinearQ[u,v,x]

Integrate[v_^n_/u_,x_] := With[{a=Simplify[D[u,x]],b=Simplify[D[v,x]]}, v^(n+1)/((n+1)*(b*u-a*v)) -    a*(n+1)/((n+1)*(b*u-a*v))*Integrate[v^(n+1)/u,x] /; NeQ[b*u-a*v,0]] /;
PiecewiseLinearQ[u,v,x] && LtQ[n,-1]

Integrate[v_^n_/u_,x_] := With[{a=Simplify[D[u,x]],b=Simplify[D[v,x]]}, v^(n+1)/((n+1)*(b*u-a*v))*Hypergeometric2F1[1,n+1,n+2,-a*v/(b*u-a*v)] /; NeQ[b*u-a*v,0]] /;
PiecewiseLinearQ[u,v,x] && Not[IntegerQ[n]]

Integrate[1/(Sqrt[u_]*Sqrt[v_]),x_] := With[{a=Simplify[D[u,x]],b=Simplify[D[v,x]]}, 2/Rt[a*b,2]*ArcTanh[Rt[a*b,2]*Sqrt[u]/(a*Sqrt[v])] /; NeQ[b*u-a*v,0] && PosQ[a*b]] /;
PiecewiseLinearQ[u,v,x]

Integrate[1/(Sqrt[u_]*Sqrt[v_]),x_] := With[{a=Simplify[D[u,x]],b=Simplify[D[v,x]]}, 2/Rt[-a*b,2]*ArcTan[Rt[-a*b,2]*Sqrt[u]/(a*Sqrt[v])] /; NeQ[b*u-a*v,0] && NegQ[a*b]] /;
PiecewiseLinearQ[u,v,x]

Integrate[u_^m_*v_^n_,x_] := With[{a=Simplify[D[u,x]],b=Simplify[D[v,x]]}, -u^(m+1)*v^(n+1)/((m+1)*(b*u-a*v)) /; NeQ[b*u-a*v,0]] /;
FreeQ[{m,n},x] && PiecewiseLinearQ[u,v,x] && EqQ[m+n+2,0] && NeQ[m,-1]

Integrate[u_^m_*v_^n_.,x_] := With[{a=Simplify[D[u,x]],b=Simplify[D[v,x]]}, u^(m+1)*v^n/(a*(m+1)) -    b*n/(a*(m+1))*Integrate[u^(m+1)*v^(n-1),x] /; NeQ[b*u-a*v,0]] /;
FreeQ[{m,n},x] && PiecewiseLinearQ[u,v,x]  && NeQ[m,-1] && ( LtQ[m,-1] && GtQ[n,0] && Not[ILtQ[m+n,-2] && (FractionQ[m] || GeQ[2*n+m+1,0])] || IGtQ[n,0] && IGtQ[m,0] && LeQ[n,m] || IGtQ[n,0] && Not[IntegerQ[m]] || ILtQ[m,0] && Not[IntegerQ[n]])

Integrate[u_^m_*v_^n_.,x_] := With[{a=Simplify[D[u,x]],b=Simplify[D[v,x]]}, u^(m+1)*v^n/(a*(m+n+1)) -    n*(b*u-a*v)/(a*(m+n+1))*Integrate[u^m*v^(n-1),x] /; NeQ[b*u-a*v,0]] /;
PiecewiseLinearQ[u,v,x] && NeQ[m+n+2,0] && GtQ[n,0] && NeQ[m+n+1,0] && Not[IGtQ[m,0] && (Not[IntegerQ[n]] || LtQ[0,m,n])] && Not[ILtQ[m+n,-2]]

Integrate[u_^m_*v_^n_,x_] := With[{a=Simplify[D[u,x]],b=Simplify[D[v,x]]}, u^(m+1)*v^n/(a*(m+n+1)) -    n*(b*u-a*v)/(a*(m+n+1))*Integrate[u^m*v^Simplify[n-1],x] /; NeQ[b*u-a*v,0]] /;
PiecewiseLinearQ[u,v,x] && NeQ[m+n+1,0] && Not[RationalQ[n]] && SumSimplerQ[n,-1]

Integrate[u_^m_*v_^n_,x_] := With[{a=Simplify[D[u,x]],b=Simplify[D[v,x]]}, -u^(m+1)*v^(n+1)/((m+1)*(b*u-a*v)) +    b*(m+n+2)/((m+1)*(b*u-a*v))*Integrate[u^(m+1)*v^n,x] /; NeQ[b*u-a*v,0]] /;
PiecewiseLinearQ[u,v,x] && NeQ[m+n+2,0] && LtQ[m,-1]

Integrate[u_^m_*v_^n_,x_] := With[{a=Simplify[D[u,x]],b=Simplify[D[v,x]]}, -u^(m+1)*v^(n+1)/((m+1)*(b*u-a*v)) +    b*(m+n+2)/((m+1)*(b*u-a*v))*Integrate[u^Simplify[m+1]*v^n,x] /; NeQ[b*u-a*v,0]] /;
PiecewiseLinearQ[u,v,x] && Not[RationalQ[m]] && SumSimplerQ[m,1]

Integrate[u_^m_*v_^n_,x_] := With[{a=Simplify[D[u,x]],b=Simplify[D[v,x]]}, u^m*v^(n+1)/(b*(n+1)*(b*u/(b*u-a*v))^m)*Hypergeometric2F1[-m,n+1,n+2,-a*v/(b*u-a*v)] /; NeQ[b*u-a*v,0]] /;
PiecewiseLinearQ[u,v,x] && Not[IntegerQ[m]] && Not[IntegerQ[n]]

Integrate[u_^n_*Log[a_.+b_*x_],x_] := With[{c=Simplify[D[u,x]]}, u^n*(a+b*x)*Log[a+b*x]/b - Integrate[u^n,x] - c*n/b*Integrate[u^(n-1)*(a+b*x)*Log[a+b*x],x]] /;
FreeQ[{a,b},x] && PiecewiseLinearQ[u,x] && Not[LinearQ[u,x]] && GtQ[n,0] (* Integrate[u_^n_*Log[a_.+b_*x_]/(a_.+b_*x_),x_] := With[{c=Simplify[D[u,x]]}, u^n*Log[a+b*x]^2/(2*b) - c*n/(2*b)*Integrate[u^(n-1)*Log[a+b*x]^2,x]] /; FreeQ[{a,b},x] && PiecewiseLinearQ[u,x] && GtQ[n,0] *)

Integrate[u_^n_*(a_.+b_*x_)^m_*Log[a_.+b_*x_],x_] := With[{c=Simplify[D[u,x]]}, u^n*(a+b*x)^(m+1)*Log[a+b*x]/(b*(m+1)) - 1/(m+1)*Integrate[u^n*(a+b*x)^m,x] - c*n/(b*(m+1))*Integrate[u^(n-1)*(a+b*x)^(m+1)*Log[a+b*x],x]] /;
FreeQ[{a,b,m},x] && PiecewiseLinearQ[u,x] && Not[LinearQ[u,x]] && GtQ[n,0] && NeQ[m,-1]

Integrate[(a_.+b_*F_[c_*Sqrt[d_.+e_*x_]/Sqrt[f_.+g_*x_]])^n_./(A_.+B_*x_+C_*x_^2),x_] := 2*e*g/(C*(e*f-d*g))*Subst[Integrate[(a+b*F[c*x])^n/x,x],x,Sqrt[d+e*x]/Sqrt[f+g*x]] /;
FreeQ[{a,b,c,d,e,f,g,A,B,C,F},x] && EqQ[C*d*f-A*e*g,0] && EqQ[B*e*g-C*(e*f+d*g),0] && IGtQ[n,0]

Integrate[(a_.+b_*F_[c_*Sqrt[d_.+e_*x_]/Sqrt[f_.+g_*x_]])^n_./(A_.+C_*x_^2),x_] := 2*e*g/(C*(e*f-d*g))*Subst[Integrate[(a+b*F[c*x])^n/x,x],x,Sqrt[d+e*x]/Sqrt[f+g*x]] /;
FreeQ[{a,b,c,d,e,f,g,A,C,F},x] && EqQ[C*d*f-A*e*g,0] && EqQ[e*f+d*g,0] && IGtQ[n,0]

Integrate[(a_.+b_*F_[c_*Sqrt[d_.+e_*x_]/Sqrt[f_.+g_*x_]])^n_/(A_.+B_*x_+C_*x_^2),x_] := Unintegrable[(a+b*F[c*Sqrt[d+e*x]/Sqrt[f+g*x]])^n/(A+B*x+C*x^2),x] /;
FreeQ[{a,b,c,d,e,f,g,A,B,C,F,n},x] && EqQ[C*d*f-A*e*g,0] && EqQ[B*e*g-C*(e*f+d*g),0] && Not[IGtQ[n,0]]

Integrate[(a_.+b_*F_[c_*Sqrt[d_.+e_*x_]/Sqrt[f_.+g_*x_]])^n_/(A_+C_*x_^2),x_] := Unintegrable[(a+b*F[c*Sqrt[d+e*x]/Sqrt[f+g*x]])^n/(A+C*x^2),x] /;
FreeQ[{a,b,c,d,e,f,g,A,C,F,n},x] && EqQ[C*d*f-A*e*g,0] && EqQ[e*f+d*g,0] && Not[IGtQ[n,0]]

Integrate[u_/y_,x_] := With[{q=DerivativeDivides[y,u,x]}, q*Log[RemoveContent[y,x]] /; Not[FalseQ[q]]]

Integrate[u_/(y_*w_),x_] := With[{q=DerivativeDivides[y*w,u,x]}, q*Log[RemoveContent[y*w,x]] /; Not[FalseQ[q]]]

Integrate[u_*y_^m_.,x_] := With[{q=DerivativeDivides[y,u,x]}, q*y^(m+1)/(m+1) /; Not[FalseQ[q]]] /;
FreeQ[m,x] && NeQ[m,-1]

Integrate[u_*y_^m_*z_^n_.,x_] := With[{q=DerivativeDivides[y*z,u*z^(n-m),x]}, q*y^(m+1)*z^(m+1)/(m+1) /; Not[FalseQ[q]]] /;
FreeQ[{m,n},x] && NeQ[m,-1]

Integrate[u_,x_] := With[{v=SimplifyIntegrand[u,x]}, Integrate[v,x] /; SimplerIntegrandQ[v,u,x]]

