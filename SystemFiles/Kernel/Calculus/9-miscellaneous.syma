Integrate[u_*(a_*v_)^m_*(b_*v_)^n_,x_] := a^(m+n)*(b*v)^n/(a*v)^n*Integrate[u*v^(m+n),x] /;
FreeQ[{a,b,m,n},x] && Not[IntegerQ[m]] && Not[IntegerQ[n]] && IntegerQ[m+n]

