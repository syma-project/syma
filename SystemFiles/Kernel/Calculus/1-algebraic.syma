Integrate[(f_*x_)^m_*(a_+c_*x_^4)^p_./(d_.+e_*x_^2),x_] := 1/(d*e)*Integrate[(f*x)^m*(a*e+c*d*x^2)*(a+c*x^4)^(p-1),x] - (c*d^2+a*e^2)/(d*e*f^2)*Integrate[(f*x)^(m+2)*(a+c*x^4)^(p-1)/(d+e*x^2),x] /;
FreeQ[{a,c,d,e,f},x] && GtQ[p,0] && LtQ[m,0]

Integrate[(f_*x_)^m_*(a_.+b_*x_^2+c_*x_^4)^p_/(d_.+e_*x_^2),x_] := -f^4/(c*d^2-b*d*e+a*e^2)*Integrate[(f*x)^(m-4)*(a*d+(b*d-a*e)*x^2)*(a+b*x^2+c*x^4)^p,x] + d^2*f^4/(c*d^2-b*d*e+a*e^2)*Integrate[(f*x)^(m-4)*(a+b*x^2+c*x^4)^(p+1)/(d+e*x^2),x] /;
FreeQ[{a,b,c,d,e,f},x] && NeQ[b^2-4*a*c,0] && LtQ[p,-1] && GtQ[m,2]

Integrate[(f_*x_)^m_*(a_+c_*x_^4)^p_/(d_.+e_*x_^2),x_] := -a*f^4/(c*d^2+a*e^2)*Integrate[(f*x)^(m-4)*(d-e*x^2)*(a+c*x^4)^p,x] + d^2*f^4/(c*d^2+a*e^2)*Integrate[(f*x)^(m-4)*(a+c*x^4)^(p+1)/(d+e*x^2),x] /;
FreeQ[{a,c,d,e,f},x] && LtQ[p,-1] && GtQ[m,2]

Integrate[(f_*x_)^m_*(a_.+b_*x_^2+c_*x_^4)^p_/(d_.+e_*x_^2),x_] := f^2/(c*d^2-b*d*e+a*e^2)*Integrate[(f*x)^(m-2)*(a*e+c*d*x^2)*(a+b*x^2+c*x^4)^p,x] - d*e*f^2/(c*d^2-b*d*e+a*e^2)*Integrate[(f*x)^(m-2)*(a+b*x^2+c*x^4)^(p+1)/(d+e*x^2),x] /;
FreeQ[{a,b,c,d,e,f},x] && NeQ[b^2-4*a*c,0] && LtQ[p,-1] && GtQ[m,0]

Integrate[(f_*x_)^m_*(a_+c_*x_^4)^p_/(d_.+e_*x_^2),x_] := f^2/(c*d^2+a*e^2)*Integrate[(f*x)^(m-2)*(a*e+c*d*x^2)*(a+c*x^4)^p,x] - d*e*f^2/(c*d^2+a*e^2)*Integrate[(f*x)^(m-2)*(a+c*x^4)^(p+1)/(d+e*x^2),x] /;
FreeQ[{a,c,d,e,f},x] && LtQ[p,-1] && GtQ[m,0]

Integrate[x_^2/((d_+e_*x_^2)*Sqrt[a_+b_*x_^2+c_*x_^4]),x_] := d/(2*d*e)*Integrate[1/Sqrt[a+b*x^2+c*x^4],x] - d/(2*d*e)*Integrate[(d-e*x^2)/((d+e*x^2)*Sqrt[a+b*x^2+c*x^4]),x] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && NeQ[c*d^2-b*d*e+a*e^2,0] && PosQ[c/a] && EqQ[c*d^2-a*e^2,0]

Integrate[x_^2/((d_+e_*x_^2)*Sqrt[a_+c_*x_^4]),x_] := d/(2*d*e)*Integrate[1/Sqrt[a+c*x^4],x] - d/(2*d*e)*Integrate[(d-e*x^2)/((d+e*x^2)*Sqrt[a+c*x^4]),x] /;
FreeQ[{a,c,d,e},x] && NeQ[c*d^2+a*e^2,0] && PosQ[c/a] && EqQ[c*d^2-a*e^2,0]

Integrate[x_^2/((d_+e_*x_^2)*Sqrt[a_+b_*x_^2+c_*x_^4]),x_] := With[{q=Rt[c/a,2]}, -a*(e+d*q)/(c*d^2-a*e^2)*Integrate[1/Sqrt[a+b*x^2+c*x^4],x] + a*d*(e+d*q)/(c*d^2-a*e^2)*Integrate[(1+q*x^2)/((d+e*x^2)*Sqrt[a+b*x^2+c*x^4]),x]] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && NeQ[c*d^2-b*d*e+a*e^2,0] && PosQ[c/a] && NeQ[c*d^2-a*e^2,0]

Integrate[x_^2/((d_+e_*x_^2)*Sqrt[a_+c_*x_^4]),x_] := With[{q=Rt[c/a,2]}, -a*(e+d*q)/(c*d^2-a*e^2)*Integrate[1/Sqrt[a+c*x^4],x] + a*d*(e+d*q)/(c*d^2-a*e^2)*Integrate[(1+q*x^2)/((d+e*x^2)*Sqrt[a+c*x^4]),x]] /;
FreeQ[{a,c,d,e},x] && NeQ[c*d^2+a*e^2,0] && PosQ[c/a] && NeQ[c*d^2-a*e^2,0]

Integrate[x_^4/((d_+e_*x_^2)*Sqrt[a_+b_*x_^2+c_*x_^4]),x_] := -1/e^2*Integrate[(d-e*x^2)/Sqrt[a+b*x^2+c*x^4],x] + d^2/e^2*Integrate[1/((d+e*x^2)*Sqrt[a+b*x^2+c*x^4]),x] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && PosQ[c/a] && EqQ[c*d^2-a*e^2,0]

Integrate[x_^4/((d_+e_*x_^2)*Sqrt[a_+c_*x_^4]),x_] := -1/e^2*Integrate[(d-e*x^2)/Sqrt[a+c*x^4],x] + d^2/e^2*Integrate[1/((d+e*x^2)*Sqrt[a+c*x^4]),x] /;
FreeQ[{a,c,d,e},x] && PosQ[c/a] && EqQ[c*d^2-a*e^2,0]

Integrate[x_^4/((d_+e_*x_^2)*Sqrt[a_+b_*x_^2+c_*x_^4]),x_] := With[{q=Rt[c/a,2]}, -1/(e*q)*Integrate[(1-q*x^2)/Sqrt[a+b*x^2+c*x^4],x] + d^2/(e*(e-d*q))*Integrate[(1+q*x^2)/((d+e*x^2)*Sqrt[a+b*x^2+c*x^4]),x] /; EqQ[2*c*d-a*e*q,0]] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && PosQ[c/a] && NeQ[c*d^2-a*e^2,0]

Integrate[x_^4/((d_+e_*x_^2)*Sqrt[a_+c_*x_^4]),x_] := With[{q=Rt[c/a,2]}, -1/(e*q)*Integrate[(1-q*x^2)/Sqrt[a+c*x^4],x] + d^2/(e*(e-d*q))*Integrate[(1+q*x^2)/((d+e*x^2)*Sqrt[a+c*x^4]),x] /; EqQ[2*c*d-a*e*q,0]] /;
FreeQ[{a,c,d,e},x] && PosQ[c/a] && NeQ[c*d^2-a*e^2,0]

Integrate[x_^4/((d_+e_*x_^2)*Sqrt[a_+b_*x_^2+c_*x_^4]),x_] := With[{q=Rt[c/a,2]}, -(2*c*d-a*e*q)/(c*e*(e-d*q))*Integrate[1/Sqrt[a+b*x^2+c*x^4],x] - 1/(e*q)*Integrate[(1-q*x^2)/Sqrt[a+b*x^2+c*x^4],x] + d^2/(e*(e-d*q))*Integrate[(1+q*x^2)/((d+e*x^2)*Sqrt[a+b*x^2+c*x^4]),x]] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && PosQ[c/a] && NeQ[c*d^2-a*e^2,0]

Integrate[x_^4/((d_+e_*x_^2)*Sqrt[a_+c_*x_^4]),x_] := With[{q=Rt[c/a,2]}, -(2*c*d-a*e*q)/(c*e*(e-d*q))*Integrate[1/Sqrt[a+c*x^4],x] - 1/(e*q)*Integrate[(1-q*x^2)/Sqrt[a+c*x^4],x] + d^2/(e*(e-d*q))*Integrate[(1+q*x^2)/((d+e*x^2)*Sqrt[a+c*x^4]),x]] /;
FreeQ[{a,c,d,e},x] && PosQ[c/a] && NeQ[c*d^2-a*e^2,0]

Integrate[x_^m_/((d_+e_*x_^2)*Sqrt[a_+b_*x_^2+c_*x_^4]),x_] := x^(m-5)*Sqrt[a+b*x^2+c*x^4]/(c*e*(m-3)) - 1/(c*e*(m-3))*Integrate[x^(m-6)/((d+e*x^2)*Sqrt[a+b*x^2+c*x^4])* Simp[a*d*(m-5)+(a*e*(m-5)+b*d*(m-4))*x^2+(b*e*(m-4)+c*d*(m-3))*x^4,x],x] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && IGtQ[m/2,2]

Integrate[x_^m_/((d_+e_*x_^2)*Sqrt[a_+c_*x_^4]),x_] := x^(m-5)*Sqrt[a+c*x^4]/(c*e*(m-3)) - 1/(c*e*(m-3))*Integrate[x^(m-6)/((d+e*x^2)*Sqrt[a+c*x^4])*Simp[a*d*(m-5)+a*e*(m-5)*x^2+c*d*(m-3)*x^4,x],x] /;
FreeQ[{a,c,d,e},x] && IGtQ[m/2,2]

Integrate[x_^m_/((d_+e_*x_^2)*Sqrt[a_+b_*x_^2+c_*x_^4]),x_] := x^(m+1)*Sqrt[a+b*x^2+c*x^4]/(a*d*(m+1)) - 1/(a*d*(m+1))*Integrate[x^(m+2)/((d+e*x^2)*Sqrt[a+b*x^2+c*x^4])* Simp[a*e*(m+1)+b*d*(m+2)+(b*e*(m+2)+c*d*(m+3))*x^2+c*e*(m+3)*x^4,x],x] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && ILtQ[m/2,0]

Integrate[x_^m_/((d_+e_*x_^2)*Sqrt[a_+c_*x_^4]),x_] := x^(m+1)*Sqrt[a+c*x^4]/(a*d*(m+1)) - 1/(a*d*(m+1))*Integrate[x^(m+2)/((d+e*x^2)*Sqrt[a+c*x^4])*Simp[a*e*(m+1)+c*d*(m+3)*x^2+c*e*(m+3)*x^4,x],x] /;
FreeQ[{a,c,d,e},x] && ILtQ[m/2,0]

Integrate[x_^m_/(Sqrt[d_+e_*x_^2]*Sqrt[a_+b_*x_^2+c_*x_^4]),x_] := x^3*Sqrt[e+d/x^2]*Sqrt[c+b/x^2+a/x^4]/(Sqrt[d+e*x^2]*Sqrt[a+b*x^2+c*x^4])* Integrate[x^(m-3)/(Sqrt[e+d/x^2]*Sqrt[c+b/x^2+a/x^4]),x] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && IntegerQ[m/2]

Integrate[x_^m_/(Sqrt[d_+e_*x_^2]*Sqrt[a_+c_*x_^4]),x_] := x^3*Sqrt[e+d/x^2]*Sqrt[c+a/x^4]/(Sqrt[d+e*x^2]*Sqrt[a+c*x^4])* Integrate[x^(m-3)/(Sqrt[e+d/x^2]*Sqrt[c+a/x^4]),x] /;
FreeQ[{a,c,d,e},x] && IntegerQ[m/2]

Integrate[x_^m_*(d_+e_*x_^2)^q_*(a_+b_*x_^2+c_*x_^4)^p_,x_] := With[{f=Coeff[PolynomialRemainder[x^m*(d+e*x^2)^q,a+b*x^2+c*x^4,x],x,0], g=Coeff[PolynomialRemainder[x^m*(d+e*x^2)^q,a+b*x^2+c*x^4,x],x,2]}, x*(a+b*x^2+c*x^4)^(p+1)*(a*b*g-f*(b^2-2*a*c)-c*(b*f-2*a*g)*x^2)/(2*a*(p+1)*(b^2-4*a*c)) +    1/(2*a*(p+1)*(b^2-4*a*c))*Integrate[(a+b*x^2+c*x^4)^(p+1)* Simp[ExpandToSum[2*a*(p+1)*(b^2-4*a*c)*PolynomialQuotient[x^m*(d+e*x^2)^q,a+b*x^2+c*x^4,x]+ b^2*f*(2*p+3)-2*a*c*f*(4*p+5)-a*b*g+c*(4*p+7)*(b*f-2*a*g)*x^2,x],x],x]] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && LtQ[p,-1] && IGtQ[q,1] && IGtQ[m/2,0]

Integrate[x_^m_*(d_+e_*x_^2)^q_*(a_+b_*x_^2+c_*x_^4)^p_,x_] := With[{f=Coeff[PolynomialRemainder[x^m*(d+e*x^2)^q,a+b*x^2+c*x^4,x],x,0], g=Coeff[PolynomialRemainder[x^m*(d+e*x^2)^q,a+b*x^2+c*x^4,x],x,2]}, x*(a+b*x^2+c*x^4)^(p+1)*(a*b*g-f*(b^2-2*a*c)-c*(b*f-2*a*g)*x^2)/(2*a*(p+1)*(b^2-4*a*c)) +    1/(2*a*(p+1)*(b^2-4*a*c))*Integrate[x^m*(a+b*x^2+c*x^4)^(p+1)* Simp[ExpandToSum[2*a*(p+1)*(b^2-4*a*c)*x^(-m)*PolynomialQuotient[x^m*(d+e*x^2)^q,a+b*x^2+c*x^4,x]+ (b^2*f*(2*p+3)-2*a*c*f*(4*p+5)-a*b*g)*x^(-m)+c*(4*p+7)*(b*f-2*a*g)*x^(2-m),x],x],x]] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && LtQ[p,-1] && IGtQ[q,1] && ILtQ[m/2,0]

Integrate[(f_*x_)^m_*(d_+e_*x_^2)^q_*(a_+b_*x_^2+c_*x_^4)^p_.,x_] := Integrate[ExpandIntegrand[(f*x)^m*(d+e*x^2)^q*(a+b*x^2+c*x^4)^p,x],x] /;
FreeQ[{a,b,c,d,e,f,m,p,q},x] && NeQ[b^2-4*a*c,0] && (IGtQ[p,0] || IGtQ[q,0] || IntegersQ[m,q])

Integrate[(f_*x_)^m_*(d_+e_*x_^2)^q_*(a_+c_*x_^4)^p_.,x_] := Integrate[ExpandIntegrand[(f*x)^m*(d+e*x^2)^q*(a+c*x^4)^p,x],x] /;
FreeQ[{a,c,d,e,f,m,p,q},x] && (IGtQ[p,0] || IGtQ[q,0] || IntegersQ[m,q])

Integrate[(f_*x_)^m_*(d_+e_*x_^2)^q_*(a_+c_*x_^4)^p_,x_] := (f*x)^m/x^m*Integrate[ExpandIntegrand[x^m*(a+c*x^4)^p,(d/(d^2-e^2*x^4)-e*x^2/(d^2-e^2*x^4))^(-q),x],x] /;
FreeQ[{a,c,d,e,f,m,p},x] && Not[IntegerQ[p]] && ILtQ[q,0]

Integrate[(f_*x_)^m_*(d_+e_*x_^2)^q_*(a_+b_*x_^2+c_*x_^4)^p_.,x_] := Unintegrable[(f*x)^m*(d+e*x^2)^q*(a+b*x^2+c*x^4)^p,x] /;
FreeQ[{a,b,c,d,e,f,m,p,q},x]

Integrate[(f_*x_)^m_*(d_+e_*x_^2)^q_*(a_+c_*x_^4)^p_.,x_] := Unintegrable[(f*x)^m*(d+e*x^2)^q*(a+c*x^4)^p,x] /;
FreeQ[{a,c,d,e,f,m,p,q},x]

Integrate[Pq_*(a_+b_*x_^2+c_*x_^4)^p_.,x_] := Integrate[ExpandIntegrand[Pq*(a+b*x^2+c*x^4)^p,x],x] /;
FreeQ[{a,b,c},x] && PolyQ[Pq,x] && IGtQ[p,0]

Integrate[Pq_*(a_+b_*x_^2+c_*x_^4)^p_,x_] := Integrate[x*PolynomialQuotient[Pq,x,x]*(a+b*x^2+c*x^4)^p,x] /;
FreeQ[{a,b,c,p},x] && PolyQ[Pq,x] && EqQ[Coeff[Pq,x,0],0] && Not[MatchQ[Pq,x^m_*u_. /; IntegerQ[m]]]

Integrate[Pq_*(a_+b_*x_^2+c_*x_^4)^p_,x_] := Module[{q=Expon[Pq,x],k}, Integrate[Sum[Coeff[Pq,x,2*k]*x^(2*k),{k,0,q/2}]*(a+b*x^2+c*x^4)^p,x] + Integrate[x*Sum[Coeff[Pq,x,2*k+1]*x^(2*k),{k,0,(q-1)/2}]*(a+b*x^2+c*x^4)^p,x]] /;
FreeQ[{a,b,c,p},x] && PolyQ[Pq,x] && Not[PolyQ[Pq,x^2]]

Integrate[Pq_*(a_+b_*x_^2+c_*x_^4)^p_.,x_] := With[{d=Coeff[Pq,x,0],e=Coeff[Pq,x,2],f=Coeff[Pq,x,4]}, d*x*(a+b*x^2+c*x^4)^(p+1)/a /; EqQ[a*e-b*d*(2*p+3),0] && EqQ[a*f-c*d*(4*p+5),0]] /;
FreeQ[{a,b,c,p},x] && PolyQ[Pq,x^2] && EqQ[Expon[Pq,x],4]

Integrate[Pq_*(a_+b_*x_^2+c_*x_^4)^p_.,x_] := With[{d=Coeff[Pq,x,0],e=Coeff[Pq,x,2],f=Coeff[Pq,x,4],g=Coeff[Pq,x,6]}, x*(3*a*d+(a*e-b*d*(2*p+3))*x^2)*(a+b*x^2+c*x^4)^(p+1)/(3*a^2) /; EqQ[3*a^2*g-c*(4*p+7)*(a*e-b*d*(2*p+3)),0] && EqQ[3*a^2*f-3*a*c*d*(4*p+5)-b*(2*p+5)*(a*e-b*d*(2*p+3)),0]] /;
FreeQ[{a,b,c,p},x] && PolyQ[Pq,x^2] && EqQ[Expon[Pq,x],6]

Integrate[Pq_/(a_+b_*x_^2+c_*x_^4),x_] := Integrate[ExpandIntegrand[Pq/(a+b*x^2+c*x^4),x],x] /;
FreeQ[{a,b,c},x] && PolyQ[Pq,x^2] && Expon[Pq,x^2]>1

Integrate[Pq_*(a_+b_*x_^2+c_*x_^4)^p_,x_] := (a+b*x^2+c*x^4)^FracPart[p]/((4*c)^IntPart[p]*(b+2*c*x^2)^(2*FracPart[p]))*Integrate[Pq*(b+2*c*x^2)^(2*p),x] /;
FreeQ[{a,b,c,p},x] && PolyQ[Pq,x^2] && Expon[Pq,x^2]>1 && EqQ[b^2-4*a*c,0]

Integrate[Pq_*(a_+b_*x_^2+c_*x_^4)^p_,x_] := With[{d=Coeff[PolynomialRemainder[Pq,a+b*x^2+c*x^4,x],x,0], e=Coeff[PolynomialRemainder[Pq,a+b*x^2+c*x^4,x],x,2]}, x*(a+b*x^2+c*x^4)^(p+1)*(a*b*e-d*(b^2-2*a*c)-c*(b*d-2*a*e)*x^2)/(2*a*(p+1)*(b^2-4*a*c)) +    1/(2*a*(p+1)*(b^2-4*a*c))*Integrate[(a+b*x^2+c*x^4)^(p+1)* ExpandToSum[2*a*(p+1)*(b^2-4*a*c)*PolynomialQuotient[Pq,a+b*x^2+c*x^4,x]+ b^2*d*(2*p+3)-2*a*c*d*(4*p+5)-a*b*e+c*(4*p+7)*(b*d-2*a*e)*x^2,x],x]] /;
FreeQ[{a,b,c},x] && PolyQ[Pq,x^2] && Expon[Pq,x^2]>1 && NeQ[b^2-4*a*c,0] && LtQ[p,-1]

Integrate[Pq_*(a_+b_*x_^2+c_*x_^4)^p_,x_] := With[{q=Expon[Pq,x^2],e=Coeff[Pq,x^2,Expon[Pq,x^2]]}, e*x^(2*q-3)*(a+b*x^2+c*x^4)^(p+1)/(c*(2*q+4*p+1)) + 1/(c*(2*q+4*p+1))*Integrate[(a+b*x^2+c*x^4)^p*     ExpandToSum[c*(2*q+4*p+1)*Pq-a*e*(2*q-3)*x^(2*q-4)-b*e*(2*q+2*p-1)*x^(2*q-2)-c*e*(2*q+4*p+1)*x^(2*q),x],x]] /;
FreeQ[{a,b,c,p},x] && PolyQ[Pq,x^2] && Expon[Pq,x^2]>1 && NeQ[b^2-4*a*c,0] && Not[LtQ[p,-1]]

Integrate[Pq_*Q4_^p_,x_] := With[{a=Coeff[Q4,x,0],b=Coeff[Q4,x,1],c=Coeff[Q4,x,2],d=Coeff[Q4,x,3],e=Coeff[Q4,x,4]}, Subst[Integrate[SimplifyIntegrand[ReplaceAll[Pq,xRule-d/(4*e)+x]*(a+d^4/(256*e^3)-b*d/(8*e)+(c-3*d^2/(8*e))*x^2+e*x^4)^p,x],x],x,d/(4*e)+x] /; EqQ[d^3-4*c*d*e+8*b*e^2,0] && NeQ[d,0]] /;
FreeQ[p,x] && PolyQ[Pq,x] && PolyQ[Q4,x,4] && Not[IGtQ[p,0]]

Integrate[(d_*x_)^m_*Pq_*(a_+b_*x_^2+c_*x_^4)^p_,x_] := Module[{q=Expon[Pq,x],k}, Integrate[(d*x)^m*Sum[Coeff[Pq,x,2*k]*x^(2*k),{k,0,q/2+1}]*(a+b*x^2+c*x^4)^p,x] + 1/d*Integrate[(d*x)^(m+1)*Sum[Coeff[Pq,x,2*k+1]*x^(2*k),{k,0,(q-1)/2+1}]*(a+b*x^2+c*x^4)^p,x]] /;
