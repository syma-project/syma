Integrate[(d_+e_*x_^n_)/(a_+b_*x_^n_+c_*x_^n2_),x_] := With[{q=Rt[2*d/e-b/c,2]}, e/(2*c)*Integrate[1/Simp[d/e+q*x^(n/2)+x^n,x],x] + e/(2*c)*Integrate[1/Simp[d/e-q*x^(n/2)+x^n,x],x]] /;
FreeQ[{a,b,c,d,e},x] && EqQ[n2,2*n] && NeQ[b^2-4*a*c,0] && EqQ[c*d^2-a*e^2,0] && IGtQ[n/2,0] && (GtQ[2*d/e-b/c,0] || Not[LtQ[2*d/e-b/c,0]] && EqQ[d,e*Rt[a/c,2]])

Integrate[(d_+e_*x_^n_)/(a_+b_*x_^n_+c_*x_^n2_),x_] := With[{q=Rt[b^2-4*a*c,2]}, (e/2+(2*c*d-b*e)/(2*q))*Integrate[1/(b/2-q/2+c*x^n),x] + (e/2-(2*c*d-b*e)/(2*q))*Integrate[1/(b/2+q/2+c*x^n),x]] /;
