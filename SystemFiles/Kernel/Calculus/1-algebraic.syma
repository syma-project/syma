Integrate[(a_.+b_*x_+c_*x_^2+d_*x_^3)^p_,x_] := 1/3^p*Subst[Integrate[Simp[(3*a*c-b^2)/c+c^2*x^3/b,x]^p,x],x,c/(3*d)+x] /;
