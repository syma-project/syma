Integrate[(d_+e_*x_^3)/(a_+c_*x_^6),x_] := With[{q=Rt[c/a,6]}, 1/(3*a*q^2)*Integrate[(q^2*d-e*x)/(1+q^2*x^2),x] + 1/(6*a*q^2)*Integrate[(2*q^2*d-(Sqrt[3]*q^3*d-e)*x)/(1-Sqrt[3]*q*x+q^2*x^2),x] + 1/(6*a*q^2)*Integrate[(2*q^2*d+(Sqrt[3]*q^3*d+e)*x)/(1+Sqrt[3]*q*x+q^2*x^2),x]] /;
