FreeQ[{a,b,c,d,e,f},x] && NeQ[d*e-c*f,0] && EqQ[b*e^3-2*(5+3*Sqrt[3])*a*f^3,0] && NeQ[b*c^3-2*(5-3*Sqrt[3])*a*d^3,0]

Integrate[(e_+f_*x_)/((c_+d_*x_)*Sqrt[a_+b_*x_^3]),x_] := With[{q=Simplify[(-1+Sqrt[3])*f/e]}, 4*3^(1/4)*Sqrt[2+Sqrt[3]]*f*(1-q*x)*Sqrt[(1+q*x+q^2*x^2)/(1-Sqrt[3]-q*x)^2]/ (q*Sqrt[a+b*x^3]*Sqrt[-(1-q*x)/(1-Sqrt[3]-q*x)^2])* Subst[Integrate[1/(((1+Sqrt[3])*d+c*q+((1-Sqrt[3])*d+c*q)*x)*Sqrt[1-x^2]*Sqrt[7+4*Sqrt[3]+x^2]),x],x,(1+Sqrt[3]-q*x)/(-1+Sqrt[3]+q*x)]] /;
FreeQ[{a,b,c,d,e,f},x] && NeQ[d*e-c*f,0] && EqQ[b*e^3-2*(5-3*Sqrt[3])*a*f^3,0] && NeQ[b*c^3-2*(5+3*Sqrt[3])*a*d^3,0]

Integrate[(e_.+f_*x_)/((c_+d_*x_)*Sqrt[a_+b_*x_^3]),x_] := With[{q=Rt[b/a,3]}, ((1+Sqrt[3])*f-e*q)/((1+Sqrt[3])*d-c*q)*Integrate[1/Sqrt[a+b*x^3],x] + (d*e-c*f)/((1+Sqrt[3])*d-c*q)*Integrate[(1+Sqrt[3]+q*x)/((c+d*x)*Sqrt[a+b*x^3]),x]] /;
