Integrate[(d_+e_*x_^n_)/(a_+b_*x_^n_+c_*x_^n2_),x_] := With[{q=Rt[-2*d/e-b/c,2]}, e/(2*c*q)*Integrate[(q-2*x^(n/2))/Simp[d/e+q*x^(n/2)-x^n,x],x] + e/(2*c*q)*Integrate[(q+2*x^(n/2))/Simp[d/e-q*x^(n/2)-x^n,x],x]] /;
