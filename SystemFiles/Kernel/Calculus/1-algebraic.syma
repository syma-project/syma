Integrate[1/Sqrt[a_+b_*x_^4],x_] := With[{q=Rt[-a*b,2]}, Sqrt[(a-q*x^2)/(a+q*x^2)]*Sqrt[(a+q*x^2)/q]/(Sqrt[2]*Sqrt[a+b*x^4]*Sqrt[a/(a+q*x^2)])*     EllipticF[ArcSin[x/Sqrt[(a+q*x^2)/(2*q)]],1/2]] /;
FreeQ[{a,b},x] && LtQ[a,0] && GtQ[b,0]

Integrate[1/Sqrt[a_+b_*x_^4],x_] := Sqrt[1+b*x^4/a]/Sqrt[a+b*x^4]*Integrate[1/Sqrt[1+b*x^4/a],x] /;
FreeQ[{a,b},x] && NegQ[b/a] && Not[GtQ[a,0]]

Integrate[1/Sqrt[a_+b_*x_^6],x_] := With[{r=Numer[Rt[b/a,3]], s=Denom[Rt[b/a,3]]}, x*(s+r*x^2)*Sqrt[(s^2-r*s*x^2+r^2*x^4)/(s+(1+Sqrt[3])*r*x^2)^2]/ (2*3^(1/4)*s*Sqrt[a+b*x^6]*Sqrt[r*x^2*(s+r*x^2)/(s+(1+Sqrt[3])*r*x^2)^2])* EllipticF[ArcCos[(s+(1-Sqrt[3])*r*x^2)/(s+(1+Sqrt[3])*r*x^2)],(2+Sqrt[3])/4]] /;
FreeQ[{a,b},x]

Integrate[1/Sqrt[a_+b_*x_^8],x_] := 1/2*Integrate[(1-Rt[b/a,4]*x^2)/Sqrt[a+b*x^8],x] + 1/2*Integrate[(1+Rt[b/a,4]*x^2)/Sqrt[a+b*x^8],x] /;
FreeQ[{a,b},x]

Integrate[1/(a_+b_*x_^2)^(1/4),x_] := 2*x/(a+b*x^2)^(1/4) - a*Integrate[1/(a+b*x^2)^(5/4),x] /;
FreeQ[{a,b},x] && GtQ[a,0] && PosQ[b/a]

Integrate[1/(a_+b_*x_^2)^(1/4),x_] := 2/(a^(1/4)*Rt[-b/a,2])*EllipticE[1/2*ArcSin[Rt[-b/a,2]*x],2] /;
FreeQ[{a,b},x] && GtQ[a,0] && NegQ[b/a]

Integrate[1/(a_+b_*x_^2)^(1/4),x_] := (1+b*x^2/a)^(1/4)/(a+b*x^2)^(1/4)*Integrate[1/(1+b*x^2/a)^(1/4),x] /;
FreeQ[{a,b},x] && PosQ[a]

Integrate[1/(a_+b_*x_^2)^(1/4),x_] := 2*Sqrt[-b*x^2/a]/(b*x)*Subst[Integrate[x^2/Sqrt[1-x^4/a],x],x,(a+b*x^2)^(1/4)] /;
FreeQ[{a,b},x] && NegQ[a]

Integrate[1/(a_+b_*x_^2)^(3/4),x_] := 2/(a^(3/4)*Rt[b/a,2])*EllipticF[1/2*ArcTan[Rt[b/a,2]*x],2] /;
FreeQ[{a,b},x] && GtQ[a,0] && PosQ[b/a]

Integrate[1/(a_+b_*x_^2)^(3/4),x_] := 2/(a^(3/4)*Rt[-b/a,2])*EllipticF[1/2*ArcSin[Rt[-b/a,2]*x],2] /;
FreeQ[{a,b},x] && GtQ[a,0] && NegQ[b/a]

Integrate[1/(a_+b_*x_^2)^(3/4),x_] := (1+b*x^2/a)^(3/4)/(a+b*x^2)^(3/4)*Integrate[1/(1+b*x^2/a)^(3/4),x] /;
FreeQ[{a,b},x] && PosQ[a]

Integrate[1/(a_+b_*x_^2)^(3/4),x_] := 2*Sqrt[-b*x^2/a]/(b*x)*Subst[Integrate[1/Sqrt[1-x^4/a],x],x,(a+b*x^2)^(1/4)] /;
FreeQ[{a,b},x] && NegQ[a]

Integrate[1/(a_+b_*x_^2)^(1/3),x_] := 3*Sqrt[b*x^2]/(2*b*x)*Subst[Integrate[x/Sqrt[-a+x^3],x],x,(a+b*x^2)^(1/3)] /;
FreeQ[{a,b},x]

Integrate[1/(a_+b_*x_^2)^(2/3),x_] := 3*Sqrt[b*x^2]/(2*b*x)*Subst[Integrate[1/Sqrt[-a+x^3],x],x,(a+b*x^2)^(1/3)] /;
FreeQ[{a,b},x]

Integrate[1/(a_+b_*x_^4)^(3/4),x_] := x^3*(1+a/(b*x^4))^(3/4)/(a+b*x^4)^(3/4)*Integrate[1/(x^3*(1+a/(b*x^4))^(3/4)),x] /;
FreeQ[{a,b},x]

Integrate[1/(a_+b_*x_^2)^(1/6),x_] := 3*x/(2*(a+b*x^2)^(1/6)) - a/2*Integrate[1/(a+b*x^2)^(7/6),x] /;
FreeQ[{a,b},x]

Integrate[1/(a_+b_*x_^3)^(1/3),x_] := ArcTan[(1+2*Rt[b,3]*x/(a+b*x^3)^(1/3))/Sqrt[3]]/(Sqrt[3]*Rt[b,3]) - Log[(a+b*x^3)^(1/3)-Rt[b,3]*x]/(2*Rt[b,3]) /;
FreeQ[{a,b},x]

Integrate[(a_+b_*x_^n_)^p_,x_] := a^(p+1/n)*Subst[Integrate[1/(1-b*x^n)^(p+1/n+1),x],x,x/(a+b*x^n)^(1/n)] /;
FreeQ[{a,b},x] && IGtQ[n,0] && LtQ[-1,p,0] && NeQ[p,-1/2] && IntegerQ[p+1/n]

Integrate[(a_+b_*x_^n_)^p_,x_] := (a/(a+b*x^n))^(p+1/n)*(a+b*x^n)^(p+1/n)*Subst[Integrate[1/(1-b*x^n)^(p+1/n+1),x],x,x/(a+b*x^n)^(1/n)] /;
FreeQ[{a,b},x] && IGtQ[n,0] && LtQ[-1,p,0] && NeQ[p,-1/2] && LtQ[Denominator[p+1/n],Denominator[p]]

Integrate[(a_+b_*x_^n_)^p_,x_] := -Subst[Integrate[(a+b*x^(-n))^p/x^2,x],x,1/x] /;
FreeQ[{a,b,p},x] && ILtQ[n,0]

Integrate[(a_+b_*x_^n_)^p_,x_] := With[{k=Denominator[n]}, k*Subst[Integrate[x^(k-1)*(a+b*x^(k*n))^p,x],x,x^(1/k)]] /;
FreeQ[{a,b,p},x] && FractionQ[n]

Integrate[(a_+b_*x_^n_)^p_,x_] := Integrate[ExpandIntegrand[(a+b*x^n)^p,x],x] /;
FreeQ[{a,b,n},x] && IGtQ[p,0]

Integrate[(a_+b_*x_^n_)^p_,x_] := a^p*x*Hypergeometric2F1[-p,1/n,1/n+1,-b*x^n/a] /;
FreeQ[{a,b,n,p},x] && Not[IGtQ[p,0]] && Not[IntegerQ[1/n]] && Not[ILtQ[Simplify[1/n+p],0]] && (IntegerQ[p] || GtQ[a,0]) (* Integrate[(a_+b_*x_^n_)^p_,x_] := x*(a+b*x^n)^(p+1)/a*Hypergeometric2F1[1,1/n+p+1,1/n+1,-b*x^n/a] /; FreeQ[{a,b,n,p},x] && Not[IGtQ[p,0]] && Not[IntegerQ[1/n]] && Not[ILtQ[Simplify[1/n+p],0]] && Not[IntegerQ[p] || GtQ[a,0]] *)

Integrate[(a_+b_*x_^n_)^p_,x_] := a^IntPart[p]*(a+b*x^n)^FracPart[p]/(1+b*x^n/a)^FracPart[p]*Integrate[(1+b*x^n/a)^p,x] /;
FreeQ[{a,b,n,p},x] && Not[IGtQ[p,0]] && Not[IntegerQ[1/n]] && Not[ILtQ[Simplify[1/n+p],0]] && Not[IntegerQ[p] || GtQ[a,0]]

Integrate[(a_.+b_*v_^n_)^p_,x_] := 1/Coefficient[v,x,1]*Subst[Integrate[(a+b*x^n)^p,x],x,v] /;
FreeQ[{a,b,n,p},x] && LinearQ[v,x] && NeQ[v,x]

Integrate[(a1_.+b1_*x_^n_)^p_*(a2_.+b2_*x_^n_)^p_.,x_] := Integrate[(a1*a2+b1*b2*x^(2*n))^p,x] /;
FreeQ[{a1,b1,a2,b2,n,p},x] && EqQ[a2*b1+a1*b2,0] && (IntegerQ[p] || GtQ[a1,0] && GtQ[a2,0])

Integrate[(a1_+b1_*x_^n_.)^p_*(a2_+b2_*x_^n_.)^p_.,x_] := x*(a1+b1*x^n)^p*(a2+b2*x^n)^p/(2*n*p+1) + 2*a1*a2*n*p/(2*n*p+1)*Integrate[(a1+b1*x^n)^(p-1)*(a2+b2*x^n)^(p-1),x] /;
FreeQ[{a1,b1,a2,b2},x] && EqQ[a2*b1+a1*b2,0] && IGtQ[2*n,0] && GtQ[p,0] && (IntegerQ[2*p] || Denominator[p+1/n]<Denominator[p])

Integrate[(a1_+b1_*x_^n_.)^p_*(a2_+b2_*x_^n_.)^p_,x_] := -x*(a1+b1*x^n)^(p+1)*(a2+b2*x^n)^(p+1)/(2*a1*a2*n*(p+1)) +    (2*n*(p+1)+1)/(2*a1*a2*n*(p+1))*Integrate[(a1+b1*x^n)^(p+1)*(a2+b2*x^n)^(p+1),x] /;
FreeQ[{a1,b1,a2,b2},x] && EqQ[a2*b1+a1*b2,0] && IGtQ[2*n,0] && LtQ[p,-1] && (IntegerQ[2*p] || Denominator[p+1/n]<Denominator[p])

Integrate[(a1_+b1_*x_^n_)^p_*(a2_+b2_*x_^n_)^p_,x_] := -Subst[Integrate[(a1+b1*x^(-n))^p*(a2+b2*x^(-n))^p/x^2,x],x,1/x] /;
FreeQ[{a1,b1,a2,b2,p},x] && EqQ[a2*b1+a1*b2,0] && ILtQ[2*n,0]

Integrate[(a1_+b1_*x_^n_)^p_*(a2_+b2_*x_^n_)^p_,x_] := With[{k=Denominator[2*n]}, k*Subst[Integrate[x^(k-1)*(a1+b1*x^(k*n))^p*(a2+b2*x^(k*n))^p,x],x,x^(1/k)]] /;
FreeQ[{a1,b1,a2,b2,p},x] && EqQ[a2*b1+a1*b2,0] && FractionQ[2*n]

Integrate[(a1_.+b1_*x_^n_)^p_*(a2_.+b2_*x_^n_)^p_,x_] := (a1+b1*x^n)^FracPart[p]*(a2+b2*x^n)^FracPart[p]/(a1*a2+b1*b2*x^(2*n))^FracPart[p]*Integrate[(a1*a2+b1*b2*x^(2*n))^p,x] /;
FreeQ[{a1,b1,a2,b2,n,p},x] && EqQ[a2*b1+a1*b2,0] && Not[IntegerQ[p]]

Integrate[(a_+b_*(c_*x_^q_.)^n_)^p_.,x_] := x/(c*x^q)^(1/q)*Subst[Integrate[(a+b*x^(n*q))^p,x],x,(c*x^q)^(1/q)] /;
FreeQ[{a,b,c,n,p,q},x] && IntegerQ[n*q] && NeQ[x,(c*x^q)^(1/q)]

Integrate[(a_+b_*(c_*x_^q_.)^n_)^p_.,x_] := With[{k=Denominator[n]}, Subst[Integrate[(a+b*c^n*x^(n*q))^p,x],x^(1/k),(c*x^q)^(1/k)/(c^(1/k)*(x^(1/k))^(q-1))]] /;
FreeQ[{a,b,c,p,q},x] && FractionQ[n]

Integrate[(a_+b_*(c_*x_^q_.)^n_)^p_.,x_] := Subst[Integrate[(a+b*c^n*x^(n*q))^p,x],x^(n*q),(c*x^q)^n/c^n] /;
FreeQ[{a,b,c,n,p,q},x] && Not[RationalQ[n]]

Integrate[(a_+b_*(d_*x_^q_.)^n_)^p_.,x_] := -Subst[Integrate[(a+b*(d*x^(-q))^n)^p/x^2,x],x,1/x] /;
FreeQ[{a,b,d,n,p},x] && ILtQ[q,0]

Integrate[(a_+b_*(d_*x_^q_.)^n_)^p_.,x_] := With[{s=Denominator[q]}, s*Subst[Integrate[x^(s-1)*(a+b*(d*x^(q*s))^n)^p,x],x,x^(1/s)]] /;
FreeQ[{a,b,d,n,p},x] && FractionQ[q] (* Integrate[(a_+b_*(d_*x_^q_.)^n_)^p_.,x_] := Subst[Integrate[(a+b*x^(n*q))^p,x],x^(n*q),(d*x^q)^n] /; FreeQ[{a,b,d,n,p,q},x] && Not[IntegerQ[n*q]] && NeQ[x^(n*q),(d*x^q)^n] *)

Integrate[(c_*x_)^m_*(a1_+b1_*x_^n_)^p_*(a2_+b2_*x_^n_)^p_,x_] := Integrate[(c*x)^m*(a1*a2+b1*b2*x^(2*n))^p,x] /;
FreeQ[{a1,b1,a2,b2,c,m,n,p},x] && EqQ[a2*b1+a1*b2,0] && (IntegerQ[p] || GtQ[a1,0] && GtQ[a2,0])

Integrate[x_^m_./(a_+b_*x_^n_),x_] := Log[RemoveContent[a+b*x^n,x]]/(b*n) /;
FreeQ[{a,b,m,n},x] && EqQ[m,n-1]

Integrate[x_^m_*(a_+b_*x_^n_)^p_,x_] := (a+b*x^n)^(p+1)/(b*n*(p+1)) /;
FreeQ[{a,b,m,n,p},x] && EqQ[m,n-1] && NeQ[p,-1]

Integrate[x_^m_*(a1_+b1_*x_^n_.)^p_*(a2_+b2_*x_^n_.)^p_,x_] := (a1+b1*x^n)^(p+1)*(a2+b2*x^n)^(p+1)/(2*b1*b2*n*(p+1)) /;
FreeQ[{a1,b1,a2,b2,m,n,p},x] && EqQ[a2*b1+a1*b2,0] && EqQ[m,2*n-1] && NeQ[p,-1]

Integrate[x_^m_*(a_+b_*x_^n_)^p_,x_] := Integrate[x^(m+n*p)*(b+a*x^(-n))^p,x] /;
FreeQ[{a,b,m,n},x] && IntegerQ[p] && NegQ[n]

Integrate[(c_*x_)^m_*(a_+b_*x_^n_)^p_,x_] := (c*x)^(m+1)*(a+b*x^n)^(p+1)/(a*c*(m+1)) /;
FreeQ[{a,b,c,m,n,p},x] && EqQ[(m+1)/n+p+1,0] && NeQ[m,-1]

Integrate[(c_*x_)^m_*(a1_+b1_*x_^n_)^p_*(a2_+b2_*x_^n_)^p_,x_] := (c*x)^(m+1)*(a1+b1*x^n)^(p+1)*(a2+b2*x^n)^(p+1)/(a1*a2*c*(m+1)) /;
FreeQ[{a1,b1,a2,b2,c,m,n,p},x] && EqQ[a2*b1+a1*b2,0] && EqQ[(m+1)/(2*n)+p+1,0] && NeQ[m,-1]

Integrate[x_^m_*(a_+b_*x_^n_)^p_,x_] := 1/n*Subst[Integrate[x^(Simplify[(m+1)/n]-1)*(a+b*x)^p,x],x,x^n] /;
FreeQ[{a,b,m,n,p},x] && IntegerQ[Simplify[(m+1)/n]]

Integrate[x_^m_*(a1_+b1_*x_^n_)^p_*(a2_+b2_*x_^n_)^p_,x_] := 1/n*Subst[Integrate[x^(Simplify[(m+1)/n]-1)*(a1+b1*x)^p*(a2+b2*x)^p,x],x,x^n] /;
FreeQ[{a1,b1,a2,b2,m,n,p},x] && EqQ[a2*b1+a1*b2,0] && IntegerQ[Simplify[(m+1)/(2*n)]]

Integrate[(c_*x_)^m_*(a_+b_*x_^n_)^p_,x_] := c^IntPart[m]*(c*x)^FracPart[m]/x^FracPart[m]*Integrate[x^m*(a+b*x^n)^p,x] /;
FreeQ[{a,b,c,m,n,p},x] && IntegerQ[Simplify[(m+1)/n]]

Integrate[(c_*x_)^m_*(a1_+b1_*x_^n_)^p_*(a2_+b2_*x_^n_)^p_,x_] := c^IntPart[m]*(c*x)^FracPart[m]/x^FracPart[m]*Integrate[x^m*(a1+b1*x^n)^p*(a2+b2*x^n)^p,x] /;
FreeQ[{a1,b1,a2,b2,c,m,n,p},x] && EqQ[a2*b1+a1*b2,0] && IntegerQ[Simplify[(m+1)/(2*n)]]

Integrate[(c_*x_)^m_*(a_+b_*x_^n_)^p_.,x_] := Integrate[ExpandIntegrand[(c*x)^m*(a+b*x^n)^p,x],x] /;
FreeQ[{a,b,c,m,n},x] && IGtQ[p,0]

Integrate[x_^m_*(a_+b_*x_^n_)^p_,x_] := x^(m+1)*(a+b*x^n)^(p+1)/(a*(m+1)) - b*(m+n*(p+1)+1)/(a*(m+1))*Integrate[x^(m+n)*(a+b*x^n)^p,x] /;
FreeQ[{a,b,m,n,p},x] && ILtQ[Simplify[(m+1)/n+p+1],0] && NeQ[m,-1]

Integrate[x_^m_*(a1_+b1_*x_^n_)^p_*(a2_+b2_*x_^n_)^p_,x_] := x^(m+1)*(a1+b1*x^n)^(p+1)*(a2+b2*x^n)^(p+1)/(a1*a2*(m+1)) - b1*b2*(m+2*n*(p+1)+1)/(a1*a2*(m+1))*Integrate[x^(m+2*n)*(a1+b1*x^n)^p*(a2+b2*x^n)^p,x] /;
FreeQ[{a1,b1,a2,b2,m,n,p},x] && EqQ[a2*b1+a1*b2,0] && ILtQ[Simplify[(m+1)/(2*n)+p+1],0] && NeQ[m,-1]

Integrate[(c_*x_)^m_*(a_+b_*x_^n_)^p_,x_] := -(c*x)^(m+1)*(a+b*x^n)^(p+1)/(a*c*n*(p+1)) + (m+n*(p+1)+1)/(a*n*(p+1))*Integrate[(c*x)^m*(a+b*x^n)^(p+1),x] /;
FreeQ[{a,b,c,m,n,p},x] && ILtQ[Simplify[(m+1)/n+p+1],0] && NeQ[p,-1]

Integrate[(c_*x_)^m_*(a1_+b1_*x_^n_)^p_*(a2_+b2_*x_^n_)^p_,x_] := -(c*x)^(m+1)*(a1+b1*x^n)^(p+1)*(a2+b2*x^n)^(p+1)/(2*a1*a2*c*n*(p+1)) + (m+2*n*(p+1)+1)/(2*a1*a2*n*(p+1))*Integrate[(c*x)^m*(a1+b1*x^n)^(p+1)*(a2+b2*x^n)^(p+1),x] /;
FreeQ[{a1,b1,a2,b2,c,m,n,p},x] && EqQ[a2*b1+a1*b2,0] && ILtQ[Simplify[(m+1)/(2*n)+p+1],0] && NeQ[p,-1]

Integrate[x_^m_*(a_+b_*x_^n_)^p_,x_] := With[{k=GCD[m+1,n]}, 1/k*Subst[Integrate[x^((m+1)/k-1)*(a+b*x^(n/k))^p,x],x,x^k] /; kNotEqual1] /;
FreeQ[{a,b,p},x] && IGtQ[n,0] && IntegerQ[m]

Integrate[x_^m_*(a1_+b1_*x_^n_)^p_*(a2_+b2_*x_^n_)^p_,x_] := With[{k=GCD[m+1,2*n]}, 1/k*Subst[Integrate[x^((m+1)/k-1)*(a1+b1*x^(n/k))^p*(a2+b2*x^(n/k))^p,x],x,x^k] /; kNotEqual1] /;
FreeQ[{a1,b1,a2,b2,p},x] && EqQ[a2*b1+a1*b2,0] && IGtQ[2*n,0] && IntegerQ[m]

Integrate[(c_*x_)^m_*(a_+b_*x_^n_)^p_,x_] := (c*x)^(m+1)*(a+b*x^n)^p/(c*(m+1)) - b*n*p/(c^n*(m+1))*Integrate[(c*x)^(m+n)*(a+b*x^n)^(p-1),x] /;
FreeQ[{a,b,c},x] && IGtQ[n,0] && GtQ[p,0] && LtQ[m,-1] && Not[ILtQ[(m+n*p+n+1)/n,0]] && IntBinomialQ[a,b,c,n,m,p,x]

Integrate[(c_*x_)^m_*(a1_+b1_*x_^n_)^p_*(a2_+b2_*x_^n_)^p_,x_] := (c*x)^(m+1)*(a1+b1*x^n)^p*(a2+b2*x^n)^p/(c*(m+1)) - 2*b1*b2*n*p/(c^(2*n)*(m+1))*Integrate[(c*x)^(m+2*n)*(a1+b1*x^n)^(p-1)*(a2+b2*x^n)^(p-1),x] /;
FreeQ[{a1,b1,a2,b2,c,m},x] && EqQ[a2*b1+a1*b2,0] && IGtQ[2*n,0] && GtQ[p,0] && LtQ[m,-1] && NeQ[m+2*n*p+1,0] && IntBinomialQ[a1*a2,b1*b2,c,2*n,m,p,x]

Integrate[(c_*x_)^m_*(a_+b_*x_^n_)^p_,x_] := (c*x)^(m+1)*(a+b*x^n)^p/(c*(m+n*p+1)) + a*n*p/(m+n*p+1)*Integrate[(c*x)^m*(a+b*x^n)^(p-1),x] /;
FreeQ[{a,b,c,m},x] && IGtQ[n,0] && GtQ[p,0] && NeQ[m+n*p+1,0] && IntBinomialQ[a,b,c,n,m,p,x]

Integrate[(c_*x_)^m_*(a1_+b1_*x_^n_)^p_*(a2_+b2_*x_^n_)^p_,x_] := (c*x)^(m+1)*(a1+b1*x^n)^p*(a2+b2*x^n)^p/(c*(m+2*n*p+1)) + 2*a1*a2*n*p/(m+2*n*p+1)*Integrate[(c*x)^m*(a1+b1*x^n)^(p-1)*(a2+b2*x^n)^(p-1),x] /;
FreeQ[{a1,b1,a2,b2,c,m},x] && EqQ[a2*b1+a1*b2,0] && IGtQ[2*n,0] && GtQ[p,0] && NeQ[m+2*n*p+1,0] && IntBinomialQ[a1*a2,b1*b2,c,2*n,m,p,x]

