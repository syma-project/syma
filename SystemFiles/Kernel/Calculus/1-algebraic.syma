Integrate[(a_.+b_*x_+d_*x_^3)^p_,x_] := With[{r=Rt[-9*a*d^2+Sqrt[3]*d*Sqrt[4*b^3*d+27*a^2*d^2],3]}, 1/d^(2*p)*Integrate[Simp[18^(1/3)*b*d/(3*r)-r/18^(1/3)+d*x,x]^p* Simp[b*d/3+12^(1/3)*b^2*d^2/(3*r^2)+r^2/(3*12^(1/3))-d*(2^(1/3)*b*d/(3^(1/3)*r)-r/18^(1/3))*x+d^2*x^2,x]^p,x]] /;
FreeQ[{a,b,d},x] && NeQ[4*b^3+27*a^2*d,0] && IntegerQ[p]

Integrate[(a_.+b_*x_+d_*x_^3)^p_,x_] := With[{r=Rt[-9*a*d^2+Sqrt[3]*d*Sqrt[4*b^3*d+27*a^2*d^2],3]}, (a+b*x+d*x^3)^p/ (Simp[18^(1/3)*b*d/(3*r)-r/18^(1/3)+d*x,x]^p* Simp[b*d/3+12^(1/3)*b^2*d^2/(3*r^2)+r^2/(3*12^(1/3))-d*(2^(1/3)*b*d/(3^(1/3)*r)-r/18^(1/3))*x+d^2*x^2,x]^p)* Integrate[Simp[18^(1/3)*b*d/(3*r)-r/18^(1/3)+d*x,x]^p* Simp[b*d/3+12^(1/3)*b^2*d^2/(3*r^2)+r^2/(3*12^(1/3))-d*(2^(1/3)*b*d/(3^(1/3)*r)-r/18^(1/3))*x+d^2*x^2,x]^p,x]] /;
