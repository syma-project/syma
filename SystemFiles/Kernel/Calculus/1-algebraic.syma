Integrate[(a_+c_*x_^2)^p_*(d_+e_*x_+f_*x_^2)^q_*(g_.+h_*x_),x_] := (a*h-g*c*x)*(a+c*x^2)^(p+1)*(d+e*x+f*x^2)^q/(2*a*c*(p+1)) +    2/(4*a*c*(p+1))* Integrate[(a+c*x^2)^(p+1)*(d+e*x+f*x^2)^(q-1)* Simp[g*c*d*(2*p+3)-a*(h*e*q)+(g*c*e*(2*p+q+3)-a*(2*h*f*q))*x+g*c*f*(2*p+2*q+3)*x^2,x],x] /;
FreeQ[{a,c,d,e,f,g,h},x] && NeQ[e^2-4*d*f,0] && LtQ[p,-1] && GtQ[q,0]

