Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_,x_] := -x*(a+b*x^n)^(p+1)*(c+d*x^n)^q/(a*n*(p+1)) + 1/(a*n*(p+1))*Integrate[(a+b*x^n)^(p+1)*(c+d*x^n)^(q-1)*Simp[c*(n*(p+1)+1)+d*(n*(p+q+1)+1)*x^n,x],x] /;
FreeQ[{a,b,c,d,n},x] && NeQ[b*c-a*d,0] && LtQ[p,-1] && LtQ[0,q,1] && IntBinomialQ[a,b,c,d,n,p,q,x]

