Integrate[Pq_*(a_+b_*x_^n_.)^p_,x_] := Module[{q=Expon[Pq,x],i}, (a+b*x^n)^p*Sum[Coeff[Pq,x,i]*x^(i+1)/(n*p+i+1),{i,0,q}] +    a*n*p*Integrate[(a+b*x^n)^(p-1)*Sum[Coeff[Pq,x,i]*x^i/(n*p+i+1),{i,0,q}],x]] /;
FreeQ[{a,b},x] && PolyQ[Pq,x] && IGtQ[(n-1)/2,0] && GtQ[p,0]

Integrate[Pq_*(a_+b_*x_^n_)^p_,x_] := Module[{q=Expon[Pq,x],i}, (a*Coeff[Pq,x,q]-b*x*ExpandToSum[Pq-Coeff[Pq,x,q]*x^q,x])*(a+b*x^n)^(p+1)/(a*b*n*(p+1)) + 1/(a*n*(p+1))*Integrate[Sum[(n*(p+1)+i+1)*Coeff[Pq,x,i]*x^i,{i,0,q-1}]*(a+b*x^n)^(p+1),x] /; qEqualn-1] /;
FreeQ[{a,b},x] && PolyQ[Pq,x] && IGtQ[n,0] && LtQ[p,-1]

Integrate[Pq_*(a_+b_*x_^n_.)^p_,x_] := -x*Pq*(a+b*x^n)^(p+1)/(a*n*(p+1)) +    1/(a*n*(p+1))*Integrate[ExpandToSum[n*(p+1)*Pq+D[x*Pq,x],x]*(a+b*x^n)^(p+1),x] /;
FreeQ[{a,b},x] && PolyQ[Pq,x] && IGtQ[n,0] && LtQ[p,-1] && LtQ[Expon[Pq,x],n-1]

Integrate[P4_/(a_+b_*x_^4)^(3/2),x_] := With[{d=Coeff[P4,x,0],e=Coeff[P4,x,1],f=Coeff[P4,x,3],g=Coeff[P4,x,4]}, -(a*f+2*a*g*x-b*e*x^2)/(2*a*b*Sqrt[a+b*x^4]) /; EqQ[b*d+a*g,0]] /;
FreeQ[{a,b},x] && PolyQ[P4,x,4] && EqQ[Coeff[P4,x,2],0]

Integrate[P6_/(a_+b_*x_^4)^(3/2),x_] := With[{d=Coeff[P6,x,0],e=Coeff[P6,x,2],f=Coeff[P6,x,3],g=Coeff[P6,x,4],h=Coeff[P6,x,6]}, -(a*f-2*b*d*x-2*a*h*x^3)/(2*a*b*Sqrt[a+b*x^4]) /; EqQ[b*e-3*a*h,0] && EqQ[b*d+a*g,0]] /;
FreeQ[{a,b},x] && PolyQ[P6,x,6] && EqQ[Coeff[P6,x,1],0] && EqQ[Coeff[P6,x,5],0]

Integrate[Pq_*(a_+b_*x_^n_.)^p_,x_] := With[{q=Expon[Pq,x]}, Module[{Q=PolynomialQuotient[b^(Floor[(q-1)/n]+1)*Pq,a+b*x^n,x], R=PolynomialRemainder[b^(Floor[(q-1)/n]+1)*Pq,a+b*x^n,x]}, -x*R*(a+b*x^n)^(p+1)/(a*n*(p+1)*b^(Floor[(q-1)/n]+1)) +    1/(a*n*(p+1)*b^(Floor[(q-1)/n]+1))*Integrate[(a+b*x^n)^(p+1)*ExpandToSum[a*n*(p+1)*Q+n*(p+1)*R+D[x*R,x],x],x]] /; GeQ[q,n]] /;
FreeQ[{a,b},x] && PolyQ[Pq,x] && IGtQ[n,0] && LtQ[p,-1]

Integrate[(A_+B_*x_)/(a_+b_*x_^3),x_] := B^3/b*Integrate[1/(A^2-A*B*x+B^2*x^2),x] /;
FreeQ[{a,b,A,B},x] && EqQ[a*B^3-b*A^3,0]

Integrate[(A_+B_*x_)/(a_+b_*x_^3),x_] := With[{r=Numerator[Rt[a/b,3]], s=Denominator[Rt[a/b,3]]}, -r*(B*r-A*s)/(3*a*s)*Integrate[1/(r+s*x),x] + r/(3*a*s)*Integrate[(r*(B*r+2*A*s)+s*(B*r-A*s)*x)/(r^2-r*s*x+s^2*x^2),x]] /;
FreeQ[{a,b,A,B},x] && NeQ[a*B^3-b*A^3,0] && PosQ[a/b]

Integrate[(A_+B_*x_)/(a_+b_*x_^3),x_] := With[{r=Numerator[Rt[-a/b,3]], s=Denominator[Rt[-a/b,3]]}, r*(B*r+A*s)/(3*a*s)*Integrate[1/(r-s*x),x] - r/(3*a*s)*Integrate[(r*(B*r-2*A*s)-s*(B*r+A*s)*x)/(r^2+r*s*x+s^2*x^2),x]] /;
FreeQ[{a,b,A,B},x] && NeQ[a*B^3-b*A^3,0] && NegQ[a/b]

Integrate[P2_/(a_+b_*x_^3),x_] := With[{A=Coeff[P2,x,0],B=Coeff[P2,x,1],C=Coeff[P2,x,2]}, -C^2/b*Integrate[1/(B-C*x),x] /; EqQ[B^2-A*C,0] && EqQ[b*B^3+a*C^3,0]] /;
FreeQ[{a,b},x] && PolyQ[P2,x,2]

Integrate[P2_/(a_+b_*x_^3),x_] := With[{A=Coeff[P2,x,0],B=Coeff[P2,x,1],C=Coeff[P2,x,2]}, With[{q=a^(1/3)/b^(1/3)}, C/b*Integrate[1/(q+x),x] + (B+C*q)/b*Integrate[1/(q^2-q*x+x^2),x]] /; EqQ[A*b^(2/3)-a^(1/3)*b^(1/3)*B-2*a^(2/3)*C,0]] /;
FreeQ[{a,b},x] && PolyQ[P2,x,2]

Integrate[P2_/(a_+b_*x_^3),x_] := With[{A=Coeff[P2,x,0],B=Coeff[P2,x,1],C=Coeff[P2,x,2]}, With[{q=(-a)^(1/3)/(-b)^(1/3)}, C/b*Integrate[1/(q+x),x] + (B+C*q)/b*Integrate[1/(q^2-q*x+x^2),x]] /; EqQ[A*(-b)^(2/3)-(-a)^(1/3)*(-b)^(1/3)*B-2*(-a)^(2/3)*C,0]] /;
FreeQ[{a,b},x] && PolyQ[P2,x,2]

Integrate[P2_/(a_+b_*x_^3),x_] := With[{A=Coeff[P2,x,0],B=Coeff[P2,x,1],C=Coeff[P2,x,2]}, With[{q=(-a)^(1/3)/b^(1/3)}, -C/b*Integrate[1/(q-x),x] + (B-C*q)/b*Integrate[1/(q^2+q*x+x^2),x]] /; EqQ[A*b^(2/3)+(-a)^(1/3)*b^(1/3)*B-2*(-a)^(2/3)*C,0]] /;
FreeQ[{a,b},x] && PolyQ[P2,x,2]

Integrate[P2_/(a_+b_*x_^3),x_] := With[{A=Coeff[P2,x,0],B=Coeff[P2,x,1],C=Coeff[P2,x,2]}, With[{q=a^(1/3)/(-b)^(1/3)}, -C/b*Integrate[1/(q-x),x] + (B-C*q)/b*Integrate[1/(q^2+q*x+x^2),x]] /; EqQ[A*(-b)^(2/3)+a^(1/3)*(-b)^(1/3)*B-2*a^(2/3)*C,0]] /;
FreeQ[{a,b},x] && PolyQ[P2,x,2]

Integrate[P2_/(a_+b_*x_^3),x_] := With[{A=Coeff[P2,x,0],B=Coeff[P2,x,1],C=Coeff[P2,x,2]}, With[{q=(a/b)^(1/3)}, C/b*Integrate[1/(q+x),x] + (B+C*q)/b*Integrate[1/(q^2-q*x+x^2),x]] /; EqQ[A-(a/b)^(1/3)*B-2*(a/b)^(2/3)*C,0]] /;
FreeQ[{a,b},x] && PolyQ[P2,x,2]

Integrate[P2_/(a_+b_*x_^3),x_] := With[{A=Coeff[P2,x,0],B=Coeff[P2,x,1],C=Coeff[P2,x,2]}, With[{q=Rt[a/b,3]}, C/b*Integrate[1/(q+x),x] + (B+C*q)/b*Integrate[1/(q^2-q*x+x^2),x]] /; EqQ[A-Rt[a/b,3]*B-2*Rt[a/b,3]^2*C,0]] /;
FreeQ[{a,b},x] && PolyQ[P2,x,2]

Integrate[P2_/(a_+b_*x_^3),x_] := With[{A=Coeff[P2,x,0],B=Coeff[P2,x,1],C=Coeff[P2,x,2]}, With[{q=(-a/b)^(1/3)}, -C/b*Integrate[1/(q-x),x] + (B-C*q)/b*Integrate[1/(q^2+q*x+x^2),x]] /; EqQ[A+(-a/b)^(1/3)*B-2*(-a/b)^(2/3)*C,0]] /;
FreeQ[{a,b},x] && PolyQ[P2,x,2]

Integrate[P2_/(a_+b_*x_^3),x_] := With[{A=Coeff[P2,x,0],B=Coeff[P2,x,1],C=Coeff[P2,x,2]}, With[{q=Rt[-a/b,3]}, -C/b*Integrate[1/(q-x),x] + (B-C*q)/b*Integrate[1/(q^2+q*x+x^2),x]] /; EqQ[A+Rt[-a/b,3]*B-2*Rt[-a/b,3]^2*C,0]] /;
FreeQ[{a,b},x] && PolyQ[P2,x,2]

Integrate[P2_/(a_+b_*x_^3),x_] := With[{A=Coeff[P2,x,0],B=Coeff[P2,x,1],C=Coeff[P2,x,2]}, Integrate[(A+B*x)/(a+b*x^3),x] + C*Integrate[x^2/(a+b*x^3),x] /; EqQ[a*B^3-b*A^3,0] || Not[RationalQ[a/b]]] /;
FreeQ[{a,b},x] && PolyQ[P2,x,2]

Integrate[P2_/(a_+b_*x_^3),x_] := With[{A=Coeff[P2,x,0],B=Coeff[P2,x,1],C=Coeff[P2,x,2]}, With[{q=(a/b)^(1/3)}, q^2/a*Integrate[(A+C*q*x)/(q^2-q*x+x^2),x]] /; EqQ[A-B*(a/b)^(1/3)+C*(a/b)^(2/3),0]] /;
FreeQ[{a,b},x] && PolyQ[P2,x,2]

Integrate[P2_/(a_+b_*x_^3),x_] := With[{A=Coeff[P2,x,0],B=Coeff[P2,x,1],C=Coeff[P2,x,2]}, With[{q=(-a/b)^(1/3)}, q/a*Integrate[(A*q+(A+B*q)*x)/(q^2+q*x+x^2),x]] /; EqQ[A+B*(-a/b)^(1/3)+C*(-a/b)^(2/3),0]] /;
FreeQ[{a,b},x] && PolyQ[P2,x,2]

Integrate[P2_/(a_+b_*x_^3),x_] := With[{A=Coeff[P2,x,0],B=Coeff[P2,x,1],C=Coeff[P2,x,2],q=(a/b)^(1/3)}, q*(A-B*q+C*q^2)/(3*a)*Integrate[1/(q+x),x] + q/(3*a)*Integrate[(q*(2*A+B*q-C*q^2)-(A-B*q-2*C*q^2)*x)/(q^2-q*x+x^2),x] /; NeQ[a*B^3-b*A^3,0] && NeQ[A-B*q+C*q^2,0]] /;
FreeQ[{a,b},x] && PolyQ[P2,x,2] && GtQ[a/b,0]

Integrate[P2_/(a_+b_*x_^3),x_] := With[{A=Coeff[P2,x,0],B=Coeff[P2,x,1],C=Coeff[P2,x,2],q=(-a/b)^(1/3)}, q*(A+B*q+C*q^2)/(3*a)*Integrate[1/(q-x),x] + q/(3*a)*Integrate[(q*(2*A-B*q-C*q^2)+(A+B*q-2*C*q^2)*x)/(q^2+q*x+x^2),x] /; NeQ[a*B^3-b*A^3,0] && NeQ[A+B*q+C*q^2,0]] /;
FreeQ[{a,b},x] && PolyQ[P2,x,2] && LtQ[a/b,0]

Integrate[Pq_/(a_+b_*x_^n_),x_] := With[{v=Sum[x^ii*(Coeff[Pq,x,ii]+Coeff[Pq,x,n/2+ii]*x^(n/2))/(a+b*x^n),{ii,0,n/2-1}]}, Integrate[v,x] /; SumQ[v]] /;
FreeQ[{a,b},x] && PolyQ[Pq,x] && IGtQ[n/2,0] && Expon[Pq,x]<n

Integrate[(c_+d_*x_)/Sqrt[a_+b_*x_^3],x_] := With[{r=Numer[Simplify[(1-Sqrt[3])*d/c]], s=Denom[Simplify[(1-Sqrt[3])*d/c]]}, 2*d*s^3*Sqrt[a+b*x^3]/(a*r^2*((1+Sqrt[3])*s+r*x)) - 3^(1/4)*Sqrt[2-Sqrt[3]]*d*s*(s+r*x)*Sqrt[(s^2-r*s*x+r^2*x^2)/((1+Sqrt[3])*s+r*x)^2]/ (r^2*Sqrt[a+b*x^3]*Sqrt[s*(s+r*x)/((1+Sqrt[3])*s+r*x)^2])* EllipticE[ArcSin[((1-Sqrt[3])*s+r*x)/((1+Sqrt[3])*s+r*x)],-7-4*Sqrt[3]]] /;
FreeQ[{a,b,c,d},x] && PosQ[a] && EqQ[b*c^3-2*(5-3*Sqrt[3])*a*d^3,0]

Integrate[(c_+d_*x_)/Sqrt[a_+b_*x_^3],x_] := With[{r=Numer[Rt[b/a,3]], s=Denom[Rt[b/a,3]]}, (c*r-(1-Sqrt[3])*d*s)/r*Integrate[1/Sqrt[a+b*x^3],x] + d/r*Integrate[((1-Sqrt[3])*s+r*x)/Sqrt[a+b*x^3],x]] /;
FreeQ[{a,b,c,d},x] && PosQ[a] && NeQ[b*c^3-2*(5-3*Sqrt[3])*a*d^3,0]

Integrate[(c_+d_*x_)/Sqrt[a_+b_*x_^3],x_] := With[{r=Numer[Simplify[(1+Sqrt[3])*d/c]], s=Denom[Simplify[(1+Sqrt[3])*d/c]]}, 2*d*s^3*Sqrt[a+b*x^3]/(a*r^2*((1-Sqrt[3])*s+r*x)) + 3^(1/4)*Sqrt[2+Sqrt[3]]*d*s*(s+r*x)*Sqrt[(s^2-r*s*x+r^2*x^2)/((1-Sqrt[3])*s+r*x)^2]/ (r^2*Sqrt[a+b*x^3]*Sqrt[-s*(s+r*x)/((1-Sqrt[3])*s+r*x)^2])* EllipticE[ArcSin[((1+Sqrt[3])*s+r*x)/((1-Sqrt[3])*s+r*x)],-7+4*Sqrt[3]]] /;
FreeQ[{a,b,c,d},x] && NegQ[a] && EqQ[b*c^3-2*(5+3*Sqrt[3])*a*d^3,0]

Integrate[(c_+d_*x_)/Sqrt[a_+b_*x_^3],x_] := With[{r=Numer[Rt[b/a,3]], s=Denom[Rt[b/a,3]]}, (c*r-(1+Sqrt[3])*d*s)/r*Integrate[1/Sqrt[a+b*x^3],x] + d/r*Integrate[((1+Sqrt[3])*s+r*x)/Sqrt[a+b*x^3],x]] /;
FreeQ[{a,b,c,d},x] && NegQ[a] && NeQ[b*c^3-2*(5+3*Sqrt[3])*a*d^3,0]

Integrate[(c_+d_*x_^4)/Sqrt[a_+b_*x_^6],x_] := With[{r=Numer[Rt[b/a,3]], s=Denom[Rt[b/a,3]]}, (1+Sqrt[3])*d*s^3*x*Sqrt[a+b*x^6]/(2*a*r^2*(s+(1+Sqrt[3])*r*x^2)) - 3^(1/4)*d*s*x*(s+r*x^2)*Sqrt[(s^2-r*s*x^2+r^2*x^4)/(s+(1+Sqrt[3])*r*x^2)^2]/ (2*r^2*Sqrt[(r*x^2*(s+r*x^2))/(s+(1+Sqrt[3])*r*x^2)^2]*Sqrt[a+b*x^6])* EllipticE[ArcCos[(s+(1-Sqrt[3])*r*x^2)/(s+(1+Sqrt[3])*r*x^2)],(2+Sqrt[3])/4]] /;
FreeQ[{a,b,c,d},x] && EqQ[2*Rt[b/a,3]^2*c-(1-Sqrt[3])*d,0]

Integrate[(c_+d_*x_^4)/Sqrt[a_+b_*x_^6],x_] := With[{q=Rt[b/a,3]}, (2*c*q^2-(1-Sqrt[3])*d)/(2*q^2)*Integrate[1/Sqrt[a+b*x^6],x] + d/(2*q^2)*Integrate[(1-Sqrt[3]+2*q^2*x^4)/Sqrt[a+b*x^6],x]] /;
FreeQ[{a,b,c,d},x] && NeQ[2*Rt[b/a,3]^2*c-(1-Sqrt[3])*d,0]

Integrate[(c_+d_*x_^2)/Sqrt[a_+b_*x_^8],x_] := -c*d*x^3*Sqrt[-(c-d*x^2)^2/(c*d*x^2)]*Sqrt[-d^2*(a+b*x^8)/(b*c^2*x^4)]/(Sqrt[2+Sqrt[2]]*(c-d*x^2)*Sqrt[a+b*x^8])* EllipticF[ArcSin[1/2*Sqrt[(Sqrt[2]*c^2+2*c*d*x^2+Sqrt[2]*d^2*x^4)/(c*d*x^2)]],-2*(1-Sqrt[2])] /;
FreeQ[{a,b,c,d},x] && EqQ[b*c^4-a*d^4,0]

Integrate[(c_+d_*x_^2)/Sqrt[a_+b_*x_^8],x_] := (d+Rt[b/a,4]*c)/(2*Rt[b/a,4])*Integrate[(1+Rt[b/a,4]*x^2)/Sqrt[a+b*x^8],x] - (d-Rt[b/a,4]*c)/(2*Rt[b/a,4])*Integrate[(1-Rt[b/a,4]*x^2)/Sqrt[a+b*x^8],x] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c^4-a*d^4,0]

Integrate[Pq_/(x_*Sqrt[a_+b_*x_^n_]),x_] := Coeff[Pq,x,0]*Integrate[1/(x*Sqrt[a+b*x^n]),x] + Integrate[ExpandToSum[(Pq-Coeff[Pq,x,0])/x,x]/Sqrt[a+b*x^n],x] /;
FreeQ[{a,b},x] && PolyQ[Pq,x] && IGtQ[n,0] && NeQ[Coeff[Pq,x,0],0]

Integrate[Pq_*(a_+b_*x_^n_)^p_,x_] := Module[{q=Expon[Pq,x],j,k}, Integrate[Sum[x^j*Sum[Coeff[Pq,x,j+k*n/2]*x^(k*n/2),{k,0,2*(q-j)/n+1}]*(a+b*x^n)^p,{j,0,n/2-1}],x]] /;
FreeQ[{a,b,p},x] && PolyQ[Pq,x] && IGtQ[n/2,0] && Not[PolyQ[Pq,x^(n/2)]]

Integrate[Pq_*(a_+b_*x_^n_)^p_,x_] := Coeff[Pq,x,n-1]*Integrate[x^(n-1)*(a+b*x^n)^p,x] + Integrate[ExpandToSum[Pq-Coeff[Pq,x,n-1]*x^(n-1),x]*(a+b*x^n)^p,x] /;
FreeQ[{a,b,p},x] && PolyQ[Pq,x] && IGtQ[n,0] && Expon[Pq,x]Equaln-1

Integrate[Pq_/(a_+b_*x_^n_),x_] := Integrate[ExpandIntegrand[Pq/(a+b*x^n),x],x] /;
FreeQ[{a,b},x] && PolyQ[Pq,x] && IntegerQ[n]

Integrate[Pq_*(a_+b_*x_^n_)^p_,x_] := With[{q=Expon[Pq,x]}, With[{Pqq=Coeff[Pq,x,q]}, Pqq*x^(q-n+1)*(a+b*x^n)^(p+1)/(b*(q+n*p+1)) + 1/(b*(q+n*p+1))*Integrate[ExpandToSum[b*(q+n*p+1)*(Pq-Pqq*x^q)-a*Pqq*(q-n+1)*x^(q-n),x]*(a+b*x^n)^p,x]] /; NeQ[q+n*p+1,0] && q-nGreaterEqual0 && (IntegerQ[2*p] || IntegerQ[p+(q+1)/(2*n)])] /;
FreeQ[{a,b,p},x] && PolyQ[Pq,x] && IGtQ[n,0]

Integrate[Pq_*(a_+b_*x_^n_)^p_,x_] := With[{q=Expon[Pq,x]}, -Subst[Integrate[ExpandToSum[x^q*ReplaceAll[Pq,xRulex^(-1)],x]*(a+b*x^(-n))^p/x^(q+2),x],x,1/x]] /;
FreeQ[{a,b,p},x] && PolyQ[Pq,x] && ILtQ[n,0]

Integrate[Pq_*(a_+b_*x_^n_)^p_,x_] := With[{g=Denominator[n]}, g*Subst[Integrate[x^(g-1)*ReplaceAll[Pq,xRulex^g]*(a+b*x^(g*n))^p,x],x,x^(1/g)]] /;
FreeQ[{a,b,p},x] && PolyQ[Pq,x] && FractionQ[n]

Integrate[(A_+B_*x_^m_.)*(a_+b_*x_^n_)^p_.,x_] := A*Integrate[(a+b*x^n)^p,x] + B*Integrate[x^m*(a+b*x^n)^p,x] /;
FreeQ[{a,b,A,B,m,n,p},x] && EqQ[m-n+1,0]

Integrate[P3_*(a_+b_*x_^n_)^p_,x_] := With[{A=Coeff[P3,x^(n/2),0],B=Coeff[P3,x^(n/2),1],C=Coeff[P3,x^(n/2),2],D=Coeff[P3,x^(n/2),3]}, -(x*(b*A-a*C+(b*B-a*D)*x^(n/2))*(a+b*x^n)^(p+1))/(a*b*n*(p+1)) - 1/(2*a*b*n*(p+1))*Integrate[(a+b*x^n)^(p+1)*Simp[2*a*C-2*b*A*(n*(p+1)+1)+(a*D*(n+2)-b*B*(n*(2*p+3)+2))*x^(n/2),x],x]] /;
FreeQ[{a,b,n},x] && PolyQ[P3,x^(n/2),3] && ILtQ[p,-1]

Integrate[Pq_*(a_+b_*x_^n_)^p_.,x_] := Integrate[ExpandIntegrand[Pq*(a+b*x^n)^p,x],x] /;
FreeQ[{a,b,n,p},x] && (PolyQ[Pq,x] || PolyQ[Pq,x^n])

Integrate[Pq_*(a_+b_*v_^n_.)^p_,x_] := 1/Coeff[v,x,1]*Subst[Integrate[SubstFor[v,Pq,x]*(a+b*x^n)^p,x],x,v] /;
FreeQ[{a,b,n,p},x] && LinearQ[v,x] && PolyQ[Pq,v^n]

Integrate[Pq_*(a1_+b1_*x_^n_.)^p_*(a2_+b2_*x_^n_.)^p_.,x_] := Integrate[Pq*(a1*a2+b1*b2*x^(2*n))^p,x] /;
FreeQ[{a1,b1,a2,b2,n,p},x] && PolyQ[Pq,x] && EqQ[a2*b1+a1*b2,0] && (IntegerQ[p] || GtQ[a1,0] && GtQ[a2,0])

