FreeQ[{a,b,c,m,n,p},x] && (PolyQ[Pq,x] || PolyQ[Pq,x^n]) && Not[IGtQ[m,0]]

Integrate[u_^m_*Pq_*(a_+b_*v_^n_.)^p_,x_] := u^m/(Coeff[v,x,1]*v^m)*Subst[Integrate[x^m*SubstFor[v,Pq,x]*(a+b*x^n)^p,x],x,v] /;
FreeQ[{a,b,m,n,p},x] && LinearPairQ[u,v,x] && PolyQ[Pq,v^n]

Integrate[(c_*x_)^m_*Pq_*(a1_+b1_*x_^n_.)^p_*(a2_+b2_*x_^n_.)^p_.,x_] := Integrate[(c*x)^m*Pq*(a1*a2+b1*b2*x^(2*n))^p,x] /;
FreeQ[{a1,b1,a2,b2,c,m,n,p},x] && PolyQ[Pq,x] && EqQ[a2*b1+a1*b2,0] && (IntegerQ[p] || GtQ[a1,0] && GtQ[a2,0])

Integrate[(c_*x_)^m_*Pq_*(a1_+b1_*x_^n_.)^p_*(a2_+b2_*x_^n_.)^p_.,x_] := (a1+b1*x^n)^FracPart[p]*(a2+b2*x^n)^FracPart[p]/(a1*a2+b1*b2*x^(2*n))^FracPart[p]* Integrate[(c*x)^m*Pq*(a1*a2+b1*b2*x^(2*n))^p,x] /;
FreeQ[{a1,b1,a2,b2,c,m,n,p},x] && PolyQ[Pq,x] && EqQ[a2*b1+a1*b2,0] && Not[EqQ[n,1] && LinearQ[Pq,x]]

Integrate[(h_*x_)^m_*(e_+f_*x_^n_.+g_*x_^n2_.)*(a_+b_*x_^n_.)^p_*(c_+d_*x_^n_.)^p_.,x_] := e*(h*x)^(m+1)*(a+b*x^n)^(p+1)*(c+d*x^n)^(p+1)/(a*c*h*(m+1)) /;
FreeQ[{a,b,c,d,e,f,g,h,m,n,p},x] && EqQ[n2,2*n] && EqQ[a*c*f*(m+1)-e*(b*c+a*d)*(m+n*(p+1)+1),0] && EqQ[a*c*g*(m+1)-b*d*e*(m+2*n*(p+1)+1),0] && NeQ[m,-1]

Integrate[(h_*x_)^m_*(e_+g_*x_^n2_.)*(a_+b_*x_^n_.)^p_*(c_+d_*x_^n_.)^p_.,x_] := e*(h*x)^(m+1)*(a+b*x^n)^(p+1)*(c+d*x^n)^(p+1)/(a*c*h*(m+1)) /;
FreeQ[{a,b,c,d,e,g,h,m,n,p},x] && EqQ[n2,2*n] && EqQ[m+n*(p+1)+1,0] && EqQ[a*c*g*(m+1)-b*d*e*(m+2*n*(p+1)+1),0] && NeQ[m,-1]

Integrate[1/x_,x_] := Log[x]

Integrate[x_^m_.,x_] := x^(m+1)/(m+1) /;
FreeQ[m,x] && NeQ[m,-1]

Integrate[1/(a_+b_*x_),x_] := Log[RemoveContent[a+b*x,x]]/b /;
FreeQ[{a,b},x]

Integrate[(a_.+b_*x_)^m_,x_] := (a+b*x)^(m+1)/(b*(m+1)) /;
FreeQ[{a,b,m},x] && NeQ[m,-1]

Integrate[(a_.+b_*u_)^m_,x_] := 1/Coefficient[u,x,1]*Subst[Integrate[(a+b*x)^m,x],x,u] /;
FreeQ[{a,b,m},x] && LinearQ[u,x] && NeQ[u,x]

Integrate[(a_+b_*x_)^m_*(c_+d_*x_),x_] := d*x*(a+b*x)^(m+1)/(b*(m+2)) /;
FreeQ[{a,b,c,d,m},x] && EqQ[a*d-b*c*(m+2),0]

Integrate[1/((a_+b_*x_)*(c_+d_*x_)),x_] := Integrate[1/(a*c+b*d*x^2),x] /;
FreeQ[{a,b,c,d},x] && EqQ[b*c+a*d,0]

Integrate[1/((a_.+b_*x_)*(c_.+d_*x_)),x_] := b/(b*c-a*d)*Integrate[1/(a+b*x),x] - d/(b*c-a*d)*Integrate[1/(c+d*x),x] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0]

Integrate[(a_.+b_*x_)^m_*(c_.+d_*x_)^n_,x_] := (a+b*x)^(m+1)*(c+d*x)^(n+1)/((b*c-a*d)*(m+1)) /;
FreeQ[{a,b,c,d,m,n},x] && NeQ[b*c-a*d,0] && EqQ[m+n+2,0] && NeQ[m,-1]

Integrate[(a_+b_*x_)^m_*(c_+d_*x_)^m_,x_] := x*(a+b*x)^m*(c+d*x)^m/(2*m+1) + 2*a*c*m/(2*m+1)*Integrate[(a+b*x)^(m-1)*(c+d*x)^(m-1),x] /;
FreeQ[{a,b,c,d},x] && EqQ[b*c+a*d,0] && IGtQ[m+1/2,0]

Integrate[1/((a_+b_*x_)^(3/2)*(c_+d_*x_)^(3/2)),x_] := x/(a*c*Sqrt[a+b*x]*Sqrt[c+d*x]) /;
FreeQ[{a,b,c,d},x] && EqQ[b*c+a*d,0]

Integrate[(a_+b_*x_)^m_*(c_+d_*x_)^m_,x_] := -x*(a+b*x)^(m+1)*(c+d*x)^(m+1)/(2*a*c*(m+1)) +    (2*m+3)/(2*a*c*(m+1))*Integrate[(a+b*x)^(m+1)*(c+d*x)^(m+1),x] /;
FreeQ[{a,b,c,d},x] && EqQ[b*c+a*d,0] && ILtQ[m+3/2,0]

Integrate[(a_+b_*x_)^m_*(c_+d_*x_)^m_.,x_] := Integrate[(a*c+b*d*x^2)^m,x] /;
FreeQ[{a,b,c,d,m},x] && EqQ[b*c+a*d,0] && (IntegerQ[m] || GtQ[a,0] && GtQ[c,0])

