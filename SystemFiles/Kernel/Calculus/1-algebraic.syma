Integrate[x_^m_./(a_+b_*x_^n_),x_] := Module[{r=Numerator[Rt[a/b,n]], s=Denominator[Rt[a/b,n]], k, u}, u=Integrate[(r*Cos[(2*k-1)*m*Pi/n]-s*Cos[(2*k-1)*(m+1)*Pi/n]*x)/(r^2-2*r*s*Cos[(2*k-1)*Pi/n]*x+s^2*x^2),x]; -(-r)^(m+1)/(a*n*s^m)*Integrate[1/(r+s*x),x] + Dist[2*r^(m+1)/(a*n*s^m),Sum[u,{k,1,(n-1)/2}],x]] /;
FreeQ[{a,b},x] && IGtQ[(n-1)/2,0] && IGtQ[m,0] && LtQ[m,n-1] && PosQ[a/b]

