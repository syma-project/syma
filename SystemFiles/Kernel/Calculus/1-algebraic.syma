Integrate[(d_*x_)^m_*(a_+b_*(c_*x_)^n_)^p_.,x_] := 1/c*Subst[Integrate[(d*x/c)^m*(a+b*x^n)^p,x],x,c*x] /;
FreeQ[{a,b,c,d,m,n,p},x]

Integrate[(d_*x_)^m_*(a_+b_*(c_*x_^q_)^n_)^p_.,x_] := (d*x)^(m+1)/(d*((c*x^q)^(1/q))^(m+1))*Subst[Integrate[x^m*(a+b*x^(n*q))^p,x],x,(c*x^q)^(1/q)] /;
FreeQ[{a,b,c,d,m,n,p,q},x] && IntegerQ[n*q] && NeQ[x,(c*x^q)^(1/q)]

Integrate[(d_*x_)^m_*(a_+b_*(c_*x_^q_)^n_)^p_.,x_] := With[{k=Denominator[n]}, Subst[Integrate[(d*x)^m*(a+b*c^n*x^(n*q))^p,x],x^(1/k),(c*x^q)^(1/k)/(c^(1/k)*(x^(1/k))^(q-1))]] /;
FreeQ[{a,b,c,d,m,p,q},x] && FractionQ[n]

Integrate[(d_*x_)^m_*(a_+b_*(c_*x_^q_)^n_)^p_.,x_] := Subst[Integrate[(d*x)^m*(a+b*c^n*x^(n*q))^p,x],x^(n*q),(c*x^q)^n/c^n] /;
FreeQ[{a,b,c,d,m,n,p,q},x] && Not[RationalQ[n]]

Integrate[x_^m_*(a_+b_*v_^n_)^p_.,x_] := With[{c=Coefficient[v,x,0],d=Coefficient[v,x,1]}, 1/d^(m+1)*Subst[Integrate[SimplifyIntegrand[(x-c)^m*(a+b*x^n)^p,x],x],x,v] /; NeQ[c,0]] /;
FreeQ[{a,b,n,p},x] && LinearQ[v,x] && IntegerQ[m]

Integrate[u_^m_*(a_+b_*v_^n_)^p_.,x_] := u^m/(Coefficient[v,x,1]*v^m)*Subst[Integrate[x^m*(a+b*x^n)^p,x],x,v] /;
FreeQ[{a,b,m,n,p},x] && LinearPairQ[u,v,x]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_.,x_] := Integrate[ExpandIntegrand[(a+b*x^n)^p*(c+d*x^n)^q,x],x] /;
FreeQ[{a,b,c,d,n},x] && NeQ[b*c-a*d,0] && IGtQ[p,0] && IGtQ[q,0]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_.,x_] := Integrate[x^(n*(p+q))*(b+a*x^(-n))^p*(d+c*x^(-n))^q,x] /;
FreeQ[{a,b,c,d,n},x] && NeQ[b*c-a*d,0] && IntegersQ[p,q] && NegQ[n]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_.,x_] := -Subst[Integrate[(a+b*x^(-n))^p*(c+d*x^(-n))^q/x^2,x],x,1/x] /;
FreeQ[{a,b,c,d,p,q},x] && NeQ[b*c-a*d,0] && ILtQ[n,0]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_.,x_] := With[{g=Denominator[n]}, g*Subst[Integrate[x^(g-1)*(a+b*x^(g*n))^p*(c+d*x^(g*n))^q,x],x,x^(1/g)]] /;
FreeQ[{a,b,c,d,p,q},x] && NeQ[b*c-a*d,0] && FractionQ[n]

Integrate[1/((a_+b_*x_^3)^(1/3)*(c_+d_*x_^3)),x_] := With[{q=Rt[(b*c-a*d)/c,3]}, ArcTan[(1+(2*q*x)/(a+b*x^3)^(1/3))/Sqrt[3]]/(Sqrt[3]*c*q) + Log[c+d*x^3]/(6*c*q) - Log[q*x-(a+b*x^3)^(1/3)]/(2*c*q)] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0]

Integrate[(a_+b_*x_^n_)^p_/(c_+d_*x_^n_),x_] := Subst[Integrate[1/(c-(b*c-a*d)*x^n),x],x,x/(a+b*x^n)^(1/n)] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0] && EqQ[n*p+1,0] && IntegerQ[n]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_.,x_] := -x*(a+b*x^n)^(p+1)*(c+d*x^n)^q/(a*n*(p+1)) - c*q/(a*(p+1))*Integrate[(a+b*x^n)^(p+1)*(c+d*x^n)^(q-1),x] /;
FreeQ[{a,b,c,d,n,p},x] && NeQ[b*c-a*d,0] && EqQ[n*(p+q+1)+1,0] && GtQ[q,0] && NeQ[p,-1]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_,x_] := a^p*x/(c^(p+1)*(c+d*x^n)^(1/n))*Hypergeometric2F1[1/n,-p,1+1/n,-(b*c-a*d)*x^n/(a*(c+d*x^n))] /;
FreeQ[{a,b,c,d,n,q},x] && NeQ[b*c-a*d,0] && EqQ[n*(p+q+1)+1,0] && ILtQ[p,0]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_,x_] := x*(a+b*x^n)^p/(c*(c*(a+b*x^n)/(a*(c+d*x^n)))^p*(c+d*x^n)^(1/n+p))* Hypergeometric2F1[1/n,-p,1+1/n,-(b*c-a*d)*x^n/(a*(c+d*x^n))] /;
FreeQ[{a,b,c,d,n,p,q},x] && NeQ[b*c-a*d,0] && EqQ[n*(p+q+1)+1,0]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_,x_] := x*(a+b*x^n)^(p+1)*(c+d*x^n)^(q+1)/(a*c) /;
FreeQ[{a,b,c,d,n,p,q},x] && NeQ[b*c-a*d,0] && EqQ[n*(p+q+2)+1,0] && EqQ[a*d*(p+1)+b*c*(q+1),0] (* Integrate[(a1_+b1_*x_^n2_.)^p_*(a2_+b2_*x_^n2_.)^p_*(c_+d_*x_^n_)^q_,x_] := x*(a1+b1*x^(n/2))^(p+1)*(a2+b2*x^(n/2))^(p+1)*(c+d*x^n)^(q+1)/(a1*a2*c) /; FreeQ[{a1,b1,a2,b2,c,d,n,p,q},x] && EqQ[n2,n/2] && EqQ[a2*b1+a1*b2,0] && EqQ[n*(p+q+2)+1,0] && EqQ[a1*a2*d*(p+1)+b1*b2*c*(q+1),0] *)

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_,x_] := -b*x*(a+b*x^n)^(p+1)*(c+d*x^n)^(q+1)/(a*n*(p+1)*(b*c-a*d)) + (b*c+n*(p+1)*(b*c-a*d))/(a*n*(p+1)*(b*c-a*d))*Integrate[(a+b*x^n)^(p+1)*(c+d*x^n)^q,x] /;
FreeQ[{a,b,c,d,n,q},x] && NeQ[b*c-a*d,0] && EqQ[n*(p+q+2)+1,0] && (LtQ[p,-1] || Not[LtQ[q,-1]]) && NeQ[p,-1]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_),x_] := c*x*(a+b*x^n)^(p+1)/a /;
FreeQ[{a,b,c,d,n,p},x] && NeQ[b*c-a*d,0] && EqQ[a*d-b*c*(n*(p+1)+1),0]

Integrate[(a1_+b1_*x_^non2_.)^p_*(a2_+b2_*x_^non2_.)^p_*(c_+d_*x_^n_),x_] := c*x*(a1+b1*x^(n/2))^(p+1)*(a2+b2*x^(n/2))^(p+1)/(a1*a2) /;
FreeQ[{a1,b1,a2,b2,c,d,n,p},x] && EqQ[non2,n/2] && EqQ[a2*b1+a1*b2,0] && EqQ[a1*a2*d-b1*b2*c*(n*(p+1)+1),0]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_),x_] := -(b*c-a*d)*x*(a+b*x^n)^(p+1)/(a*b*n*(p+1)) - (a*d-b*c*(n*(p+1)+1))/(a*b*n*(p+1))*Integrate[(a+b*x^n)^(p+1),x] /;
FreeQ[{a,b,c,d,n,p},x] && NeQ[b*c-a*d,0] && (LtQ[p,-1] || ILtQ[1/n+p,0])

Integrate[(a1_+b1_*x_^non2_.)^p_*(a2_+b2_*x_^non2_.)^p_*(c_+d_*x_^n_),x_] := -(b1*b2*c-a1*a2*d)*x*(a1+b1*x^(n/2))^(p+1)*(a2+b2*x^(n/2))^(p+1)/(a1*a2*b1*b2*n*(p+1)) - (a1*a2*d-b1*b2*c*(n*(p+1)+1))/(a1*a2*b1*b2*n*(p+1))*Integrate[(a1+b1*x^(n/2))^(p+1)*(a2+b2*x^(n/2))^(p+1),x] /;
FreeQ[{a1,b1,a2,b2,c,d,n},x] && EqQ[non2,n/2] && EqQ[a2*b1+a1*b2,0] && (LtQ[p,-1] || ILtQ[1/n+p,0])

Integrate[(c_+d_*x_^n_)/(a_+b_*x_^n_),x_] := c*x/a - (b*c-a*d)/a*Integrate[1/(b+a*x^(-n)),x] /;
FreeQ[{a,b,c,d,n},x] && NeQ[b*c-a*d,0] && LtQ[n,0]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_),x_] := d*x*(a+b*x^n)^(p+1)/(b*(n*(p+1)+1)) - (a*d-b*c*(n*(p+1)+1))/(b*(n*(p+1)+1))*Integrate[(a+b*x^n)^p,x] /;
FreeQ[{a,b,c,d,n},x] && NeQ[b*c-a*d,0] && NeQ[n*(p+1)+1,0]

Integrate[(a1_+b1_*x_^non2_.)^p_*(a2_+b2_*x_^non2_.)^p_*(c_+d_*x_^n_),x_] := d*x*(a1+b1*x^(n/2))^(p+1)*(a2+b2*x^(n/2))^(p+1)/(b1*b2*(n*(p+1)+1)) - (a1*a2*d-b1*b2*c*(n*(p+1)+1))/(b1*b2*(n*(p+1)+1))*Integrate[(a1+b1*x^(n/2))^p*(a2+b2*x^(n/2))^p,x] /;
FreeQ[{a1,b1,a2,b2,c,d,n,p},x] && EqQ[non2,n/2] && EqQ[a2*b1+a1*b2,0] && NeQ[n*(p+1)+1,0]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_,x_] := Integrate[PolynomialDivide[(a+b*x^n)^p,(c+d*x^n)^(-q),x],x] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0] && IGtQ[n,0] && IGtQ[p,0] && ILtQ[q,0] && GeQ[p,-q]

Integrate[(a_+b_*x_^n_)^p_/(c_+d_*x_^n_),x_] := b/d*Integrate[(a+b*x^n)^(p-1),x] - (b*c-a*d)/d*Integrate[(a+b*x^n)^(p-1)/(c+d*x^n),x] /;
FreeQ[{a,b,c,d,p},x] && NeQ[b*c-a*d,0] && EqQ[n*(p-1)+1,0] && IntegerQ[n]

Integrate[1/((a_+b_*x_^n_)*(c_+d_*x_^n_)),x_] := b/(b*c-a*d)*Integrate[1/(a+b*x^n),x] - d/(b*c-a*d)*Integrate[1/(c+d*x^n),x] /;
FreeQ[{a,b,c,d,n},x] && NeQ[b*c-a*d,0]

Integrate[1/((a_+b_*x_^2)^(1/3)*(c_+d_*x_^2)),x_] := With[{q=Rt[b/a,2]}, q*ArcTanh[Sqrt[3]/(q*x)]/(2*2^(2/3)*Sqrt[3]*a^(1/3)*d) + q*ArcTanh[Sqrt[3]*(a^(1/3)-2^(1/3)*(a+b*x^2)^(1/3))/(a^(1/3)*q*x)]/(2*2^(2/3)*Sqrt[3]*a^(1/3)*d) + q*ArcTan[q*x]/(6*2^(2/3)*a^(1/3)*d) -    q*ArcTan[(a^(1/3)*q*x)/(a^(1/3)+2^(1/3)*(a+b*x^2)^(1/3))]/(2*2^(2/3)*a^(1/3)*d)] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0] && EqQ[b*c+3*a*d,0] && PosQ[b/a]

Integrate[1/((a_+b_*x_^2)^(1/3)*(c_+d_*x_^2)),x_] := With[{q=Rt[-b/a,2]}, q*ArcTan[Sqrt[3]/(q*x)]/(2*2^(2/3)*Sqrt[3]*a^(1/3)*d) + q*ArcTan[Sqrt[3]*(a^(1/3)-2^(1/3)*(a+b*x^2)^(1/3))/(a^(1/3)*q*x)]/(2*2^(2/3)*Sqrt[3]*a^(1/3)*d) - q*ArcTanh[q*x]/(6*2^(2/3)*a^(1/3)*d) +    q*ArcTanh[(a^(1/3)*q*x)/(a^(1/3)+2^(1/3)*(a+b*x^2)^(1/3))]/(2*2^(2/3)*a^(1/3)*d)] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0] && EqQ[b*c+3*a*d,0] && NegQ[b/a]

Integrate[1/((a_+b_*x_^2)^(1/3)*(c_+d_*x_^2)),x_] := With[{q=Rt[b/a,2]}, q*ArcTan[q*x/3]/(12*Rt[a,3]*d) + q*ArcTan[(Rt[a,3]-(a+b*x^2)^(1/3))^2/(3*Rt[a,3]^2*q*x)]/(12*Rt[a,3]*d) - q*ArcTanh[(Sqrt[3]*(Rt[a,3]-(a+b*x^2)^(1/3)))/(Rt[a,3]*q*x)]/(4*Sqrt[3]*Rt[a,3]*d)] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0] && EqQ[b*c-9*a*d,0] && PosQ[b/a]

Integrate[1/((a_+b_*x_^2)^(1/3)*(c_+d_*x_^2)),x_] := With[{q=Rt[-b/a,2]}, -q*ArcTanh[q*x/3]/(12*Rt[a,3]*d) + q*ArcTanh[(Rt[a,3]-(a+b*x^2)^(1/3))^2/(3*Rt[a,3]^2*q*x)]/(12*Rt[a,3]*d) - q*ArcTan[(Sqrt[3]*(Rt[a,3]-(a+b*x^2)^(1/3)))/(Rt[a,3]*q*x)]/(4*Sqrt[3]*Rt[a,3]*d)] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0] && EqQ[b*c-9*a*d,0] && NegQ[b/a]

Integrate[(a_+b_*x_^2)^(2/3)/(c_+d_*x_^2),x_] := b/d*Integrate[1/(a+b*x^2)^(1/3),x] - (b*c-a*d)/d*Integrate[1/((a+b*x^2)^(1/3)*(c+d*x^2)),x] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0] && EqQ[b*c+3*a*d,0]

Integrate[1/((a_+b_*x_^2)^(1/4)*(c_+d_*x_^2)),x_] := With[{q=Rt[b^2/a,4]}, -b/(2*a*d*q)*ArcTan[(b+q^2*Sqrt[a+b*x^2])/(q^3*x*(a+b*x^2)^(1/4))] -    b/(2*a*d*q)*ArcTanh[(b-q^2*Sqrt[a+b*x^2])/(q^3*x*(a+b*x^2)^(1/4))]] /;
FreeQ[{a,b,c,d},x] && EqQ[b*c-2*a*d,0] && PosQ[b^2/a]

Integrate[1/((a_+b_*x_^2)^(1/4)*(c_+d_*x_^2)),x_] := With[{q=Rt[-b^2/a,4]}, b/(2*Sqrt[2]*a*d*q)*ArcTan[q*x/(Sqrt[2]*(a+b*x^2)^(1/4))] + b/(2*Sqrt[2]*a*d*q)*ArcTanh[q*x/(Sqrt[2]*(a+b*x^2)^(1/4))]] /;
FreeQ[{a,b,c,d},x] && EqQ[b*c-2*a*d,0] && NegQ[b^2/a] (* Integrate[1/((a_+b_*x_^2)^(1/4)*(c_+d_*x_^2)),x_] := With[{q=Rt[-b^2/a,4]}, b/(2*Sqrt[2]*a*d*q)*ArcTan[q*x/(Sqrt[2]*(a+b*x^2)^(1/4))] + b/(4*Sqrt[2]*a*d*q)*Log[(Sqrt[2]*q*x+2*(a+b*x^2)^(1/4))/(Sqrt[2]*q*x-2*(a+b*x^2)^(1/4))]] /; FreeQ[{a,b,c,d},x] && EqQ[b*c-2*a*d,0] && NegQ[b^2/a] *)

Integrate[1/((a_+b_*x_^2)^(1/4)*(c_+d_*x_^2)),x_] := 2*Sqrt[-b*x^2/a]/x*Subst[Integrate[x^2/(Sqrt[1-x^4/a]*(b*c-a*d+d*x^4)),x],x,(a+b*x^2)^(1/4)] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0]

Integrate[1/((a_+b_*x_^2)^(3/4)*(c_+d_*x_^2)),x_] := 1/c*Integrate[1/(a+b*x^2)^(3/4),x] - d/c*Integrate[x^2/((a+b*x^2)^(3/4)*(c+d*x^2)),x] /;
FreeQ[{a,b,c,d},x] && EqQ[b*c-2*a*d,0]

Integrate[1/((a_+b_*x_^2)^(3/4)*(c_+d_*x_^2)),x_] := Sqrt[-b*x^2/a]/(2*x)*Subst[Integrate[1/(Sqrt[-b*x/a]*(a+b*x)^(3/4)*(c+d*x)),x],x,x^2] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0]

Integrate[(a_+b_*x_^2)^p_./(c_+d_*x_^2),x_] := b/d*Integrate[(a+b*x^2)^(p-1),x] - (b*c-a*d)/d*Integrate[(a+b*x^2)^(p-1)/(c+d*x^2),x] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0] && GtQ[p,0] && (EqQ[p,1/2] || EqQ[Denominator[p],4])

Integrate[(a_+b_*x_^2)^p_/(c_+d_*x_^2),x_] := b/(b*c-a*d)*Integrate[(a+b*x^2)^p,x] - d/(b*c-a*d)*Integrate[(a+b*x^2)^(p+1)/(c+d*x^2),x] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0] && LtQ[p,-1] && EqQ[Denominator[p],4] && (EqQ[p,-5/4] || EqQ[p,-7/4])

Integrate[Sqrt[a_+b_*x_^4]/(c_+d_*x_^4),x_] := a/c*Subst[Integrate[1/(1-4*a*b*x^4),x],x,x/Sqrt[a+b*x^4]] /;
FreeQ[{a,b,c,d},x] && EqQ[b*c+a*d,0] && PosQ[a*b]

Integrate[Sqrt[a_+b_*x_^4]/(c_+d_*x_^4),x_] := With[{q=Rt[-a*b,4]}, a/(2*c*q)*ArcTan[q*x*(a+q^2*x^2)/(a*Sqrt[a+b*x^4])] + a/(2*c*q)*ArcTanh[q*x*(a-q^2*x^2)/(a*Sqrt[a+b*x^4])]] /;
FreeQ[{a,b,c,d},x] && EqQ[b*c+a*d,0] && NegQ[a*b]

Integrate[Sqrt[a_+b_*x_^4]/(c_+d_*x_^4),x_] := b/d*Integrate[1/Sqrt[a+b*x^4],x] - (b*c-a*d)/d*Integrate[1/(Sqrt[a+b*x^4]*(c+d*x^4)),x] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0]

Integrate[(a_+b_*x_^4)^(1/4)/(c_+d_*x_^4),x_] := Sqrt[a+b*x^4]*Sqrt[a/(a+b*x^4)]*Subst[Integrate[1/(Sqrt[1-b*x^4]*(c-(b*c-a*d)*x^4)),x],x,x/(a+b*x^4)^(1/4)] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0]

Integrate[(a_+b_*x_^4)^(5/4)/(c_+d_*x_^4),x_] := b/d*Integrate[(a+b*x^4)^(1/4),x] - (b*c-a*d)/d*Integrate[(a+b*x^4)^(1/4)/(c+d*x^4),x] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0]

Integrate[1/(Sqrt[a_+b_*x_^4]*(c_+d_*x_^4)),x_] := 1/(2*c)*Integrate[1/(Sqrt[a+b*x^4]*(1-Rt[-d/c,2]*x^2)),x] + 1/(2*c)*Integrate[1/(Sqrt[a+b*x^4]*(1+Rt[-d/c,2]*x^2)),x] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0]

Integrate[1/((a_+b_*x_^4)^(3/4)*(c_+d_*x_^4)),x_] := b/(b*c-a*d)*Integrate[1/(a+b*x^4)^(3/4),x] - d/(b*c-a*d)*Integrate[(a+b*x^4)^(1/4)/(c+d*x^4),x] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0]

Integrate[(a_+b_*x_^3)^(1/3)/(c_+d_*x_^3),x_] := With[{q=Rt[b/a,3]}, 9*a/(c*q)*Subst[Integrate[x/((4-a*x^3)*(1+2*a*x^3)),x],x,(1+q*x)/(a+b*x^3)^(1/3)]] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0] && EqQ[b*c+a*d,0]

Integrate[1/((a_+b_*x_^3)^(2/3)*(c_+d_*x_^3)),x_] := b/(b*c-a*d)*Integrate[1/(a+b*x^3)^(2/3),x] - d/(b*c-a*d)*Integrate[(a+b*x^3)^(1/3)/(c+d*x^3),x] /;
FreeQ[{a,b,c,d},x] && NeQ[b*c-a*d,0] && EqQ[b*c+a*d,0]

Integrate[Sqrt[a_+b_*x_^2]/(c_+d_*x_^2)^(3/2),x_] := Sqrt[a+b*x^2]/(c*Rt[d/c,2]*Sqrt[c+d*x^2]*Sqrt[c*(a+b*x^2)/(a*(c+d*x^2))])*EllipticE[ArcTan[Rt[d/c,2]*x],1-b*c/(a*d)] /;
