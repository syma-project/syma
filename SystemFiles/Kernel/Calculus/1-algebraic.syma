Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_,x_] := x*(a+b*x^n)^p*(c+d*x^n)^q/(n*(p+q)+1) + n/(n*(p+q)+1)*Integrate[(a+b*x^n)^(p-1)*(c+d*x^n)^(q-1)*Simp[a*c*(p+q)+(q*(b*c-a*d)+a*d*(p+q))*x^n,x],x] /;
