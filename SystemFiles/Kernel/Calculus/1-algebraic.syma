FreeQ[{a1,b1,a2,b2,c,m},x] && EqQ[a2*b1+a1*b2,0] && IGtQ[2*n,0] && LtQ[p,-1] && IntBinomialQ[a1*a2,b1*b2,c,2*n,m,p,x]

Integrate[x_/(a_+b_*x_^3),x_] := -1/(3*Rt[a,3]*Rt[b,3])*Integrate[1/(Rt[a,3]+Rt[b,3]*x),x] + 1/(3*Rt[a,3]*Rt[b,3])*Integrate[(Rt[a,3]+Rt[b,3]*x)/(Rt[a,3]^2-Rt[a,3]*Rt[b,3]*x+Rt[b,3]^2*x^2),x] /;
