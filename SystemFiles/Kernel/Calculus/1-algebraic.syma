FreeQ[{a,b,c,d},x] && NeQ[b*c^3-a*d^3,0]

Integrate[1/((c_+d_*x_)*(a_+b_*x_^3)^(1/3)),x_] := Sqrt[3]*ArcTan[(1-2^(1/3)*Rt[b,3]*(c-d*x)/(d*(a+b*x^3)^(1/3)))/Sqrt[3]]/(2^(4/3)*Rt[b,3]*c) + Log[(c+d*x)^2*(c-d*x)]/(2^(7/3)*Rt[b,3]*c) -    (3*Log[Rt[b,3]*(c-d*x)+2^(2/3)*d*(a+b*x^3)^(1/3)])/(2^(7/3)*Rt[b,3]*c) /;
FreeQ[{a,b,c,d},x] && EqQ[b*c^3+a*d^3,0]

Integrate[1/((c_+d_*x_)*(a_+b_*x_^3)^(1/3)),x_] := 1/(2*c)*Integrate[1/(a+b*x^3)^(1/3),x] + 1/(2*c)*Integrate[(c-d*x)/((c+d*x)*(a+b*x^3)^(1/3)),x] /;
FreeQ[{a,b,c,d},x] && EqQ[2*b*c^3-a*d^3,0]

Integrate[(e_+f_*x_)/((c_+d_*x_)*(a_+b_*x_^3)^(1/3)),x_] := Sqrt[3]*f*ArcTan[(1+2*Rt[b,3]*(2*c+d*x)/(d*(a+b*x^3)^(1/3)))/Sqrt[3]]/(Rt[b,3]*d) + (f*Log[c+d*x])/(Rt[b,3]*d) -    (3*f*Log[Rt[b,3]*(2*c+d*x)-d*(a+b*x^3)^(1/3)])/(2*Rt[b,3]*d) /;
FreeQ[{a,b,c,d,e,f},x] && EqQ[d*e+c*f,0] && EqQ[2*b*c^3-a*d^3,0]

Integrate[(e_.+f_*x_)/((c_.+d_*x_)*(a_+b_*x_^3)^(1/3)),x_] := f/d*Integrate[1/(a+b*x^3)^(1/3),x] + (d*e-c*f)/d*Integrate[1/((c+d*x)*(a+b*x^3)^(1/3)),x] /;
FreeQ[{a,b,c,d,e,f},x]

Integrate[(a_+b_*x_^3)^(2/3)/(c_+d_*x_),x_] := (a+b*x^3)^(2/3)/(2*d) - b*c/d^2*Integrate[x/(a+b*x^3)^(1/3),x] +    1/d^2*Integrate[(a*d^2+b*c^2*x)/((c+d*x)*(a+b*x^3)^(1/3)),x] /;
FreeQ[{a,b,c,d},x]

Integrate[1/((c_+d_*x_)*(a_+b_*x_^3)^(2/3)),x_] := With[{q=Rt[b,3]}, -d*ArcTan[(1+2*q*x/(a+b*x^3)^(1/3))/Sqrt[3]]/(2*Sqrt[3]*q^2*c^2) + Sqrt[3]*d*ArcTan[(1+2*q*(2*c+d*x)/(d*(a+b*x^3)^(1/3)))/Sqrt[3]]/(2*q^2*c^2) -    d*Log[c+d*x]/(2*q^2*c^2) - d*Log[q*x-(a+b*x^3)^(1/3)]/(4*q^2*c^2) +    3*d*Log[q*(2*c+d*x)-d*(a+b*x^3)^(1/3)]/(4*q^2*c^2)] /;
FreeQ[{a,b,c,d},x] && EqQ[2*b*c^3-a*d^3,0]

Integrate[x_^m_*Px_*(c_+d_*x_)^q_*(a_+b_*x_^3)^p_.,x_] := Integrate[ExpandIntegrand[(c^3+d^3*x^3)^q*(a+b*x^3)^p,x^m*Px/(c^2-c*d*x+d^2*x^2)^q,x],x] /;
FreeQ[{a,b,c,d,m,p},x] && PolyQ[Px,x] && ILtQ[q,0] && IntegerQ[m] && RationalQ[p] && EqQ[Denominator[p],3]

Integrate[Px_*(c_+d_*x_)^q_*(a_+b_*x_^3)^p_.,x_] := Integrate[ExpandIntegrand[(c^3+d^3*x^3)^q*(a+b*x^3)^p,Px/(c^2-c*d*x+d^2*x^2)^q,x],x] /;
FreeQ[{a,b,c,d,p},x] && PolyQ[Px,x] && ILtQ[q,0] && RationalQ[p] && EqQ[Denominator[p],3]

Integrate[x_^m_*Px_*(c_+d_*x_+e_*x_^2)^q_*(a_+b_*x_^3)^p_.,x_] := 1/c^q*Integrate[ExpandIntegrand[(c^3-d^3*x^3)^q*(a+b*x^3)^p,x^m*Px/(c-d*x)^q,x],x] /;
FreeQ[{a,b,c,d,e,m,p},x] && PolyQ[Px,x] && EqQ[d^2-c*e,0] && ILtQ[q,0] && IntegerQ[m] && RationalQ[p] && EqQ[Denominator[p],3]

Integrate[Px_*(c_+d_*x_+e_*x_^2)^q_*(a_+b_*x_^3)^p_.,x_] := 1/c^q*Integrate[ExpandIntegrand[(c^3-d^3*x^3)^q*(a+b*x^3)^p,Px/(c-d*x)^q,x],x] /;
FreeQ[{a,b,c,d,e,p},x] && PolyQ[Px,x] && EqQ[d^2-c*e,0] && ILtQ[q,0] && RationalQ[p] && EqQ[Denominator[p],3]

Integrate[(c_+d_*x_^n_.)^q_*(a_+b_*x_^nn_.)^p_,x_] := Integrate[ExpandIntegrand[(a+b*x^nn)^p,(c/(c^2-d^2*x^(2*n))-d*x^n/(c^2-d^2*x^(2*n)))^(-q),x],x] /;
FreeQ[{a,b,c,d,n,nn,p},x] && Not[IntegerQ[p]] && ILtQ[q,0] && IGtQ[Log[2,nn/n],0]

Integrate[(e_*x_)^m_*(c_+d_*x_^n_.)^q_*(a_+b_*x_^nn_.)^p_,x_] := (e*x)^m/x^m*Integrate[ExpandIntegrand[x^m*(a+b*x^nn)^p,(c/(c^2-d^2*x^(2*n))-d*x^n/(c^2-d^2*x^(2*n)))^(-q),x],x] /;
FreeQ[{a,b,c,d,e,m,n,nn,p},x] && Not[IntegerQ[p]] && ILtQ[q,0] && IGtQ[Log[2,nn/n],0]

Integrate[x_^m_./(c_+d_*x_^n_+e_*Sqrt[a_+b_*x_^n_]),x_] := 1/n*Subst[Integrate[x^((m+1)/n-1)/(c+d*x+e*Sqrt[a+b*x]),x],x,x^n] /;
FreeQ[{a,b,c,d,e,m,n},x] && EqQ[b*c-a*d,0] && IntegerQ[(m+1)/n]

Integrate[u_./(c_+d_*x_^n_+e_*Sqrt[a_+b_*x_^n_]),x_] := c*Integrate[u/(c^2-a*e^2+c*d*x^n),x] - a*e*Integrate[u/((c^2-a*e^2+c*d*x^n)*Sqrt[a+b*x^n]),x] /;
FreeQ[{a,b,c,d,e,n},x] && EqQ[b*c-a*d,0]

Integrate[u_*(c_*(d_*(a_.+b_* x_))^q_)^p_,x_] := (c*(d*(a+b*x))^q)^p/(a+b*x)^(p*q)*Integrate[u*(a+b*x)^(p*q),x] /;
FreeQ[{a,b,c,d,q,p},x] && Not[IntegerQ[q]] && Not[IntegerQ[p]]

Integrate[u_*(c_*(d_*(a_.+b_* x_)^n_)^q_)^p_,x_] := (c*(d*(a+b*x)^n)^q)^p/(a+b*x)^(n*p*q)*Integrate[u*(a+b*x)^(n*p*q),x] /;
FreeQ[{a,b,c,d,n,q,p},x] && Not[IntegerQ[q]] && Not[IntegerQ[p]]

Integrate[u_*(c_*(a_.+b_*x_^n_.)^q_)^p_,x_] := Simp[(c*(a+b*x^n)^q)^p/(a+b*x^n)^(p*q)]*Integrate[u*(a+b*x^n)^(p*q),x] /;
FreeQ[{a,b,c,n,p,q},x] && GeQ[a,0]

Integrate[u_*(c_*(a_+b_*x_^n_.)^q_)^p_,x_] := Simp[(c*(a+b*x^n)^q)^p/(1+b*x^n/a)^(p*q)]*Integrate[u*(1+b*x^n/a)^(p*q),x] /;
FreeQ[{a,b,c,n,p,q},x] && Not[GeQ[a,0]]

Integrate[u_*(e_*(a_.+b_*x_^n_.)^q_*(c_+d_*x_^n_.)^q_.)^p_,x_] := Integrate[u*(e*(d/b)^q*(a+b*x^n)^(2*q))^p,x] /;
FreeQ[{a,b,c,d,e,n,p},x] && IntegerQ[q] && EqQ[b*c-a*d,0]

Integrate[u_*(e_*(a_.+b_*x_^n_.)^q_*(c_+d_*x_^n_.)^q_)^p_,x_] := Integrate[u*(e*(-a^2*d/b+b*d*x^(2*n))^q)^p,x] /;
FreeQ[{a,b,c,d,e,n,p},x] && IntegerQ[q] && EqQ[b*c+a*d,0] (* Integrate[u_*((a_.+b_*x_^n_.)*(c_+d_*x_^n_.))^p_,x_] := Integrate[u*(a+b*x^n)^p*(c+d*x^n)^p,x] /; FreeQ[{a,b,c,d,n,p},x] && EqQ[b+d,0] && GtQ[a,0] && GtQ[c,0] *)

Integrate[u_*(e_*(a_.+b_*x_^n_.)*(c_+d_*x_^n_.))^p_,x_] := Integrate[u*(a*c*e+(b*c+a*d)*e*x^n+b*d*e*x^(2*n))^p,x] /;
FreeQ[{a,b,c,d,e,n,p},x]

Integrate[u_*(e_*(a_.+b_*x_^n_.)/(c_+d_*x_^n_.))^p_,x_] := (b*e/d)^p*Integrate[u,x] /;
FreeQ[{a,b,c,d,e,n,p},x] && EqQ[b*c-a*d,0]

Integrate[u_*(e_*(a_.+b_*x_^n_.)/(c_+d_*x_^n_.))^p_,x_] := Integrate[u*(a*e+b*e*x^n)^p/(c+d*x^n)^p,x] /;
FreeQ[{a,b,c,d,e,n,p},x] && GtQ[b*d*e,0] && GtQ[c-a*d/b,0] (* Integrate[u_*(e_*(a_.+b_*x_^n_.)/(c_+d_*x_^n_.))^p_,x_] := Integrate[u*(a*e+b*e*x^n)^p/(c+d*x^n)^p,x] /; FreeQ[{a,b,c,d,e,n,p},x] && EqQ[b*c+a*d,0] && GtQ[b*e/d,0] && GtQ[c,0] *) (* Integrate[u_*(e_*(a_.+b_*x_^n_.)/(c_+d_*x_^n_.))^p_,x_] := Integrate[u*(-a*e-b*e*x^n)^p/(-c-d*x^n)^p,x] /; FreeQ[{a,b,c,d,e,n,p},x] && EqQ[b*c+a*d,0] && GtQ[b*e/d,0] && LtQ[c,0] *)

Integrate[(e_*(a_.+b_*x_^n_.)/(c_+d_*x_^n_.))^p_,x_] := With[{q=Denominator[p]}, q*e*(b*c-a*d)/n*Subst[ Integrate[x^(q*(p+1)-1)*(-a*e+c*x^q)^(1/n-1)/(b*e-d*x^q)^(1/n+1),x],x,(e*(a+b*x^n)/(c+d*x^n))^(1/q)]] /;
FreeQ[{a,b,c,d,e},x] && FractionQ[p] && IntegerQ[1/n]

Integrate[x_^m_*(e_*(a_.+b_*x_)/(c_+d_*x_))^p_,x_] := With[{q=Denominator[p]}, q*e*(b*c-a*d)*Subst[Integrate[x^(q*(p+1)-1)*(-a*e+c*x^q)^m/(b*e-d*x^q)^(m+2),x],x,(e*(a+b*x)/(c+d*x))^(1/q)]] /;
FreeQ[{a,b,c,d,e,m},x] && FractionQ[p] && IntegerQ[m]

Integrate[x_^m_*(e_*(a_.+b_*x_^n_.)/(c_+d_*x_^n_.))^p_,x_] := 1/n*Subst[Integrate[x^(Simplify[(m+1)/n]-1)*(e*(a+b*x)/(c+d*x))^p,x],x,x^n] /;
FreeQ[{a,b,c,d,e,m,n,p},x] && IntegerQ[Simplify[(m+1)/n]]

Integrate[(f_*x_)^m_*(e_*(a_.+b_*x_^n_.)/(c_+d_*x_^n_.))^p_,x_] := Simp[(c*x)^m/x^m]*Integrate[x^m*(e*(a+b*x^n)/(c+d*x^n))^p,x] /;
FreeQ[{a,b,c,d,e,f,m,n,p},x] && IntegerQ[Simplify[(m+1)/n]]

Integrate[u_^r_*(e_*(a_.+b_*x_^n_.)/(c_+d_*x_^n_.))^p_,x_] := With[{q=Denominator[p]}, q*e*(b*c-a*d)/n*Subst[Integrate[SimplifyIntegrand[x^(q*(p+1)-1)*(-a*e+c*x^q)^(1/n-1)/(b*e-d*x^q)^(1/n+1)* ReplaceAll[u,xRule(-a*e+c*x^q)^(1/n)/(b*e-d*x^q)^(1/n)]^r,x],x],x,(e*(a+b*x^n)/(c+d*x^n))^(1/q)]] /;
FreeQ[{a,b,c,d,e},x] && PolynomialQ[u,x] && FractionQ[p] && IntegerQ[1/n] && IntegerQ[r]

Integrate[x_^m_*u_^r_*(e_*(a_.+b_*x_^n_.)/(c_+d_*x_^n_.))^p_,x_] := With[{q=Denominator[p]}, q*e*(b*c-a*d)/n*Subst[Integrate[SimplifyIntegrand[x^(q*(p+1)-1)*(-a*e+c*x^q)^((m+1)/n-1)/(b*e-d*x^q)^((m+1)/n+1)* ReplaceAll[u,xRule(-a*e+c*x^q)^(1/n)/(b*e-d*x^q)^(1/n)]^r,x],x],x,(e*(a+b*x^n)/(c+d*x^n))^(1/q)]] /;
FreeQ[{a,b,c,d,e},x] && PolynomialQ[u,x] && FractionQ[p] && IntegerQ[1/n] && IntegersQ[m,r]

Integrate[u_*(a_+b_./(c_+d_*x_^n_))^p_,x_] := Integrate[u*((b+a*c+a*d*x^n)/(c+d*x^n))^p,x] /;
FreeQ[{a,b,c,d,n,p},x]

Integrate[u_*(e_*(a_.+b_*x_^n_.)^q_*(c_+d_*x_^n_)^r_.)^p_,x_] := Simp[(e*(a+b*x^n)^q*(c+d*x^n)^r)^p/((a+b*x^n)^(p*q)*(c+d*x^n)^(p*r))]* Integrate[u*(a+b*x^n)^(p*q)*(c+d*x^n)^(p*r),x] /;
FreeQ[{a,b,c,d,e,n,p,q,r},x]

Integrate[(a_.+b_*(c_./x_)^n_)^p_,x_] := -c*Subst[Integrate[(a+b*x^n)^p/x^2,x],x,c/x] /;
FreeQ[{a,b,c,n,p},x]

Integrate[x_^m_*(a_.+b_*(c_./x_)^n_)^p_,x_] := -c^(m+1)*Subst[Integrate[(a+b*x^n)^p/x^(m+2),x],x,c/x] /;
FreeQ[{a,b,c,n,p},x] && IntegerQ[m]

Integrate[(d_*x_)^m_*(a_.+b_*(c_./x_)^n_)^p_,x_] := -c*(d*x)^m*(c/x)^m*Subst[Integrate[(a+b*x^n)^p/x^(m+2),x],x,c/x] /;
FreeQ[{a,b,c,d,m,n,p},x] && Not[IntegerQ[m]]

Integrate[(a_.+b_*(d_./x_)^n_+c_*(d_./x_)^n2_.)^p_,x_] := -d*Subst[Integrate[(a+b*x^n+c*x^(2*n))^p/x^2,x],x,d/x] /;
FreeQ[{a,b,c,d,n,p},x] && EqQ[n2,2*n]

Integrate[x_^m_*(a_+b_*(d_./x_)^n_+c_*(d_./x_)^n2_.)^p_,x_] := -d^(m+1)*Subst[Integrate[(a+b*x^n+c*x^(2*n))^p/x^(m+2),x],x,d/x] /;
FreeQ[{a,b,c,d,n,p},x] && EqQ[n2,2*n] && IntegerQ[m]

Integrate[(e_*x_)^m_*(a_+b_*(d_./x_)^n_+c_*(d_./x_)^n2_.)^p_,x_] := -d*(e*x)^m*(d/x)^m*Subst[Integrate[(a+b*x^n+c*x^(2*n))^p/x^(m+2),x],x,d/x] /;
FreeQ[{a,b,c,d,e,m,n,p},x] && EqQ[n2,2*n] && Not[IntegerQ[m]]

Integrate[(a_.+b_*(d_./x_)^n_+c_*x_^n2_.)^p_,x_] := -d*Subst[Integrate[(a+b*x^n+c/d^(2*n)*x^(2*n))^p/x^2,x],x,d/x] /;
FreeQ[{a,b,c,d,n,p},x] && EqQ[n2,-2*n] && IntegerQ[2*n]

Integrate[x_^m_*(a_+b_*(d_./x_)^n_+c_*x_^n2_.)^p_,x_] := -d^(m+1)*Subst[Integrate[(a+b*x^n+c/d^(2*n)*x^(2*n))^p/x^(m+2),x],x,d/x] /;
FreeQ[{a,b,c,d,n,p},x] && EqQ[n2,-2*n] && IntegerQ[2*n] && IntegerQ[m]

Integrate[(e_*x_)^m_*(a_+b_*(d_./x_)^n_+c_*x_^n2_.)^p_,x_] := -d*(e*x)^m*(d/x)^m*Subst[Integrate[(a+b*x^n+c/d^(2*n)*x^(2*n))^p/x^(m+2),x],x,d/x] /;
FreeQ[{a,b,c,d,e,n,p},x] && EqQ[n2,-2*n] && Not[IntegerQ[m]] && IntegerQ[2*n]

Integrate[u_*(e_*(a_+b_*x_^n_.)^r_.)^p_*(f_*(c_+d_*x_^n_.)^s_)^q_,x_] := (e*(a+b*x^n)^r)^p*(f*(c+d*x^n)^s)^q/((a+b*x^n)^(p*r)*(c+d*x^n)^(q*s))* Integrate[u*(a+b*x^n)^(p*r)*(c+d*x^n)^(q*s),x] /;
FreeQ[{a,b,c,d,e,f,n,p,q,r,s},x]

Integrate[u_^m_,x_] := Integrate[ExpandToSum[u,x]^m,x] /;
FreeQ[m,x] && LinearQ[u,x] && Not[LinearMatchQ[u,x]]

Integrate[u_^m_*v_^n_.,x_] := Integrate[ExpandToSum[u,x]^m*ExpandToSum[v,x]^n,x] /;
FreeQ[{m,n},x] && LinearQ[{u,v},x] && Not[LinearMatchQ[{u,v},x]]

Integrate[u_^m_*v_^n_*w_^p_.,x_] := Integrate[ExpandToSum[u,x]^m*ExpandToSum[v,x]^n*ExpandToSum[w,x]^p,x] /;
FreeQ[{m,n,p},x] && LinearQ[{u,v,w},x] && Not[LinearMatchQ[{u,v,w},x]]

Integrate[u_^m_*v_^n_*w_^p_*z_^q_.,x_] := Integrate[ExpandToSum[u,x]^m*ExpandToSum[v,x]^n*ExpandToSum[w,x]^p*ExpandToSum[z,x]^q,x] /;
FreeQ[{m,n,p,q},x] && LinearQ[{u,v,w,z},x] && Not[LinearMatchQ[{u,v,w,z},x]]

Integrate[u_^p_,x_] := Integrate[ExpandToSum[u,x]^p,x] /;
FreeQ[p,x] && BinomialQ[u,x] && Not[BinomialMatchQ[u,x]]

Integrate[(c_*x_)^m_*u_^p_.,x_] := Integrate[(c*x)^m*ExpandToSum[u,x]^p,x] /;
FreeQ[{c,m,p},x] && BinomialQ[u,x] && Not[BinomialMatchQ[u,x]]

Integrate[u_^p_*v_^q_.,x_] := Integrate[ExpandToSum[u,x]^p*ExpandToSum[v,x]^q,x] /;
FreeQ[{p,q},x] && BinomialQ[{u,v},x] && EqQ[BinomialDegree[u,x]-BinomialDegree[v,x],0] && Not[BinomialMatchQ[{u,v},x]]

Integrate[(e_*x_)^m_*u_^p_*v_^q_.,x_] := Integrate[(e*x)^m*ExpandToSum[u,x]^p*ExpandToSum[v,x]^q,x] /;
FreeQ[{e,m,p,q},x] && BinomialQ[{u,v},x] && EqQ[BinomialDegree[u,x]-BinomialDegree[v,x],0] && Not[BinomialMatchQ[{u,v},x]]

Integrate[u_^m_*v_^p_*w_^q_.,x_] := Integrate[ExpandToSum[u,x]^m*ExpandToSum[v,x]^p*ExpandToSum[w,x]^q,x] /;
FreeQ[{m,p,q},x] && BinomialQ[{u,v,w},x] && EqQ[BinomialDegree[u,x]-BinomialDegree[v,x],0] && EqQ[BinomialDegree[u,x]-BinomialDegree[w,x],0] && Not[BinomialMatchQ[{u,v,w},x]]

Integrate[(g_*x_)^m_*u_^p_*v_^q_*z_^r_.,x_] := Integrate[(g*x)^m*ExpandToSum[u,x]^p*ExpandToSum[v,x]^q*ExpandToSum[z,x]^r,x] /;
FreeQ[{g,m,p,q,r},x] && BinomialQ[{u,v,z},x] && EqQ[BinomialDegree[u,x]-BinomialDegree[v,x],0] && EqQ[BinomialDegree[u,x]-BinomialDegree[z,x],0] && Not[BinomialMatchQ[{u,v,z},x]]

Integrate[(c_*x_)^m_*Pq_*u_^p_.,x_] := Integrate[(c*x)^m*Pq*ExpandToSum[u,x]^p,x] /;
FreeQ[{c,m,p},x] && PolyQ[Pq,x] && BinomialQ[u,x] && Not[BinomialMatchQ[u,x]]

Integrate[u_^p_,x_] := Integrate[ExpandToSum[u,x]^p,x] /;
FreeQ[p,x] && GeneralizedBinomialQ[u,x] && Not[GeneralizedBinomialMatchQ[u,x]]

Integrate[(c_*x_)^m_*u_^p_.,x_] := Integrate[(c*x)^m*ExpandToSum[u,x]^p,x] /;
FreeQ[{c,m,p},x] && GeneralizedBinomialQ[u,x] && Not[GeneralizedBinomialMatchQ[u,x]]

Integrate[u_^p_,x_] := Integrate[ExpandToSum[u,x]^p,x] /;
FreeQ[p,x] && QuadraticQ[u,x] && Not[QuadraticMatchQ[u,x]]

Integrate[u_^m_*v_^p_.,x_] := Integrate[ExpandToSum[u,x]^m*ExpandToSum[v,x]^p,x] /;
FreeQ[{m,p},x] && LinearQ[u,x] && QuadraticQ[v,x] && Not[LinearMatchQ[u,x] && QuadraticMatchQ[v,x]]

Integrate[u_^m_*v_^n_*w_^p_.,x_] := Integrate[ExpandToSum[u,x]^m*ExpandToSum[v,x]^n*ExpandToSum[w,x]^p,x] /;
FreeQ[{m,n,p},x] && LinearQ[{u,v},x] && QuadraticQ[w,x] && Not[LinearMatchQ[{u,v},x] && QuadraticMatchQ[w,x]]

Integrate[u_^p_*v_^q_.,x_] := Integrate[ExpandToSum[u,x]^p*ExpandToSum[v,x]^q,x] /;
FreeQ[{p,q},x] && QuadraticQ[{u,v},x] && Not[QuadraticMatchQ[{u,v},x]]

Integrate[z_^m_*u_^p_*v_^q_.,x_] := Integrate[ExpandToSum[z,x]^m*ExpandToSum[u,x]^p*ExpandToSum[v,x]^q,x] /;
FreeQ[{m,p,q},x] && LinearQ[z,x] && QuadraticQ[{u,v},x] && Not[LinearMatchQ[z,x] && QuadraticMatchQ[{u,v},x]]

Integrate[Pq_*u_^p_.,x_] := Integrate[Pq*ExpandToSum[u,x]^p,x] /;
FreeQ[p,x] && PolyQ[Pq,x] && QuadraticQ[u,x] && Not[QuadraticMatchQ[u,x]]

Integrate[u_^m_*Pq_*v_^p_.,x_] := Integrate[ExpandToSum[u,x]^m*Pq*ExpandToSum[v,x]^p,x] /;
FreeQ[{m,p},x] && PolyQ[Pq,x] && LinearQ[u,x] && QuadraticQ[v,x] && Not[LinearMatchQ[u,x] && QuadraticMatchQ[v,x]]

Integrate[u_^p_,x_] := Integrate[ExpandToSum[u,x]^p,x] /;
