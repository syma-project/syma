FreeQ[{a,b,c,d,e,f,g,h,m,n},x] && IntegersQ[p,q]

Integrate[(a_.+b_*x_)^m_*(c_.+d_*x_)^n_*(e_.+f_*x_)^p_*(g_.+h_*x_)^q_,x_] := h/b*Integrate[(a+b*x)^(m+1)*(c+d*x)^n*(e+f*x)^p*(g+h*x)^(q-1),x] + (b*g-a*h)/b*Integrate[(a+b*x)^m*(c+d*x)^n*(e+f*x)^p*(g+h*x)^(q-1),x] /;
FreeQ[{a,b,c,d,e,f,g,h,m,n,p},x] && IGtQ[q,0] && (SumSimplerQ[m,1] || Not[SumSimplerQ[n,1]] && Not[SumSimplerQ[p,1]])

Integrate[(a_.+b_*x_)^m_*(c_.+d_*x_)^n_*(e_.+f_*x_)^p_*(g_.+h_*x_)^q_.,x_] := CannotIntegrate[(a+b*x)^m*(c+d*x)^n*(e+f*x)^p*(g+h*x)^q,x] /;
FreeQ[{a,b,c,d,e,f,g,h,m,n,p,q},x]

