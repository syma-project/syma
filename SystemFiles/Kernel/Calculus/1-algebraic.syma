Integrate[(e_+f_*x_^2)/(Sqrt[a_+b_*x_^2]*(c_+d_*x_^2)^(3/2)),x_] := (b*e-a*f)/(b*c-a*d)*Integrate[1/(Sqrt[a+b*x^2]*Sqrt[c+d*x^2]),x] - (d*e-c*f)/(b*c-a*d)*Integrate[Sqrt[a+b*x^2]/(c+d*x^2)^(3/2),x] /;
FreeQ[{a,b,c,d,e,f},x] && PosQ[b/a] && PosQ[d/c]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_*(e_+f_*x_^n_),x_] := -(b*e-a*f)*x*(a+b*x^n)^(p+1)*(c+d*x^n)^q/(a*b*n*(p+1)) + 1/(a*b*n*(p+1))* Integrate[(a+b*x^n)^(p+1)*(c+d*x^n)^(q-1)*Simp[c*(b*e*n*(p+1)+b*e-a*f)+d*(b*e*n*(p+1)+(b*e-a*f)*(n*q+1))*x^n,x],x] /;
FreeQ[{a,b,c,d,e,f,n},x] && LtQ[p,-1] && GtQ[q,0]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_*(e_+f_*x_^n_),x_] := -(b*e-a*f)*x*(a+b*x^n)^(p+1)*(c+d*x^n)^(q+1)/(a*n*(b*c-a*d)*(p+1)) + 1/(a*n*(b*c-a*d)*(p+1))* Integrate[(a+b*x^n)^(p+1)*(c+d*x^n)^q*Simp[c*(b*e-a*f)+e*n*(b*c-a*d)*(p+1)+d*(b*e-a*f)*(n*(p+q+2)+1)*x^n,x],x] /;
FreeQ[{a,b,c,d,e,f,n,q},x] && LtQ[p,-1]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_*(e_+f_*x_^n_),x_] := f*x*(a+b*x^n)^(p+1)*(c+d*x^n)^q/(b*(n*(p+q+1)+1)) + 1/(b*(n*(p+q+1)+1))* Integrate[(a+b*x^n)^p*(c+d*x^n)^(q-1)*Simp[c*(b*e-a*f+b*e*n*(p+q+1))+(d*(b*e-a*f)+f*n*q*(b*c-a*d)+b*d*e*n*(p+q+1))*x^n,x],x] /;
FreeQ[{a,b,c,d,e,f,n,p},x] && GtQ[q,0] && NeQ[n*(p+q+1)+1,0]

Integrate[(e_+f_*x_^4)/((a_+b_*x_^4)^(3/4)*(c_+d_*x_^4)),x_] := (b*e-a*f)/(b*c-a*d)*Integrate[1/(a+b*x^4)^(3/4),x] - (d*e-c*f)/(b*c-a*d)*Integrate[(a+b*x^4)^(1/4)/(c+d*x^4),x] /;
FreeQ[{a,b,c,d,e,f},x]

Integrate[(a_+b_*x_^n_)^p_*(e_+f_*x_^n_)/(c_+d_*x_^n_),x_] := f/d*Integrate[(a+b*x^n)^p,x] + (d*e-c*f)/d*Integrate[(a+b*x^n)^p/(c+d*x^n),x] /;
FreeQ[{a,b,c,d,e,f,p,n},x]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_*(e_+f_*x_^n_),x_] := e*Integrate[(a+b*x^n)^p*(c+d*x^n)^q,x] + f*Integrate[x^n*(a+b*x^n)^p*(c+d*x^n)^q,x] /;
FreeQ[{a,b,c,d,e,f,n,p,q},x]

Integrate[1/((a_+b_*x_^2)*(c_+d_*x_^2)*Sqrt[e_+f_*x_^2]),x_] := b/(b*c-a*d)*Integrate[1/((a+b*x^2)*Sqrt[e+f*x^2]),x] - d/(b*c-a*d)*Integrate[1/((c+d*x^2)*Sqrt[e+f*x^2]),x] /;
FreeQ[{a,b,c,d,e,f},x]

Integrate[1/(x_^2*(c_+d_*x_^2)*Sqrt[e_+f_*x_^2]),x_] := 1/c*Integrate[1/(x^2*Sqrt[e+f*x^2]),x] - d/c*Integrate[1/((c+d*x^2)*Sqrt[e+f*x^2]),x] /;
FreeQ[{c,d,e,f},x] && NeQ[d*e-c*f,0]

Integrate[Sqrt[c_+d_*x_^2]*Sqrt[e_+f_*x_^2]/(a_+b_*x_^2),x_] := d/b*Integrate[Sqrt[e+f*x^2]/Sqrt[c+d*x^2],x] + (b*c-a*d)/b*Integrate[Sqrt[e+f*x^2]/((a+b*x^2)*Sqrt[c+d*x^2]),x] /;
FreeQ[{a,b,c,d,e,f},x] && GtQ[d/c,0] && GtQ[f/e,0] && Not[SimplerSqrtQ[d/c,f/e]]

Integrate[Sqrt[c_+d_*x_^2]*Sqrt[e_+f_*x_^2]/(a_+b_*x_^2),x_] := d/b*Integrate[Sqrt[e+f*x^2]/Sqrt[c+d*x^2],x] + (b*c-a*d)/b*Integrate[Sqrt[e+f*x^2]/((a+b*x^2)*Sqrt[c+d*x^2]),x] /;
FreeQ[{a,b,c,d,e,f},x] && Not[SimplerSqrtQ[-f/e,-d/c]]

Integrate[1/((a_+b_*x_^2)*Sqrt[c_+d_*x_^2]*Sqrt[e_+f_*x_^2]),x_] := -f/(b*e-a*f)*Integrate[1/(Sqrt[c+d*x^2]*Sqrt[e+f*x^2]),x] + b/(b*e-a*f)*Integrate[Sqrt[e+f*x^2]/((a+b*x^2)*Sqrt[c+d*x^2]),x] /;
FreeQ[{a,b,c,d,e,f},x] && GtQ[d/c,0] && GtQ[f/e,0] && Not[SimplerSqrtQ[d/c,f/e]]

Integrate[1/((a_+b_*x_^2)*Sqrt[c_+d_*x_^2]*Sqrt[e_+f_*x_^2]),x_] := 1/(a*Sqrt[c]*Sqrt[e]*Rt[-d/c,2])*EllipticPi[b*c/(a*d), ArcSin[Rt[-d/c,2]*x], c*f/(d*e)] /;
FreeQ[{a,b,c,d,e,f},x] && Not[GtQ[d/c,0]] && GtQ[c,0] && GtQ[e,0] && Not[Not[GtQ[f/e,0]] && SimplerSqrtQ[-f/e,-d/c]]

Integrate[1/((a_+b_*x_^2)*Sqrt[c_+d_*x_^2]*Sqrt[e_+f_*x_^2]),x_] := Sqrt[1+d/c*x^2]/Sqrt[c+d*x^2]*Integrate[1/((a+b*x^2)*Sqrt[1+d/c*x^2]*Sqrt[e+f*x^2]),x] /;
FreeQ[{a,b,c,d,e,f},x] && Not[GtQ[c,0]]

Integrate[Sqrt[c_+d_*x_^2]/((a_+b_*x_^2)*Sqrt[e_+f_*x_^2]),x_] := c*Sqrt[e+f*x^2]/(a*e*Rt[d/c,2]*Sqrt[c+d*x^2]*Sqrt[c*(e+f*x^2)/(e*(c+d*x^2))])*     EllipticPi[1-b*c/(a*d),ArcTan[Rt[d/c,2]*x],1-c*f/(d*e)] /;
FreeQ[{a,b,c,d,e,f},x] && PosQ[d/c] (* Integrate[Sqrt[c_+d_*x_^2]/((a_+b_*x_^2)*Sqrt[e_+f_*x_^2]),x_] := Sqrt[c+d*x^2]*Sqrt[c*(e+f*x^2)/(e*(c+d*x^2))]/(a*Rt[d/c,2]*Sqrt[e+f*x^2])*     EllipticPi[1-b*c/(a*d),ArcTan[Rt[d/c,2]*x],1-c*f/(d*e)] /; FreeQ[{a,b,c,d,e,f},x] && PosQ[d/c] *)

Integrate[Sqrt[c_+d_*x_^2]/((a_+b_*x_^2)*Sqrt[e_+f_*x_^2]),x_] := d/b*Integrate[1/(Sqrt[c+d*x^2]*Sqrt[e+f*x^2]),x] + (b*c-a*d)/b*Integrate[1/((a+b*x^2)*Sqrt[c+d*x^2]*Sqrt[e+f*x^2]),x] /;
FreeQ[{a,b,c,d,e,f},x] && NegQ[d/c]

Integrate[Sqrt[e_+f_*x_^2]/((a_+b_*x_^2)*(c_+d_*x_^2)^(3/2)),x_] := b/(b*c-a*d)*Integrate[Sqrt[e+f*x^2]/((a+b*x^2)*Sqrt[c+d*x^2]),x] - d/(b*c-a*d)*Integrate[Sqrt[e+f*x^2]/(c+d*x^2)^(3/2),x] /;
FreeQ[{a,b,c,d,e,f},x] && PosQ[d/c] && PosQ[f/e]

Integrate[(e_+f_*x_^2)^(3/2)/((a_+b_*x_^2)*(c_+d_*x_^2)^(3/2)),x_] := (b*e-a*f)/(b*c-a*d)*Integrate[Sqrt[e+f*x^2]/((a+b*x^2)*Sqrt[c+d*x^2]),x] - (d*e-c*f)/(b*c-a*d)*Integrate[Sqrt[e+f*x^2]/(c+d*x^2)^(3/2),x] /;
FreeQ[{a,b,c,d,e,f},x] && PosQ[d/c] && PosQ[f/e]

Integrate[(c_+d_*x_^2)^(3/2)*Sqrt[e_+f_*x_^2]/(a_+b_*x_^2),x_] := (b*c-a*d)^2/b^2*Integrate[Sqrt[e+f*x^2]/((a+b*x^2)*Sqrt[c+d*x^2]),x] + d/b^2*Integrate[(2*b*c-a*d+b*d*x^2)*Sqrt[e+f*x^2]/Sqrt[c+d*x^2],x] /;
FreeQ[{a,b,c,d,e,f},x] && PosQ[d/c] && PosQ[f/e]

Integrate[(c_+d_*x_^2)^q_*(e_+f_*x_^2)^r_/(a_+b_*x_^2),x_] := b*(b*e-a*f)/(b*c-a*d)^2*Integrate[(c+d*x^2)^(q+2)*(e+f*x^2)^(r-1)/(a+b*x^2),x] - 1/(b*c-a*d)^2*Integrate[(c+d*x^2)^q*(e+f*x^2)^(r-1)*(2*b*c*d*e-a*d^2*e-b*c^2*f+d^2*(b*e-a*f)*x^2),x] /;
FreeQ[{a,b,c,d,e,f},x] && LtQ[q,-1] && GtQ[r,1]

Integrate[(c_+d_*x_^2)^q_*(e_+f_*x_^2)^r_/(a_+b_*x_^2),x_] := d/b*Integrate[(c+d*x^2)^(q-1)*(e+f*x^2)^r,x] + (b*c-a*d)/b*Integrate[(c+d*x^2)^(q-1)*(e+f*x^2)^r/(a+b*x^2),x] /;
FreeQ[{a,b,c,d,e,f,r},x] && GtQ[q,1]

Integrate[(c_+d_*x_^2)^q_*(e_+f_*x_^2)^r_/(a_+b_*x_^2),x_] := b^2/(b*c-a*d)^2*Integrate[(c+d*x^2)^(q+2)*(e+f*x^2)^r/(a+b*x^2),x] - d/(b*c-a*d)^2*Integrate[(c+d*x^2)^q*(e+f*x^2)^r*(2*b*c-a*d+b*d*x^2),x] /;
FreeQ[{a,b,c,d,e,f,r},x] && LtQ[q,-1]

Integrate[(c_+d_*x_^2)^q_*(e_+f_*x_^2)^r_/(a_+b_*x_^2),x_] := -d/(b*c-a*d)*Integrate[(c+d*x^2)^q*(e+f*x^2)^r,x] + b/(b*c-a*d)*Integrate[(c+d*x^2)^(q+1)*(e+f*x^2)^r/(a+b*x^2),x] /;
FreeQ[{a,b,c,d,e,f,r},x] && LeQ[q,-1]

Integrate[Sqrt[c_+d_*x_^2]*Sqrt[e_+f_*x_^2]/(a_+b_*x_^2)^2,x_] := x*Sqrt[c+d*x^2]*Sqrt[e+f*x^2]/(2*a*(a+b*x^2)) + d*f/(2*a*b^2)*Integrate[(a-b*x^2)/(Sqrt[c+d*x^2]*Sqrt[e+f*x^2]),x] + (b^2*c*e-a^2*d*f)/(2*a*b^2)*Integrate[1/((a+b*x^2)*Sqrt[c+d*x^2]*Sqrt[e+f*x^2]),x] /;
FreeQ[{a,b,c,d,e,f},x]

Integrate[1/((a_+b_*x_^2)^2*Sqrt[c_+d_*x_^2]*Sqrt[e_+f_*x_^2]),x_] := b^2*x*Sqrt[c+d*x^2]*Sqrt[e+f*x^2]/(2*a*(b*c-a*d)*(b*e-a*f)*(a+b*x^2)) - d*f/(2*a*(b*c-a*d)*(b*e-a*f))*Integrate[(a+b*x^2)/(Sqrt[c+d*x^2]*Sqrt[e+f*x^2]),x] + (b^2*c*e+3*a^2*d*f-2*a*b*(d*e+c*f))/(2*a*(b*c-a*d)*(b*e-a*f))*Integrate[1/((a+b*x^2)*Sqrt[c+d*x^2]*Sqrt[e+f*x^2]),x] /;
FreeQ[{a,b,c,d,e,f},x]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_*(e_+f_*x_^n_)^r_,x_] := d/b*Integrate[(a+b*x^n)^(p+1)*(c+d*x^n)^(q-1)*(e+f*x^n)^r,x] + (b*c-a*d)/b*Integrate[(a+b*x^n)^p*(c+d*x^n)^(q-1)*(e+f*x^n)^r,x] /;
FreeQ[{a,b,c,d,e,f,n,r},x] && ILtQ[p,0] && GtQ[q,0]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_*(e_+f_*x_^n_)^r_,x_] := b/(b*c-a*d)*Integrate[(a+b*x^n)^p*(c+d*x^n)^(q+1)*(e+f*x^n)^r,x] - d/(b*c-a*d)*Integrate[(a+b*x^n)^(p+1)*(c+d*x^n)^q*(e+f*x^n)^r,x] /;
FreeQ[{a,b,c,d,e,f,n,q},x] && ILtQ[p,0] && LeQ[q,-1]

Integrate[1/(Sqrt[a_+b_*x_^2]*Sqrt[c_+d_*x_^2]*Sqrt[e_+f_*x_^2]),x_] := Sqrt[c+d*x^2]*Sqrt[a*(e+f*x^2)/(e*(a+b*x^2))]/(c*Sqrt[e+f*x^2]*Sqrt[a*(c+d*x^2)/(c*(a+b*x^2))])* Subst[Integrate[1/(Sqrt[1-(b*c-a*d)*x^2/c]*Sqrt[1-(b*e-a*f)*x^2/e]),x],x,x/Sqrt[a+b*x^2]] /;
FreeQ[{a,b,c,d,e,f},x]

Integrate[Sqrt[a_+b_*x_^2]/(Sqrt[c_+d_*x_^2]*Sqrt[e_+f_*x_^2]),x_] := a*Sqrt[c+d*x^2]*Sqrt[a*(e+f*x^2)/(e*(a+b*x^2))]/(c*Sqrt[e+f*x^2]*Sqrt[a*(c+d*x^2)/(c*(a+b*x^2))])* Subst[Integrate[1/((1-b*x^2)*Sqrt[1-(b*c-a*d)*x^2/c]*Sqrt[1-(b*e-a*f)*x^2/e]),x],x,x/Sqrt[a+b*x^2]] /;
FreeQ[{a,b,c,d,e,f},x]

Integrate[Sqrt[c_+d_*x_^2]/((a_+b_*x_^2)^(3/2)*Sqrt[e_+f_*x_^2]),x_] := Sqrt[c+d*x^2]*Sqrt[a*(e+f*x^2)/(e*(a+b*x^2))]/(a*Sqrt[e+f*x^2]*Sqrt[a*(c+d*x^2)/(c*(a+b*x^2))])*     Subst[Integrate[Sqrt[1-(b*c-a*d)*x^2/c]/Sqrt[1-(b*e-a*f)*x^2/e],x],x,x/Sqrt[a+b*x^2]] /;
FreeQ[{a,b,c,d,e,f},x]

Integrate[Sqrt[a_+b_*x_^2]*Sqrt[c_+d_*x_^2]/Sqrt[e_+f_*x_^2],x_] := d*x*Sqrt[a+b*x^2]*Sqrt[e+f*x^2]/(2*f*Sqrt[c+d*x^2]) -    c*(d*e-c*f)/(2*f)*Integrate[Sqrt[a+b*x^2]/((c+d*x^2)^(3/2)*Sqrt[e+f*x^2]),x] + b*c*(d*e-c*f)/(2*d*f)*Integrate[1/(Sqrt[a+b*x^2]*Sqrt[c+d*x^2]*Sqrt[e+f*x^2]),x] - (b*d*e-b*c*f-a*d*f)/(2*d*f)*Integrate[Sqrt[c+d*x^2]/(Sqrt[a+b*x^2]*Sqrt[e+f*x^2]),x] /;
FreeQ[{a,b,c,d,e,f},x] && PosQ[(d*e-c*f)/c]

Integrate[Sqrt[a_+b_*x_^2]*Sqrt[c_+d_*x_^2]/Sqrt[e_+f_*x_^2],x_] := x*Sqrt[a+b*x^2]*Sqrt[c+d*x^2]/(2*Sqrt[e+f*x^2]) +    e*(b*e-a*f)/(2*f)*Integrate[Sqrt[c+d*x^2]/(Sqrt[a+b*x^2]*(e+f*x^2)^(3/2)),x] +    (b*e-a*f)*(d*e-2*c*f)/(2*f^2)*Integrate[1/(Sqrt[a+b*x^2]*Sqrt[c+d*x^2]*Sqrt[e+f*x^2]),x] -    (b*d*e-b*c*f-a*d*f)/(2*f^2)*Integrate[Sqrt[e+f*x^2]/(Sqrt[a+b*x^2]*Sqrt[c+d*x^2]),x] /;
FreeQ[{a,b,c,d,e,f},x] && NegQ[(d*e-c*f)/c]

Integrate[Sqrt[a_+b_*x_^2]*Sqrt[c_+d_*x_^2]/(e_+f_*x_^2)^(3/2),x_] := b/f*Integrate[Sqrt[c+d*x^2]/(Sqrt[a+b*x^2]*Sqrt[e+f*x^2]),x] - (b*e-a*f)/f*Integrate[Sqrt[c+d*x^2]/(Sqrt[a+b*x^2]*(e+f*x^2)^(3/2)),x] /;
FreeQ[{a,b,c,d,e,f},x]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_*(e_+f_*x_^n_)^r_,x_] := With[{u=ExpandIntegrand[(a+b*x^n)^p*(c+d*x^n)^q*(e+f*x^n)^r,x]}, Integrate[u,x] /; SumQ[u]] /;
FreeQ[{a,b,c,d,e,f,p,q,r},x] && IGtQ[n,0]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_*(e_+f_*x_^n_)^r_,x_] := -Subst[Integrate[(a+b*x^(-n))^p*(c+d*x^(-n))^q*(e+f*x^(-n))^r/x^2,x],x,1/x] /;
FreeQ[{a,b,c,d,e,f,p,q,r},x] && ILtQ[n,0]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_*(e_+f_*x_^n_)^r_.,x_] := Unintegrable[(a+b*x^n)^p*(c+d*x^n)^q*(e+f*x^n)^r,x] /;
FreeQ[{a,b,c,d,e,f,n,p,q,r},x]

Integrate[(a_.+b_*u_^n_)^p_*(c_.+d_*v_^n_)^q_*(e_.+f_*w_^n_)^r_.,x_] := 1/Coefficient[u,x,1]*Subst[Integrate[(a+b*x^n)^p*(c+d*x^n)^q*(e+f*x^n)^r,x],x,u] /;
FreeQ[{a,b,c,d,e,f,p,n,q,r},x] && EqQ[u,v] && EqQ[u,w] && LinearQ[u,x] && NeQ[u,x]

Integrate[(a_.+b_*x_^n_.)^p_*(c_+d_*x_^mn_.)^q_*(e_+f_*x_^n_.)^r_.,x_] := Integrate[(a+b*x^n)^p*(d+c*x^n)^q*(e+f*x^n)^r/x^(n*q),x] /;
FreeQ[{a,b,c,d,e,f,n,p,r},x] && EqQ[mn,-n] && IntegerQ[q]

Integrate[(a_.+b_*x_^n_.)^p_*(c_+d_*x_^mn_.)^q_*(e_+f_*x_^n_.)^r_.,x_] := Integrate[x^(n*(p+r))*(b+a*x^(-n))^p*(c+d*x^(-n))^q*(f+e*x^(-n))^r,x] /;
FreeQ[{a,b,c,d,e,f,n,q},x] && EqQ[mn,-n] && IntegerQ[p] && IntegerQ[r]

Integrate[(a_.+b_*x_^n_.)^p_*(c_+d_*x_^mn_.)^q_*(e_+f_*x_^n_.)^r_.,x_] := x^(n*FracPart[q])*(c+d*x^(-n))^FracPart[q]/(d+c*x^n)^FracPart[q]*Integrate[(a+b*x^n)^p*(d+c*x^n)^q*(e+f*x^n)^r/x^(n*q),x] /;
FreeQ[{a,b,c,d,e,f,n,p,q,r},x] && EqQ[mn,-n] && Not[IntegerQ[q]]

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_*(e1_+f1_*x_^n2_.)^r_*(e2_+f2_*x_^n2_.)^r_.,x_] := Integrate[(a+b*x^n)^p*(c+d*x^n)^q*(e1*e2+f1*f2*x^n)^r,x] /;
FreeQ[{a,b,c,d,e1,f1,e2,f2,n,p,q,r},x] && EqQ[n2,n/2] && EqQ[e2*f1+e1*f2,0] && (IntegerQ[r] || GtQ[e1,0] && GtQ[e2,0])

Integrate[(a_+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_*(e1_+f1_*x_^n2_.)^r_*(e2_+f2_*x_^n2_.)^r_.,x_] := (e1+f1*x^(n/2))^FracPart[r]*(e2+f2*x^(n/2))^FracPart[r]/(e1*e2+f1*f2*x^n)^FracPart[r]* Integrate[(a+b*x^n)^p*(c+d*x^n)^q*(e1*e2+f1*f2*x^n)^r,x] /;
FreeQ[{a,b,c,d,e1,f1,e2,f2,n,p,q,r},x] && EqQ[n2,n/2] && EqQ[e2*f1+e1*f2,0]

Integrate[(g_*x_)^m_*(b_*x_^n_)^p_*(c_+d_*x_^n_)^q_*(e_+f_*x_^n_)^r_.,x_] := g^m/(n*b^(Simplify[(m+1)/n]-1))*Subst[Integrate[(b*x)^(p+Simplify[(m+1)/n]-1)*(c+d*x)^q*(e+f*x)^r,x],x,x^n] /;
