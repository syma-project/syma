FreeQ[{f,j,k,m,n},x] && LinearQ[u,x] && QuadraticQ[{v,w},x] && Not[LinearMatchQ[u,x] && QuadraticMatchQ[{v,w},x] && (EqQ[j,0] || EqQ[f,1])] && EqQ[Coefficient[u,x,1]^2-Coefficient[v,x,2]*f^2*k^2,0]

