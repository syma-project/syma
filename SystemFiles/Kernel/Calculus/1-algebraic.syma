Integrate[1/((c_*x_)^(3/2)*(a_+b_*x_^2)^(1/4)),x_] := -2/(c*Sqrt[c*x]*(a+b*x^2)^(1/4)) - b/c^2*Integrate[Sqrt[c*x]/(a+b*x^2)^(5/4),x] /;
FreeQ[{a,b,c},x] && PosQ[b/a]

Integrate[1/((c_*x_)^(3/2)*(a_+b_*x_^2)^(1/4)),x_] := Sqrt[c*x]*(1+a/(b*x^2))^(1/4)/(c^2*(a+b*x^2)^(1/4))*Integrate[1/(x^2*(1+a/(b*x^2))^(1/4)),x] /;
FreeQ[{a,b,c},x] && NegQ[b/a]

Integrate[Sqrt[x_]/Sqrt[a_+b_*x_^2],x_] := -2/(Sqrt[a]*(-b/a)^(3/4))*Subst[Integrate[Sqrt[1-2*x^2]/Sqrt[1-x^2],x],x,Sqrt[1-Sqrt[-b/a]*x]/Sqrt[2]] /;
