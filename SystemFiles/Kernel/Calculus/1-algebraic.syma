Integrate[x_^m_/(a_+b_*x_^n_),x_] := With[{r=Numerator[Rt[-a/b,2]], s=Denominator[Rt[-a/b,2]]}, s/(2*b)*Integrate[x^(m-n/2)/(r+s*x^(n/2)),x] - s/(2*b)*Integrate[x^(m-n/2)/(r-s*x^(n/2)),x]] /;
FreeQ[{a,b},x] && IGtQ[n/4,0] && IGtQ[m,0] && LeQ[n/2,m] && LtQ[m,n] && Not[GtQ[a/b,0]]

