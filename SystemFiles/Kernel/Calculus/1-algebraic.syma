Integrate[P4_^p_,x_] := With[{a=Coeff[P4,x,0],b=Coeff[P4,x,1],c=Coeff[P4,x,2],d=Coeff[P4,x,3],e=Coeff[P4,x,4]}, Subst[Integrate[SimplifyIntegrand[(a+d^4/(256*e^3)-b*d/(8*e)+(c-3*d^2/(8*e))*x^2+e*x^4)^p,x],x],x,d/(4*e)+x] /; EqQ[d^3-4*c*d*e+8*b*e^2,0] && NeQ[d,0]] /;
