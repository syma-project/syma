Integrate[(c_*x_)^m_*(a_+b_*x_^n_)^p_,x_] := c^(n-1)*(c*x)^(m-n+1)*(a+b*x^n)^(p+1)/(b*(m+n*p+1)) - a*c^n*(m-n+1)/(b*(m+n*p+1))*Integrate[(c*x)^(m-n)*(a+b*x^n)^p,x] /;
FreeQ[{a,b,c,p},x] && IGtQ[n,0] && GtQ[m,n-1] && NeQ[m+n*p+1,0] && IntBinomialQ[a,b,c,n,m,p,x]

