Integrate[(e_.+f_*x_)^m_*(a_+b_*x_+d_*x_^3)^p_,x_] := (a+b*x+d*x^3)^p/((3*a-b*x)^p*(3*a+2*b*x)^(2*p))*Integrate[(e+f*x)^m*(3*a-b*x)^p*(3*a+2*b*x)^(2*p),x] /;
FreeQ[{a,b,d,e,f,m,p},x] && EqQ[4*b^3+27*a^2*d,0] && Not[IntegerQ[p]]

Integrate[(e_.+f_*x_)^m_*(a_+b_*x_+d_*x_^3)^p_.,x_] := Integrate[ExpandIntegrand[(e+f*x)^m*(a+b*x+d*x^3)^p,x],x] /;
FreeQ[{a,b,d,e,f,m},x] && NeQ[4*b^3+27*a^2*d,0] && IGtQ[p,0]

Integrate[(e_.+f_*x_)^m_*(a_+b_*x_+d_*x_^3)^p_,x_] := With[{r=Rt[-9*a*d^2+Sqrt[3]*d*Sqrt[4*b^3*d+27*a^2*d^2],3]}, 1/d^(2*p)*Integrate[(e+f*x)^m*Simp[18^(1/3)*b*d/(3*r)-r/18^(1/3)+d*x,x]^p* Simp[b*d/3+12^(1/3)*b^2*d^2/(3*r^2)+r^2/(3*12^(1/3))-d*(2^(1/3)*b*d/(3^(1/3)*r)-r/18^(1/3))*x+d^2*x^2,x]^p,x]] /;
FreeQ[{a,b,d,e,f,m},x] && NeQ[4*b^3+27*a^2*d,0] && ILtQ[p,0]

Integrate[(e_.+f_*x_)^m_*(a_+b_*x_+d_*x_^3)^p_,x_] := With[{r=Rt[-9*a*d^2+Sqrt[3]*d*Sqrt[4*b^3*d+27*a^2*d^2],3]}, (a+b*x+d*x^3)^p/ (Simp[18^(1/3)*b*d/(3*r)-r/18^(1/3)+d*x,x]^p* Simp[b*d/3+12^(1/3)*b^2*d^2/(3*r^2)+r^2/(3*12^(1/3))-d*(2^(1/3)*b*d/(3^(1/3)*r)-r/18^(1/3))*x+d^2*x^2,x]^p)* Integrate[(e+f*x)^m*Simp[18^(1/3)*b*d/(3*r)-r/18^(1/3)+d*x,x]^p* Simp[b*d/3+12^(1/3)*b^2*d^2/(3*r^2)+r^2/(3*12^(1/3))-d*(2^(1/3)*b*d/(3^(1/3)*r)-r/18^(1/3))*x+d^2*x^2,x]^p,x]] /;
FreeQ[{a,b,d,e,f,m,p},x] && NeQ[4*b^3+27*a^2*d,0] && Not[IntegerQ[p]]

Integrate[(e_.+f_*x_)^m_*P3_^p_.,x_] := With[{a=Coeff[P3,x,0],b=Coeff[P3,x,1],c=Coeff[P3,x,2],d=Coeff[P3,x,3]}, Subst[Integrate[((3*d*e-c*f)/(3*d)+f*x)^m*Simp[(2*c^3-9*b*c*d+27*a*d^2)/(27*d^2)-(c^2-3*b*d)*x/(3*d)+d*x^3,x]^p,x],x,x+c/(3*d)] /; NeQ[c,0]] /;
FreeQ[{e,f,m,p},x] && PolyQ[P3,x,3]

Integrate[x_/Sqrt[a_+b_*x_+c_*x_^2+e_*x_^4],x_] := With[{Px=1/320*(33*b^2*c+6*a*c^2+40*a^2*e)-22/5*a*c*e*x^2+22/15*b*c*e*x^3+1/4*e*(5*c^2+4*a*e)*x^4+ 4/3*b*e^2*x^5+2*c*e^2*x^6+e^3*x^8}, 1/(8*Rt[e,2])*Log[Px+Dist[1/(8*Rt[e,2]*x),D[Px,x],x]*Sqrt[a+b*x+c*x^2+e*x^4]]] /;
FreeQ[{a,b,c,e},x] && EqQ[71*c^2+100*a*e,0] && EqQ[1152*c^3-125*b^2*e,0]

Integrate[(A_+B_*x_)/Sqrt[a_+b_*x_+c_*x_^2+d_*x_^3+e_*x_^4],x_] := B*Subst[Integrate[x/Sqrt[(-3*d^4+16*c*d^2*e-64*b*d*e^2+256*a*e^3)/(256*e^3)+(d^3-4*c*d*e+8*b*e^2)*x/(8*e^2)- (3*d^2-8*c*e)*x^2/(8*e)+e*x^4],x],x,d/(4*e)+x] /;
FreeQ[{a,b,c,d,e,A,B},x] && EqQ[B*d-4*A*e,0] && EqQ[d*(141*d^3-752*c*d*e-400*b*e^2)+16*e^2*(71*c^2+100*a*e),0] && EqQ[144*(3*d^2-8*c*e)^3+125*(d^3-4*c*d*e+8*b*e^2)^2,0]

Integrate[(f_+g_*x_^2)/((d_+e_*x_+d_*x_^2)*Sqrt[a_+b_*x_+c_*x_^2+b_*x_^3+a_*x_^4]),x_] := a*f/(d*Rt[a^2*(2*a-c),2])*ArcTan[(a*b+(4*a^2+b^2-2*a*c)*x+a*b*x^2)/(2*Rt[a^2*(2*a-c),2]*Sqrt[a+b*x+c*x^2+b*x^3+a*x^4])] /;
FreeQ[{a,b,c,d,e,f,g},x] && EqQ[b*d-a*e,0] && EqQ[f+g,0] && PosQ[a^2*(2*a-c)]

Integrate[(f_+g_*x_^2)/((d_+e_*x_+d_*x_^2)*Sqrt[a_+b_*x_+c_*x_^2+b_*x_^3+a_*x_^4]),x_] := -a*f/(d*Rt[-a^2*(2*a-c),2])*ArcTanh[(a*b+(4*a^2+b^2-2*a*c)*x+a*b*x^2)/(2*Rt[-a^2*(2*a-c),2]*Sqrt[a+b*x+c*x^2+b*x^3+a*x^4])] /;
FreeQ[{a,b,c,d,e,f,g},x] && EqQ[b*d-a*e,0] && EqQ[f+g,0] && NegQ[a^2*(2*a-c)]

Integrate[P3_/(a_+b_*x_+c_*x_^2+d_*x_^3+e_*x_^4),x_] := With[{q=Sqrt[8*a^2+b^2-4*a*c],A=Coeff[P3,x,0],B=Coeff[P3,x,1],C=Coeff[P3,x,2],D=Coeff[P3,x,3]}, 1/q*Integrate[(b*A-2*a*B+2*a*D+A*q+(2*a*A-2*a*C+b*D+D*q)*x)/(2*a+(b+q)*x+2*a*x^2),x] - 1/q*Integrate[(b*A-2*a*B+2*a*D-A*q+(2*a*A-2*a*C+b*D-D*q)*x)/(2*a+(b-q)*x+2*a*x^2),x]] /;
FreeQ[{a,b,c},x] && PolyQ[P3,x,3] && EqQ[a,e] && EqQ[b,d]

Integrate[x_^m_*P3_/(a_+b_*x_+c_*x_^2+d_*x_^3+e_*x_^4),x_] := With[{q=Sqrt[8*a^2+b^2-4*a*c],A=Coeff[P3,x,0],B=Coeff[P3,x,1],C=Coeff[P3,x,2],D=Coeff[P3,x,3]}, 1/q*Integrate[x^m*(b*A-2*a*B+2*a*D+A*q+(2*a*A-2*a*C+b*D+D*q)*x)/(2*a+(b+q)*x+2*a*x^2),x] - 1/q*Integrate[x^m*(b*A-2*a*B+2*a*D-A*q+(2*a*A-2*a*C+b*D-D*q)*x)/(2*a+(b-q)*x+2*a*x^2),x]] /;
FreeQ[{a,b,c,m},x] && PolyQ[P3,x,3] && EqQ[a,e] && EqQ[b,d]

Integrate[(A_.+B_*x_+C_*x_^2)/(a_+b_*x_+c_*x_^2+d_*x_^3+e_*x_^4),x_] := With[{q=Rt[C*(2*e*(B*d-4*A*e)+C*(d^2-4*c*e)),2]}, -2*C^2/q*ArcTanh[(C*d-B*e+2*C*e*x)/q] + 2*C^2/q*ArcTanh[C*(4*B*c*C-3*B^2*d-4*A*C*d+12*A*B*e+4*C*(2*c*C-B*d+2*A*e)*x+4*C*(2*C*d-B*e)*x^2+8*C^2*e*x^3)/(q*(B^2-4*A*C))]] /;
FreeQ[{a,b,c,d,e,A,B,C},x] && EqQ[B^2*d+2*C*(b*C+A*d)-2*B*(c*C+2*A*e),0] && EqQ[2*B^2*c*C-8*a*C^3-B^3*d-4*A*B*C*d+4*A*(B^2+2*A*C)*e,0] && PosQ[C*(2*e*(B*d-4*A*e)+C*(d^2-4*c*e))]

Integrate[(A_.+C_*x_^2)/(a_+b_*x_+c_*x_^2+d_*x_^3+e_*x_^4),x_] := With[{q=Rt[C*(-8*A*e^2+C*(d^2-4*c*e)),2]}, -2*C^2/q*ArcTanh[C*(d+2*e*x)/q] + 2*C^2/q*ArcTanh[C*(A*d-2*(c*C+A*e)*x-2*C*d*x^2-2*C*e*x^3)/(A*q)]] /;
FreeQ[{a,b,c,d,e,A,C},x] && EqQ[b*C+A*d,0] && EqQ[a*C^2-A^2*e,0] && PosQ[C*(-8*A*e^2+C*(d^2-4*c*e))]

Integrate[(A_.+B_*x_+C_*x_^2)/(a_+b_*x_+c_*x_^2+d_*x_^3+e_*x_^4),x_] := With[{q=Rt[-C*(2*e*(B*d-4*A*e)+C*(d^2-4*c*e)),2]}, 2*C^2/q*ArcTan[(C*d-B*e+2*C*e*x)/q] - 2*C^2/q*ArcTan[C*(4*B*c*C-3*B^2*d-4*A*C*d+12*A*B*e+4*C*(2*c*C-B*d+2*A*e)*x+4*C*(2*C*d-B*e)*x^2+8*C^2*e*x^3)/(q*(B^2-4*A*C))]] /;
FreeQ[{a,b,c,d,e,A,B,C},x] && EqQ[B^2*d+2*C*(b*C+A*d)-2*B*(c*C+2*A*e),0] && EqQ[2*B^2*c*C-8*a*C^3-B^3*d-4*A*B*C*d+4*A*(B^2+2*A*C)*e,0] && NegQ[C*(2*e*(B*d-4*A*e)+C*(d^2-4*c*e))]

Integrate[(A_.+C_*x_^2)/(a_+b_*x_+c_*x_^2+d_*x_^3+e_*x_^4),x_] := With[{q=Rt[-C*(-8*A*e^2+C*(d^2-4*c*e)),2]}, 2*C^2/q*ArcTan[(C*d+2*C*e*x)/q] - 2*C^2/q*ArcTan[-C*(-A*d+2*(c*C+A*e)*x+2*C*d*x^2+2*C*e*x^3)/(A*q)]] /;
FreeQ[{a,b,c,d,e,A,C},x] && EqQ[b*C+A*d,0] && EqQ[a*C^2-A^2*e,0] && NegQ[C*(-8*A*e^2+C*(d^2-4*c*e))]

Integrate[Px_*P4_^p_,x_] := With[{a=Coeff[P4,x,0],b=Coeff[P4,x,1],c=Coeff[P4,x,2],d=Coeff[P4,x,3],e=Coeff[P4,x,4]}, 1/a^(3*p)*Integrate[ExpandIntegrand[Px*(a-b*x)^(-p)/(a^5-b^5*x^5)^(-p),x],x] /; NeQ[a,0] && EqQ[c,b^2/a] && EqQ[d,b^3/a^2] && EqQ[e,b^4/a^3]] /;
FreeQ[p,x] && PolyQ[P4,x,4] && PolyQ[Px,x] && ILtQ[p,0]

Integrate[(A_+B_*x_^n_)/(a_+b_*x_^2+c_*x_^n_+d_*x_^n2_), x_] := A^2*(n-1)*Subst[Integrate[1/(a+A^2*b*(n-1)^2*x^2),x],x,x/(A*(n-1)-B*x^n)] /;
FreeQ[{a,b,c,d,A,B,n},x] && EqQ[n2,2*n] && NeQ[n,2] && EqQ[a*B^2-A^2*d*(n-1)^2,0] && EqQ[B*c+2*A*d*(n-1),0]

Integrate[x_^m_*(A_+B_*x_^n_.)/(a_+b_*x_^k_.+c_*x_^n_.+d_*x_^n2_), x_] := A^2*(m-n+1)/(m+1)*Subst[Integrate[1/(a+A^2*b*(m-n+1)^2*x^2),x],x,x^(m+1)/(A*(m-n+1)+B*(m+1)*x^n)] /;
FreeQ[{a,b,c,d,A,B,m,n},x] && EqQ[n2,2*n] && EqQ[k,2*(m+1)] && EqQ[a*B^2*(m+1)^2-A^2*d*(m-n+1)^2,0] && EqQ[B*c*(m+1)-2*A*d*(m-n+1),0]

Integrate[(a_+b_*x_^2+c_*x_^4)/(d_+e_*x_^2+f_*x_^4+g_*x_^6),x_] := With[{q=Rt[(-a*c*f^2+12*a^2*g^2+f*(3*c^2*d-2*a*b*g))/(c*g*(3*c*d-a*f)),2], r=Rt[(a*c*f^2+4*g*(b*c*d+a^2*g)-f*(3*c^2*d+2*a*b*g))/(c*g*(3*c*d-a*f)),2]}, c/(g*q)*ArcTan[(r+2*x)/q] -    c/(g*q)*ArcTan[(r-2*x)/q] - c/(g*q)*ArcTan[(3*c*d-a*f)*x/(g*q*(b*c*d-2*a^2*g)*(b*c*d-a*b*f+4*a^2*g))* (b*c^2*d*f-a*b^2*f*g-2*a^2*c*f*g+6*a^2*b*g^2+c*(3*c^2*d*f-a*c*f^2-b*c*d*g+2*a^2*g^2)*x^2+c^2*g*(3*c*d-a*f)*x^4)]] /;
FreeQ[{a,b,c,d,e,f,g},x] && EqQ[9*c^3*d^2-c*(b^2+6*a*c)*d*f+a^2*c*f^2+2*a*b*(3*c*d+a*f)*g-12*a^3*g^2,0] && EqQ[3*c^4*d^2*e-3*a^2*c^2*d*f*g+a^3*c*f^2*g+2*a^3*g^2*(b*f-6*a*g)-c^3*d*(2*b*d*f+a*e*f-12*a*d*g),0] && NeQ[3*c*d-a*f,0] && NeQ[b*c*d-2*a^2*g,0] && NeQ[b*c*d-a*b*f+4*a^2*g,0] && PosQ[(-a*c*f^2+12*a^2*g^2+f*(3*c^2*d-2*a*b*g))/(c*g*(3*c*d-a*f))]

Integrate[(a_+c_*x_^4)/(d_+e_*x_^2+f_*x_^4+g_*x_^6),x_] := With[{q=Rt[(-a*c*f^2+12*a^2*g^2+3*f*c^2*d)/(c*g*(3*c*d-a*f)),2], r=Rt[(a*c*f^2+4*a^2*g^2-3*c^2*d*f)/(c*g*(3*c*d-a*f)),2]}, c/(g*q)*ArcTan[(r+2*x)/q] -    c/(g*q)*ArcTan[(r-2*x)/q] - c/(g*q)*ArcTan[(c*(3*c*d-a*f)*x*(2*a^2*f*g-(3*c^2*d*f-a*c*f^2+2*a^2*g^2)*x^2-c*(3*c*d-a*f)*g*x^4))/(8*a^4*g^3*q)]] /;
FreeQ[{a,c,d,e,f,g},x] && EqQ[9*c^3*d^2-6*a*c^2*d*f+a^2*c*f^2-12*a^3*g^2,0] && EqQ[3*c^4*d^2*e-3*a^2*c^2*d*f*g+a^3*c*f^2*g-12*a^4*g^3-a*c^3*d*(e*f-12*d*g),0] && NeQ[3*c*d-a*f,0] && PosQ[(-a*c*f^2+12*a^2*g^2+3*c^2*d*f)/(c*g*(3*c*d-a*f))]

Integrate[u_*Q6_^p_,x_] := With[{a=Coeff[Q6,x,0],b=Coeff[Q6,x,2],c=Coeff[Q6,x,3],d=Coeff[Q6,x,4],e=Coeff[Q6,x,6]}, 1/(3^(3*p)*a^(2*p))*Integrate[ExpandIntegrand[u* (3*a+3*Rt[a,3]^2*Rt[c,3]*x+b*x^2)^p* (3*a-3*(-1)^(1/3)*Rt[a,3]^2*Rt[c,3]*x+b*x^2)^p* (3*a+3*(-1)^(2/3)*Rt[a,3]^2*Rt[c,3]*x+b*x^2)^p,x],x] /; EqQ[b^2-3*a*d,0] && EqQ[b^3-27*a^2*e,0]] /;
ILtQ[p,0] && PolyQ[Q6,x,6] && EqQ[Coeff[Q6,x,1],0] && EqQ[Coeff[Q6,x,5],0] && RationalFunctionQ[u,x]

Integrate[Pm_/Qn_,x_] := With[{m=Expon[Pm,x],n=Expon[Qn,x]}, Coeff[Pm,x,m]*Log[Qn]/(n*Coeff[Qn,x,n]) + Simplify[Pm-Coeff[Pm,x,m]*D[Qn,x]/(n*Coeff[Qn,x,n])]*Integrate[1/Qn,x]/; EqQ[m,n-1] && EqQ[D[Simplify[Pm-Coeff[Pm,x,m]/(n*Coeff[Qn,x,n])*D[Qn,x]],x],0]] /;
PolyQ[Pm,x] && PolyQ[Qn,x]

Integrate[Pm_*Qn_^p_,x_] := With[{m=Expon[Pm,x],n=Expon[Qn,x]}, Coeff[Pm,x,m]*Qn^(p+1)/(n*(p+1)*Coeff[Qn,x,n]) + Simplify[Pm-Coeff[Pm,x,m]*D[Qn,x]/(n*Coeff[Qn,x,n])]*Integrate[Qn^p,x]/; EqQ[m,n-1] && EqQ[D[Simplify[Pm-Coeff[Pm,x,m]/(n*Coeff[Qn,x,n])*D[Qn,x]],x],0]] /;
FreeQ[p,x] && PolyQ[Pm,x] && PolyQ[Qn,x] && NeQ[p,-1]

Integrate[Pm_/Qn_,x_] := With[{m=Expon[Pm,x],n=Expon[Qn,x]}, Coeff[Pm,x,m]*Log[Qn]/(n*Coeff[Qn,x,n]) + 1/(n*Coeff[Qn,x,n])Integrate[ExpandToSum[n*Coeff[Qn,x,n]*Pm-Coeff[Pm,x,m]*D[Qn,x],x]/Qn,x]/; EqQ[m,n-1]] /;
PolyQ[Pm,x] && PolyQ[Qn,x]

Integrate[Pm_*Qn_^p_,x_] := With[{m=Expon[Pm,x],n=Expon[Qn,x]}, Coeff[Pm,x,m]*Qn^(p+1)/(n*(p+1)*Coeff[Qn,x,n]) + 1/(n*Coeff[Qn,x,n])*Integrate[ExpandToSum[n*Coeff[Qn,x,n]*Pm-Coeff[Pm,x,m]*D[Qn,x],x]*Qn^p,x]/; EqQ[m,n-1]] /;
FreeQ[p,x] && PolyQ[Pm,x] && PolyQ[Qn,x] && NeQ[p,-1]

Integrate[Pm_*Qn_^p_.,x_] := With[{m=Expon[Pm,x],n=Expon[Qn,x]}, Coeff[Pm,x,m]*x^(m-n+1)*Qn^(p+1)/((m+n*p+1)*Coeff[Qn,x,n]) + 1/((m+n*p+1)*Coeff[Qn,x,n])* Integrate[ExpandToSum[(m+n*p+1)*Coeff[Qn,x,n]*Pm-Coeff[Pm,x,m]*x^(m-n)*((m-n+1)*Qn+(p+1)*x*D[Qn,x]),x]*Qn^p,x] /; LtQ[1,n,m+1] && m+n*p+1<0] /;
FreeQ[p,x] && PolyQ[Pm,x] && PolyQ[Qn,x] && LtQ[p,-1]

Integrate[u_/(e_*Sqrt[a_.+b_*x_]+f_*Sqrt[c_.+d_*x_]),x_] := c/(e*(b*c-a*d))*Integrate[(u*Sqrt[a+b*x])/x,x] - a/(f*(b*c-a*d))*Integrate[(u*Sqrt[c+d*x])/x,x] /;
FreeQ[{a,b,c,d,e,f},x] && NeQ[b*c-a*d,0] && EqQ[a*e^2-c*f^2,0]

Integrate[u_/(e_*Sqrt[a_.+b_*x_]+f_*Sqrt[c_.+d_*x_]),x_] := -d/(e*(b*c-a*d))*Integrate[u*Sqrt[a+b*x],x] + b/(f*(b*c-a*d))*Integrate[u*Sqrt[c+d*x],x] /;
FreeQ[{a,b,c,d,e,f},x] && NeQ[b*c-a*d,0] && EqQ[b*e^2-d*f^2,0]

Integrate[u_/(e_*Sqrt[a_.+b_*x_]+f_*Sqrt[c_.+d_*x_]),x_] := e*Integrate[(u*Sqrt[a+b*x])/(a*e^2-c*f^2+(b*e^2-d*f^2)*x),x] - f*Integrate[(u*Sqrt[c+d*x])/(a*e^2-c*f^2+(b*e^2-d*f^2)*x),x] /;
FreeQ[{a,b,c,d,e,f},x] && NeQ[a*e^2-c*f^2,0] && NeQ[b*e^2-d*f^2,0]

Integrate[u_./(d_*x_^n_.+c_*Sqrt[a_.+b_*x_^p_.]),x_] := -b/(a*d)*Integrate[u*x^n,x] + 1/(a*c)*Integrate[u*Sqrt[a+b*x^(2*n)],x] /;
FreeQ[{a,b,c,d,n},x] && EqQ[p,2*n] && EqQ[b*c^2-d^2,0]

Integrate[x_^m_./(d_*x_^n_.+c_*Sqrt[a_.+b_*x_^p_.]),x_] := -d*Integrate[x^(m+n)/(a*c^2+(b*c^2-d^2)*x^(2*n)),x] + c*Integrate[(x^m*Sqrt[a+b*x^(2*n)])/(a*c^2+(b*c^2-d^2)*x^(2*n)),x] /;
FreeQ[{a,b,c,d,m,n},x] && EqQ[p,2*n] && NeQ[b*c^2-d^2,0]

Integrate[1/((a_+b_*x_^3)*Sqrt[d_.+e_*x_+f_*x_^2]),x_] := With[{r=Numerator[Rt[a/b,3]], s=Denominator[Rt[a/b,3]]}, r/(3*a)*Integrate[1/((r+s*x)*Sqrt[d+e*x+f*x^2]),x] + r/(3*a)*Integrate[(2*r-s*x)/((r^2-r*s*x+s^2*x^2)*Sqrt[d+e*x+f*x^2]),x]] /;
FreeQ[{a,b,d,e,f},x] && PosQ[a/b]

Integrate[1/((a_+b_*x_^3)*Sqrt[d_.+f_*x_^2]),x_] := With[{r=Numerator[Rt[a/b,3]], s=Denominator[Rt[a/b,3]]}, r/(3*a)*Integrate[1/((r+s*x)*Sqrt[d+f*x^2]),x] + r/(3*a)*Integrate[(2*r-s*x)/((r^2-r*s*x+s^2*x^2)*Sqrt[d+f*x^2]),x]] /;
FreeQ[{a,b,d,f},x] && PosQ[a/b]

Integrate[1/((a_+b_*x_^3)*Sqrt[d_.+e_*x_+f_*x_^2]),x_] := With[{r=Numerator[Rt[-a/b,3]], s=Denominator[Rt[-a/b,3]]}, r/(3*a)*Integrate[1/((r-s*x)*Sqrt[d+e*x+f*x^2]),x] + r/(3*a)*Integrate[(2*r+s*x)/((r^2+r*s*x+s^2*x^2)*Sqrt[d+e*x+f*x^2]),x]] /;
FreeQ[{a,b,d,e,f},x] && NegQ[a/b]

Integrate[1/((a_+b_*x_^3)*Sqrt[d_.+f_*x_^2]),x_] := With[{r=Numerator[Rt[-a/b,3]], s=Denominator[Rt[-a/b,3]]}, r/(3*a)*Integrate[1/((r-s*x)*Sqrt[d+f*x^2]),x] + r/(3*a)*Integrate[(2*r+s*x)/((r^2+r*s*x+s^2*x^2)*Sqrt[d+f*x^2]),x]] /;
FreeQ[{a,b,d,f},x] && NegQ[a/b]

Integrate[u_*(A_+B_*x_^4)/Sqrt[v_],x_] := With[{a=Coeff[v,x,0],b=Coeff[v,x,2],c=Coeff[v,x,4],d=Coeff[1/u,x,0],e=Coeff[1/u,x,2],f=Coeff[1/u,x,4]}, A*Subst[Integrate[1/(d-(b*d-a*e)*x^2),x],x,x/Sqrt[v]] /; EqQ[a*B+A*c,0] && EqQ[c*d-a*f,0]] /;
FreeQ[{A,B},x] && PolyQ[v,x^2,2] && PolyQ[1/u,x^2,2]

Integrate[1/((a_+b_*x_)*Sqrt[c_+d_*x_^2]*Sqrt[e_+f_*x_^2]),x_] := a*Integrate[1/((a^2-b^2*x^2)*Sqrt[c+d*x^2]*Sqrt[e+f*x^2]),x] - b*Integrate[x/((a^2-b^2*x^2)*Sqrt[c+d*x^2]*Sqrt[e+f*x^2]),x] /;
FreeQ[{a,b,c,d,e,f},x]

Integrate[(g_.+h_*x_)*Sqrt[d_.+e_*x_+f_*Sqrt[a_.+b_*x_+c_*x_^2]],x_] := 2*(f*(5*b*c*g^2-2*b^2*g*h-3*a*c*g*h+2*a*b*h^2)+c*f*(10*c*g^2-b*g*h+a*h^2)*x+9*c^2*f*g*h*x^2+3*c^2*f*h^2*x^3- (e*g-d*h)*(5*c*g-2*b*h+c*h*x)*Sqrt[a+b*x+c*x^2])/   (15*c^2*f*(g+h*x))*Sqrt[d+e*x+f*Sqrt[a+b*x+c*x^2]] /;
FreeQ[{a,b,c,d,e,f,g,h},x] && EqQ[(e*g-d*h)^2-f^2*(c*g^2-b*g*h+a*h^2),0] && EqQ[2*e^2*g-2*d*e*h-f^2*(2*c*g-b*h),0]

Integrate[(g_.+h_*x_)^m_*(u_+f_*(j_.+k_*Sqrt[v_]))^n_.,x_] := Integrate[(g+h*x)^m*(ExpandToSum[u+f*j,x]+f*k*Sqrt[ExpandToSum[v,x]])^n,x] /;
FreeQ[{f,g,h,j,k,m,n},x] && LinearQ[u,x] && QuadraticQ[v,x] && Not[LinearMatchQ[u,x] && QuadraticMatchQ[v,x] && (EqQ[j,0] || EqQ[f,1])] && EqQ[(Coefficient[u,x,1]*g-h*(Coefficient[u,x,0]+f*j))^2-f^2*k^2*(Coefficient[v,x,2]*g^2-Coefficient[v,x,1]*g*h+Coefficient[v,x,0]*h^2),0] (* Integrate[1/(d_.+e_*x_+f_*Sqrt[a_.+b_*x_+c_*x_^2]),x_] := Integrate[(d+e*x)/(d^2-a*f^2+(2*d*e-b*f^2)*x),x] - f*Integrate[Sqrt[a+b*x+c*x^2]/(d^2-a*f^2+(2*d*e-b*f^2)*x),x] /; FreeQ[{a,b,c,d,e,f},x] && EqQ[e^2-c*f^2,0] *) (* Integrate[1/(d_.+e_*x_+f_*Sqrt[a_.+c_*x_^2]),x_] := Integrate[(d+e*x)/(d^2-a*f^2+2*d*e*x),x] - f*Integrate[Sqrt[a+c*x^2]/(d^2-a*f^2+2*d*e*x),x] /; FreeQ[{a,c,d,e,f},x] && EqQ[e^2-c*f^2,0] *)

