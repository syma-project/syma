FreeQ[{a,b,c,d,e,f,g,h},x] && NeQ[b^2-4*a*c,0] && NeQ[e^2-4*d*f,0] && IGtQ[p,0] && IntegerQ[q]

Integrate[(a_+c_*x_^2)^p_*(d_+e_*x_+f_*x_^2)^q_*(g_.+h_*x_),x_] := Integrate[ExpandIntegrand[(a+c*x^2)^p*(d+e*x+f*x^2)^q*(g+h*x),x],x] /;
FreeQ[{a,c,d,e,f,g,h},x] && NeQ[e^2-4*d*f,0] && IntegersQ[p,q] && (GtQ[p,0] || GtQ[q,0])

Integrate[(a_+b_*x_+c_*x_^2)^p_*(d_+e_*x_+f_*x_^2)^q_*(g_.+h_*x_),x_] := (g*b-2*a*h-(b*h-2*g*c)*x)*(a+b*x+c*x^2)^(p+1)*(d+e*x+f*x^2)^q/((b^2-4*a*c)*(p+1)) -    1/((b^2-4*a*c)*(p+1))* Integrate[(a+b*x+c*x^2)^(p+1)*(d+e*x+f*x^2)^(q-1)* Simp[e*q*(g*b-2*a*h)-d*(b*h-2*g*c)*(2*p+3)+ (2*f*q*(g*b-2*a*h)-e*(b*h-2*g*c)*(2*p+q+3))*x- f*(b*h-2*g*c)*(2*p+2*q+3)*x^2,x],x] /;
