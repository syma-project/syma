FreeQ[{a,b,c,m,p},x] && PolyQ[Pq,x] && FractionQ[n]

Integrate[x_^m_*Pq_*(a_+b_*x_^n_)^p_,x_] := 1/(m+1)*Subst[Integrate[ReplaceAll[SubstFor[x^n,Pq,x],xRulex^Simplify[n/(m+1)]]*(a+b*x^Simplify[n/(m+1)])^p,x],x,x^(m+1)] /;
FreeQ[{a,b,m,n,p},x] && PolyQ[Pq,x^n] && IntegerQ[Simplify[n/(m+1)]] && Not[IntegerQ[n]]

Integrate[(c_*x_)^m_*Pq_*(a_+b_*x_^n_)^p_,x_] := c^IntPart[m]*(c*x)^FracPart[m]/x^FracPart[m]*Integrate[x^m*Pq*(a+b*x^n)^p,x] /;
FreeQ[{a,b,c,m,n,p},x] && PolyQ[Pq,x^n] && IntegerQ[Simplify[n/(m+1)]] && Not[IntegerQ[n]]

