Integrate[(e_+f_*x_^n_.+g_*x_^n2_.)*(a_+b_*x_^n_.)^p_*(c_+d_*x_^n_.)^p_.,x_] := e*x*(a+b*x^n)^(p+1)*(c+d*x^n)^(p+1)/(a*c) /;
FreeQ[{a,b,c,d,e,f,g,n,p},x] && EqQ[n2,2*n] && EqQ[a*c*f-e*(b*c+a*d)*(n*(p+1)+1),0] && EqQ[a*c*g-b*d*e*(2*n*(p+1)+1),0]

Integrate[(e_+g_*x_^n2_.)*(a_+b_*x_^n_.)^p_*(c_+d_*x_^n_.)^p_.,x_] := e*x*(a+b*x^n)^(p+1)*(c+d*x^n)^(p+1)/(a*c) /;
FreeQ[{a,b,c,d,e,g,n,p},x] && EqQ[n2,2*n] && EqQ[n*(p+1)+1,0] && EqQ[a*c*g-b*d*e*(2*n*(p+1)+1),0]

Integrate[(A_+B_*x_^m_.)*(a_.+b_*x_^n_)^p_*(c_+d_*x_^n_)^q_.,x_] := A*Integrate[(a+b*x^n)^p*(c+d*x^n)^q,x] + B*Integrate[x^m*(a+b*x^n)^p*(c+d*x^n)^q,x] /;
FreeQ[{a,b,c,d,A,B,m,n,p,q},x] && NeQ[b*c-a*d,0] && EqQ[m-n+1,0]

