FreeQ[{a,b,c,d,m},x] && IGtQ[p,0] && Not[IntegerQ[(m+1)/2]] (* Integrate[(d_*x_)^m_*(a_+b_*x_^2+c_*x_^4)^p_.,x_] := 1/c^p*Integrate[(d*x)^m*(b/2+c*x^2)^(2*p),x] /; FreeQ[{a,b,c,d,m,p},x] && EqQ[b^2-4*a*c,0] && IntegerQ[p] *)

