Integrate[(d_+e_*x_)^m_*Pq_*(a_+c_*x_^2)^p_,x_] := With[{Q=PolynomialQuotient[Pq,a+c*x^2,x], f=Coeff[PolynomialRemainder[Pq,a+c*x^2,x],x,0], g=Coeff[PolynomialRemainder[Pq,a+c*x^2,x],x,1]}, -(d+e*x)^(m+1)*(a+c*x^2)^(p+1)*(a*(e*f-d*g)+(c*d*f+a*e*g)*x)/(2*a*(p+1)*(c*d^2+a*e^2)) + 1/(2*a*(p+1)*(c*d^2+a*e^2))*Integrate[(d+e*x)^m*(a+c*x^2)^(p+1)*    ExpandToSum[2*a*(p+1)*(c*d^2+a*e^2)*Q+c*d^2*f*(2*p+3)-a*e*(d*g*m-e*f*(m+2*p+3))+e*(c*d*f+a*e*g)*(m+2*p+4)*x,x],x]] /;
FreeQ[{a,c,d,e,m},x] && PolyQ[Pq,x] && NeQ[c*d^2+a*e^2,0] && LtQ[p,-1] && Not[IGtQ[m,0] && RationalQ[a,c,d,e] && (IntegerQ[p] || ILtQ[p+1/2,0])]

Integrate[(d_.+e_*x_)^m_*Pq_*(a_.+b_*x_+c_*x_^2)^p_,x_] := With[{Q=PolynomialQuotient[Pq,d+e*x,x], R=PolynomialRemainder[Pq,d+e*x,x]}, (e*R*(d+e*x)^(m+1)*(a+b*x+c*x^2)^(p+1))/((m+1)*(c*d^2-b*d*e+a*e^2)) + 1/((m+1)*(c*d^2-b*d*e+a*e^2))*Integrate[(d+e*x)^(m+1)*(a+b*x+c*x^2)^p* ExpandToSum[(m+1)*(c*d^2-b*d*e+a*e^2)*Q+c*d*R*(m+1)-b*e*R*(m+p+2)-c*e*R*(m+2*p+3)*x,x],x]] /;
FreeQ[{a,b,c,d,e,p},x] && PolyQ[Pq,x] && NeQ[b^2-4*a*c,0] && NeQ[c*d^2-b*d*e+a*e^2,0] && LtQ[m,-1]

Integrate[(d_+e_*x_)^m_*Pq_*(a_+c_*x_^2)^p_,x_] := With[{Q=PolynomialQuotient[Pq,d+e*x,x], R=PolynomialRemainder[Pq,d+e*x,x]}, (e*R*(d+e*x)^(m+1)*(a+c*x^2)^(p+1))/((m+1)*(c*d^2+a*e^2)) + 1/((m+1)*(c*d^2+a*e^2))*Integrate[(d+e*x)^(m+1)*(a+c*x^2)^p* ExpandToSum[(m+1)*(c*d^2+a*e^2)*Q+c*d*R*(m+1)-c*e*R*(m+2*p+3)*x,x],x]] /;
FreeQ[{a,c,d,e,p},x] && PolyQ[Pq,x] && NeQ[c*d^2+a*e^2,0] && LtQ[m,-1]

Integrate[x_^m_*Pq_*(a_+b_*x_^2)^p_,x_] := Module[{q=Expon[Pq,x],k}, Integrate[x^m*Sum[Coeff[Pq,x,2*k]*x^(2*k),{k,0,q/2}]*(a+b*x^2)^p,x] + Integrate[x^(m+1)*Sum[Coeff[Pq,x,2*k+1]*x^(2*k),{k,0,(q-1)/2}]*(a+b*x^2)^p,x]] /;
FreeQ[{a,b,p},x] && PolyQ[Pq,x] && Not[PolyQ[Pq,x^2]] && IGtQ[m,-2] && Not[IntegerQ[2*p]]

Integrate[(d_.+e_*x_)^m_*Pq_*(a_.+b_*x_+c_*x_^2)^p_,x_] := With[{q=Expon[Pq,x],f=Coeff[Pq,x,Expon[Pq,x]]}, f*(d+e*x)^(m+q-1)*(a+b*x+c*x^2)^(p+1)/(c*e^(q-1)*(m+q+2*p+1)) + 1/(c*e^q*(m+q+2*p+1))*Integrate[(d+e*x)^m*(a+b*x+c*x^2)^p*ExpandToSum[c*e^q*(m+q+2*p+1)*Pq-c*f*(m+q+2*p+1)*(d+e*x)^q- f*(d+e*x)^(q-2)*(b*d*e*(p+1)+a*e^2*(m+q-1)-c*d^2*(m+q+2*p+1)-e*(2*c*d-b*e)*(m+q+p)*x),x],x] /; GtQ[q,1] && NeQ[m+q+2*p+1,0]] /;
FreeQ[{a,b,c,d,e,m,p},x] && PolyQ[Pq,x] && NeQ[b^2-4*a*c,0] && NeQ[c*d^2-b*d*e+a*e^2,0] && Not[IGtQ[m,0] && RationalQ[a,b,c,d,e] && (IntegerQ[p] || ILtQ[p+1/2,0])]

Integrate[(d_+e_*x_)^m_*Pq_*(a_+c_*x_^2)^p_,x_] := With[{q=Expon[Pq,x],f=Coeff[Pq,x,Expon[Pq,x]]}, f*(d+e*x)^(m+q-1)*(a+c*x^2)^(p+1)/(c*e^(q-1)*(m+q+2*p+1)) + 1/(c*e^q*(m+q+2*p+1))*Integrate[(d+e*x)^m*(a+c*x^2)^p*ExpandToSum[c*e^q*(m+q+2*p+1)*Pq-c*f*(m+q+2*p+1)*(d+e*x)^q- f*(d+e*x)^(q-2)*(a*e^2*(m+q-1)-c*d^2*(m+q+2*p+1)-2*c*d*e*(m+q+p)*x),x],x] /; GtQ[q,1] && NeQ[m+q+2*p+1,0]] /;
FreeQ[{a,c,d,e,m,p},x] && PolyQ[Pq,x] && NeQ[c*d^2+a*e^2,0] && Not[EqQ[d,0] && True] && Not[IGtQ[m,0] && RationalQ[a,c,d,e] && (IntegerQ[p] || ILtQ[p+1/2,0])]

Integrate[(d_.+e_*x_)^m_*Pq_*(a_.+b_*x_+c_*x_^2)^p_.,x_] := With[{q=Expon[Pq,x]}, Coeff[Pq,x,q]/e^q*Integrate[(d+e*x)^(m+q)*(a+b*x+c*x^2)^p,x] + 1/e^q*Integrate[(d+e*x)^m*(a+b*x+c*x^2)^p*ExpandToSum[e^q*Pq-Coeff[Pq,x,q]*(d+e*x)^q,x],x]] /;
