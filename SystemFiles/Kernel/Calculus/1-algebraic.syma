FreeQ[{a,b,c,m},x] && PolyQ[Pq,x] && IntegerQ[n] && Not[IGtQ[m,0]]

Integrate[(c_*x_)^m_*Pq_*(a_+b_*x_^n_)^p_,x_] := With[{Pq0=Coeff[Pq,x,0]}, Pq0*(c*x)^(m+1)*(a+b*x^n)^(p+1)/(a*c*(m+1)) + 1/(2*a*c*(m+1))*Integrate[(c*x)^(m+1)*ExpandToSum[2*a*(m+1)*(Pq-Pq0)/x-2*b*Pq0*(m+n*(p+1)+1)*x^(n-1),x]*(a+b*x^n)^p,x] /; NeQ[Pq0,0]] /;
