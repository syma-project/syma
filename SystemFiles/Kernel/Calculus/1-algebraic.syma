Integrate[P_^p_*Q_^q_.,x_] := With[{PP=Factor[P]}, Integrate[ExpandIntegrand[PP^p*Q^q,x],x] /; Not[SumQ[NonfreeFactors[PP,x]]]] /;
FreeQ[q,x] && PolyQ[P,x] && PolyQ[Q,x] && IntegerQ[p] && NeQ[P,x]

