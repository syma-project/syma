Integrate[(d_+e_*x_^n_.)^q_*(a_+b_*x_^n_.+c_*x_^n2_.)^p_,x_] := (a+b*x^n+c*x^(2*n))^p/(d+e*x^n)^(2*p)*Integrate[(d+e*x^n)^(q+2*p),x] /;
