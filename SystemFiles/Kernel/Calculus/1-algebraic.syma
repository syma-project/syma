Integrate[x_^m_/(a_+b_*x_^n_),x_] := With[{r=Numerator[Rt[-a/b,2]], s=Denominator[Rt[-a/b,2]]}, r/(2*a)*Integrate[x^m/(r+s*x^(n/2)),x] + r/(2*a)*Integrate[x^m/(r-s*x^(n/2)),x]] /;
