FreeQ[{a,b},x] && PosQ[b/a]

Integrate[1/(x_^2*(a_+b_*x_^4)^(1/4)),x_] := x*(1+a/(b*x^4))^(1/4)/(a+b*x^4)^(1/4)*Integrate[1/(x^3*(1+a/(b*x^4))^(1/4)),x] /;
FreeQ[{a,b},x] && NegQ[b/a]

