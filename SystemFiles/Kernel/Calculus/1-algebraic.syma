Integrate[(g_+h_*x_)/((a_+c_*x_^2)^(1/3)*(d_+f_*x_^2)),x_] := Sqrt[3]*h*ArcTan[1/Sqrt[3]-2^(2/3)*(1-3*h*x/g)^(2/3)/(Sqrt[3]*(1+3*h*x/g)^(1/3))]/(2^(2/3)*a^(1/3)*f) + h*Log[d+f*x^2]/(2^(5/3)*a^(1/3)*f) -    3*h*Log[(1-3*h*x/g)^(2/3)+2^(1/3)*(1+3*h*x/g)^(1/3)]/(2^(5/3)*a^(1/3)*f) /;
