Integrate[(d_+e_*x_^n_)^q_*(a_+c_*x_^n2_),x_] := -(c*d^2+a*e^2)*x*(d+e*x^n)^(q+1)/(d*e^2*n*(q+1)) + 1/(n*(q+1)*d*e^2)*Integrate[(d+e*x^n)^(q+1)*Simp[c*d^2+a*e^2*(n*(q+1)+1)+c*d*e*n*(q+1)*x^n,x],x] /;
