FreeQ[{a,c,d,e,q},x] && EqQ[c*d^2+a*e^2,0] && IntegerQ[p]

Integrate[(d_+e_*x_^2)^q_*(a_+b_*x_^2+c_*x_^4)^p_,x_] := (a+b*x^2+c*x^4)^FracPart[p]/((d+e*x^2)^FracPart[p]*(a/d+c*x^2/e)^FracPart[p])*Integrate[(d+e*x^2)^(p+q)*(a/d+c/e*x^2)^p,x] /;
FreeQ[{a,b,c,d,e,p,q},x] && NeQ[b^2-4*a*c,0] && EqQ[c*d^2-b*d*e+a*e^2,0] && Not[IntegerQ[p]]

Integrate[(d_+e_*x_^2)^q_*(a_+c_*x_^4)^p_,x_] := (a+c*x^4)^FracPart[p]/((d+e*x^2)^FracPart[p]*(a/d+c*x^2/e)^FracPart[p])*Integrate[(d+e*x^2)^(p+q)*(a/d+c/e*x^2)^p,x] /;
FreeQ[{a,c,d,e,p,q},x] && EqQ[c*d^2+a*e^2,0] && Not[IntegerQ[p]]

Integrate[(d_+e_*x_^2)^q_*(a_+b_*x_^2+c_*x_^4)^p_.,x_] := Integrate[ExpandIntegrand[(d+e*x^2)^q*(a+b*x^2+c*x^4)^p,x],x] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && NeQ[c*d^2-b*d*e+a*e^2,0] && IGtQ[p,0] && IGtQ[q,-2]

Integrate[(d_+e_*x_^2)^q_*(a_+c_*x_^4)^p_.,x_] := Integrate[ExpandIntegrand[(d+e*x^2)^q*(a+c*x^4)^p,x],x] /;
FreeQ[{a,c,d,e},x] && NeQ[c*d^2+a*e^2,0] && IGtQ[p,0] && IGtQ[q,-2]

Integrate[(d_+e_*x_^2)^q_*(a_+b_*x_^2+c_*x_^4)^p_.,x_] := a^p*x*(d+e*x^2)^(q+1)/d + 1/d*Integrate[x^2*(d+e*x^2)^q*(d*PolynomialQuotient[(a+b*x^2+c*x^4)^p-a^p,x^2,x]-e*a^p*(2*q+3)),x] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && NeQ[c*d^2-b*d*e+a*e^2,0] && IGtQ[p,0] && ILtQ[q+1/2,0] && LtQ[4*p+2*q+1,0]

Integrate[(d_+e_*x_^2)^q_*(a_+c_*x_^4)^p_.,x_] := a^p*x*(d+e*x^2)^(q+1)/d + 1/d*Integrate[x^2*(d+e*x^2)^q*(d*PolynomialQuotient[(a+c*x^4)^p-a^p,x^2,x]-e*a^p*(2*q+3)),x] /;
FreeQ[{a,c,d,e},x] && NeQ[c*d^2+a*e^2,0] && IGtQ[p,0] && ILtQ[q+1/2,0] && LtQ[4*p+2*q+1,0]

Integrate[(d_+e_*x_^2)^q_*(a_+b_*x_^2+c_*x_^4)^p_.,x_] := With[{Qx=PolynomialQuotient[(a+b*x^2+c*x^4)^p,d+e*x^2,x], R=Coeff[PolynomialRemainder[(a+b*x^2+c*x^4)^p,d+e*x^2,x],x,0]}, -R*x*(d+e*x^2)^(q+1)/(2*d*(q+1)) + 1/(2*d*(q+1))*Integrate[(d+e*x^2)^(q+1)*ExpandToSum[2*d*(q+1)*Qx+R*(2*q+3),x],x]] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && NeQ[c*d^2-b*d*e+a*e^2,0] && IGtQ[p,0] && LtQ[q,-1]

Integrate[(d_+e_*x_^2)^q_*(a_+c_*x_^4)^p_.,x_] := With[{Qx=PolynomialQuotient[(a+c*x^4)^p,d+e*x^2,x], R=Coeff[PolynomialRemainder[(a+c*x^4)^p,d+e*x^2,x],x,0]}, -R*x*(d+e*x^2)^(q+1)/(2*d*(q+1)) + 1/(2*d*(q+1))*Integrate[(d+e*x^2)^(q+1)*ExpandToSum[2*d*(q+1)*Qx+R*(2*q+3),x],x]] /;
FreeQ[{a,c,d,e},x] && NeQ[c*d^2+a*e^2,0] && IGtQ[p,0] && LtQ[q,-1]

Integrate[(d_+e_*x_^2)^q_*(a_+b_*x_^2+c_*x_^4)^p_.,x_] := c^p*x^(4*p-1)*(d+e*x^2)^(q+1)/(e*(4*p+2*q+1)) + 1/(e*(4*p+2*q+1))*Integrate[(d+e*x^2)^q*ExpandToSum[e*(4*p+2*q+1)*(a+b*x^2+c*x^4)^p-d*c^p*(4*p-1)*x^(4*p-2)-e*c^p*(4*p+2*q+1)*x^(4*p),x],x] /;
FreeQ[{a,b,c,d,e,q},x] && NeQ[b^2-4*a*c,0] && NeQ[c*d^2-b*d*e+a*e^2,0] && IGtQ[p,0] && Not[LtQ[q,-1]]

Integrate[(d_+e_*x_^2)^q_*(a_+c_*x_^4)^p_.,x_] := c^p*x^(4*p-1)*(d+e*x^2)^(q+1)/(e*(4*p+2*q+1)) + 1/(e*(4*p+2*q+1))*Integrate[(d+e*x^2)^q*ExpandToSum[e*(4*p+2*q+1)*(a+c*x^4)^p-d*c^p*(4*p-1)*x^(4*p-2)-e*c^p*(4*p+2*q+1)*x^(4*p),x],x] /;
FreeQ[{a,c,d,e,q},x] && NeQ[c*d^2+a*e^2,0] && IGtQ[p,0] && Not[LtQ[q,-1]]

Integrate[(d_+e_*x_^2)/(a_+b_*x_^2+c_*x_^4),x_] := With[{q=Rt[2*d/e-b/c,2]}, e/(2*c)*Integrate[1/Simp[d/e+q*x+x^2,x],x] + e/(2*c)*Integrate[1/Simp[d/e-q*x+x^2,x],x]] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && EqQ[c*d^2-a*e^2,0] && (GtQ[2*d/e-b/c,0] || Not[LtQ[2*d/e-b/c,0]] && EqQ[d-e*Rt[a/c,2],0])

Integrate[(d_+e_*x_^2)/(a_+c_*x_^4),x_] := With[{q=Rt[2*d/e,2]}, e/(2*c)*Integrate[1/Simp[d/e+q*x+x^2,x],x] + e/(2*c)*Integrate[1/Simp[d/e-q*x+x^2,x],x]] /;
FreeQ[{a,c,d,e},x] && EqQ[c*d^2-a*e^2,0] && PosQ[d*e]

Integrate[(d_+e_*x_^2)/(a_+b_*x_^2+c_*x_^4),x_] := With[{q=Rt[b^2-4*a*c,2]}, (e/2+(2*c*d-b*e)/(2*q))*Integrate[1/(b/2-q/2+c*x^2),x] + (e/2-(2*c*d-b*e)/(2*q))*Integrate[1/(b/2+q/2+c*x^2),x]] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && EqQ[c*d^2-a*e^2,0] && GtQ[b^2-4*a*c,0]

Integrate[(d_+e_*x_^2)/(a_+b_*x_^2+c_*x_^4),x_] := With[{q=Rt[-2*d/e-b/c,2]}, e/(2*c*q)*Integrate[(q-2*x)/Simp[d/e+q*x-x^2,x],x] + e/(2*c*q)*Integrate[(q+2*x)/Simp[d/e-q*x-x^2,x],x]] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && EqQ[c*d^2-a*e^2,0] && Not[GtQ[b^2-4*a*c,0]]

Integrate[(d_+e_*x_^2)/(a_+c_*x_^4),x_] := With[{q=Rt[-2*d/e,2]}, e/(2*c*q)*Integrate[(q-2*x)/Simp[d/e+q*x-x^2,x],x] + e/(2*c*q)*Integrate[(q+2*x)/Simp[d/e-q*x-x^2,x],x]] /;
FreeQ[{a,c,d,e},x] && EqQ[c*d^2-a*e^2,0] && NegQ[d*e]

Integrate[(d_+e_*x_^2)/(a_+b_*x_^2+c_*x_^4),x_] := With[{q=Rt[b^2-4*a*c,2]}, (e/2+(2*c*d-b*e)/(2*q))*Integrate[1/(b/2-q/2+c*x^2),x] + (e/2-(2*c*d-b*e)/(2*q))*Integrate[1/(b/2+q/2+c*x^2),x]] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && NeQ[c*d^2-a*e^2,0] && PosQ[b^2-4*a*c]

Integrate[(d_+e_*x_^2)/(a_+c_*x_^4),x_] := With[{q=Rt[-a*c,2]}, (e/2+c*d/(2*q))*Integrate[1/(-q+c*x^2),x] + (e/2-c*d/(2*q))*Integrate[1/(q+c*x^2),x]] /;
FreeQ[{a,c,d,e},x] && NeQ[c*d^2-a*e^2,0] && PosQ[-a*c]

Integrate[(d_+e_*x_^2)/(a_+c_*x_^4),x_] := With[{q=Rt[a*c,2]}, (d*q+a*e)/(2*a*c)*Integrate[(q+c*x^2)/(a+c*x^4),x] + (d*q-a*e)/(2*a*c)*Integrate[(q-c*x^2)/(a+c*x^4),x]] /;
FreeQ[{a,c,d,e},x] && NeQ[c*d^2+a*e^2,0] && NeQ[c*d^2-a*e^2,0] && NegQ[-a*c]

Integrate[(d_+e_*x_^2)/(a_+b_*x_^2+c_*x_^4),x_] := With[{q=Rt[a/c,2]}, With[{r=Rt[2*q-b/c,2]}, 1/(2*c*q*r)*Integrate[(d*r-(d-e*q)*x)/(q-r*x+x^2),x] + 1/(2*c*q*r)*Integrate[(d*r+(d-e*q)*x)/(q+r*x+x^2),x]]] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && NeQ[c*d^2-b*d*e+a*e^2,0] && NegQ[b^2-4*a*c]

Integrate[(d_+e_*x_^2)^q_/(a_+b_*x_^2+c_*x_^4),x_] := Integrate[ExpandIntegrand[(d+e*x^2)^q/(a+b*x^2+c*x^4),x],x] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && NeQ[c*d^2-b*d*e+a*e^2,0] && IntegerQ[q]

Integrate[(d_+e_*x_^2)^q_/(a_+c_*x_^4),x_] := Integrate[ExpandIntegrand[(d+e*x^2)^q/(a+c*x^4),x],x] /;
FreeQ[{a,c,d,e},x] && NeQ[c*d^2+a*e^2,0] && IntegerQ[q]

Integrate[(d_+e_*x_^2)^q_/(a_+b_*x_^2+c_*x_^4),x_] := e^2/(c*d^2-b*d*e+a*e^2)*Integrate[(d+e*x^2)^q,x] +    1/(c*d^2-b*d*e+a*e^2)*Integrate[(d+e*x^2)^(q+1)*(c*d-b*e-c*e*x^2)/(a+b*x^2+c*x^4),x] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && NeQ[c*d^2-b*d*e+a*e^2,0] && Not[IntegerQ[q]] && LtQ[q,-1]

Integrate[(d_+e_*x_^2)^q_/(a_+c_*x_^4),x_] := e^2/(c*d^2+a*e^2)*Integrate[(d+e*x^2)^q,x] +    c/(c*d^2+a*e^2)*Integrate[(d+e*x^2)^(q+1)*(d-e*x^2)/(a+c*x^4),x] /;
FreeQ[{a,c,d,e},x] && NeQ[c*d^2+a*e^2,0] && Not[IntegerQ[q]] && LtQ[q,-1]

Integrate[(d_+e_*x_^2)^q_/(a_+b_*x_^2+c_*x_^4),x_] := With[{r=Rt[b^2-4*a*c,2]}, 2*c/r*Integrate[(d+e*x^2)^q/(b-r+2*c*x^2),x] - 2*c/r*Integrate[(d+e*x^2)^q/(b+r+2*c*x^2),x]] /;
FreeQ[{a,b,c,d,e,q},x] && NeQ[b^2-4*a*c,0] && NeQ[c*d^2-b*d*e+a*e^2,0] && Not[IntegerQ[q]]

Integrate[(d_+e_*x_^2)^q_/(a_+c_*x_^4),x_] := With[{r=Rt[-a*c,2]}, -c/(2*r)*Integrate[(d+e*x^2)^q/(r-c*x^2),x] - c/(2*r)*Integrate[(d+e*x^2)^q/(r+c*x^2),x]] /;
FreeQ[{a,c,d,e,q},x] && NeQ[c*d^2+a*e^2,0] && Not[IntegerQ[q]]

Integrate[(d_+e_*x_^2)*(a_+b_*x_^2+c_*x_^4)^p_,x_] := x*(2*b*e*p+c*d*(4*p+3)+c*e*(4*p+1)*x^2)*(a+b*x^2+c*x^4)^p/(c*(4*p+1)*(4*p+3)) + 2*p/(c*(4*p+1)*(4*p+3))*Integrate[Simp[2*a*c*d*(4*p+3)-a*b*e+(2*a*c*e*(4*p+1)+b*c*d*(4*p+3)-b^2*e*(2*p+1))*x^2,x]* (a+b*x^2+c*x^4)^(p-1),x] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && NeQ[c*d^2-b*d*e+a*e^2,0] && GtQ[p,0] && FractionQ[p] && IntegerQ[2*p]

Integrate[(d_+e_*x_^2)*(a_+c_*x_^4)^p_,x_] := x*(d*(4*p+3)+e*(4*p+1)*x^2)*(a+c*x^4)^p/((4*p+1)*(4*p+3)) + 2*p/((4*p+1)*(4*p+3))*Integrate[Simp[2*a*d*(4*p+3)+(2*a*e*(4*p+1))*x^2,x]*(a+c*x^4)^(p-1),x] /;
FreeQ[{a,c,d,e},x] && NeQ[c*d^2+a*e^2,0] && GtQ[p,0] && FractionQ[p] && IntegerQ[2*p]

Integrate[(d_+e_*x_^2)*(a_+b_*x_^2+c_*x_^4)^p_,x_] := x*(a*b*e-d*(b^2-2*a*c)-c*(b*d-2*a*e)*x^2)*(a+b*x^2+c*x^4)^(p+1)/(2*a*(p+1)*(b^2-4*a*c)) + 1/(2*a*(p+1)*(b^2-4*a*c))*Integrate[Simp[(2*p+3)*d*b^2-a*b*e-2*a*c*d*(4*p+5)+(4*p+7)*(d*b-2*a*e)*c*x^2,x]* (a+b*x^2+c*x^4)^(p+1),x] /;
FreeQ[{a,b,c,d,e},x] && NeQ[b^2-4*a*c,0] && NeQ[c*d^2-b*d*e+a*e^2,0] && LtQ[p,-1] && IntegerQ[2*p]

Integrate[(d_+e_*x_^2)*(a_+c_*x_^4)^p_,x_] := -x*(d+e*x^2)*(a+c*x^4)^(p+1)/(4*a*(p+1)) + 1/(4*a*(p+1))*Integrate[Simp[d*(4*p+5)+e*(4*p+7)*x^2,x]*(a+c*x^4)^(p+1),x] /;
FreeQ[{a,c,d,e},x] && NeQ[c*d^2+a*e^2,0] && LtQ[p,-1] && IntegerQ[2*p]

Integrate[(d_+e_*x_^2)/Sqrt[a_+b_*x_^2+c_*x_^4],x_] := With[{q=Rt[b^2-4*a*c,2]}, 2*Sqrt[-c]*Integrate[(d+e*x^2)/(Sqrt[b+q+2*c*x^2]*Sqrt[-b+q-2*c*x^2]),x]] /;
FreeQ[{a,b,c,d,e},x] && GtQ[b^2-4*a*c,0] && LtQ[c,0]

Integrate[(d_+e_*x_^2)/Sqrt[a_+c_*x_^4],x_] := With[{q=Rt[-a*c,2]}, Sqrt[-c]*Integrate[(d+e*x^2)/(Sqrt[q+c*x^2]*Sqrt[q-c*x^2]),x]] /;
FreeQ[{a,c,d,e},x] && GtQ[a,0] && LtQ[c,0]

Integrate[(d_+e_*x_^2)/Sqrt[a_+b_*x_^2+c_*x_^4],x_] := With[{q=Rt[c/a,4]}, -d*x*Sqrt[a+b*x^2+c*x^4]/(a*(1+q^2*x^2)) +    d*(1+q^2*x^2)*Sqrt[(a+b*x^2+c*x^4)/(a*(1+q^2*x^2)^2)]/(q*Sqrt[a+b*x^2+c*x^4])*EllipticE[2*ArcTan[q*x],1/2-b*q^2/(4*c)] /; EqQ[e+d*q^2,0]] /;
FreeQ[{a,b,c,d,e},x] && GtQ[b^2-4*a*c,0] && GtQ[c/a,0] && LtQ[b/a,0]

Integrate[(d_+e_*x_^2)/Sqrt[a_+b_*x_^2+c_*x_^4],x_] := With[{q=Rt[c/a,2]}, (e+d*q)/q*Integrate[1/Sqrt[a+b*x^2+c*x^4],x] - e/q*Integrate[(1-q*x^2)/Sqrt[a+b*x^2+c*x^4],x] /; NeQ[e+d*q,0]] /;
FreeQ[{a,b,c,d,e},x] && GtQ[b^2-4*a*c,0] && GtQ[c/a,0] && LtQ[b/a,0]

Integrate[(d_+e_*x_^2)/Sqrt[a_+b_*x_^2+c_*x_^4],x_] := With[{q=Rt[b^2-4*a*c,2]}, e*x*(b+q+2*c*x^2)/(2*c*Sqrt[a+b*x^2+c*x^4]) - e*q*Sqrt[(2*a+(b-q)*x^2)/(2*a+(b+q)*x^2)]*Sqrt[(2*a+(b+q)*x^2)/q]/(2*c*Sqrt[a+b*x^2+c*x^4]*Sqrt[a/(2*a+(b+q)*x^2)])*     EllipticE[ArcSin[x/Sqrt[(2*a+(b+q)*x^2)/(2*q)]],(b+q)/(2*q)] /; EqQ[2*c*d-e*(b-q),0]] /;
FreeQ[{a,b,c,d,e},x] && GtQ[b^2-4*a*c,0] && LtQ[a,0] && GtQ[c,0]

Integrate[(d_+e_*x_^2)/Sqrt[a_+c_*x_^4],x_] := With[{q=Rt[-a*c,2]}, e*x*(q+c*x^2)/(c*Sqrt[a+c*x^4]) - Sqrt[2]*e*q*Sqrt[-a+q*x^2]*Sqrt[(a+q*x^2)/q]/(Sqrt[-a]*c*Sqrt[a+c*x^4])*     EllipticE[ArcSin[x/Sqrt[(a+q*x^2)/(2*q)]],1/2] /; EqQ[c*d+e*q,0] && IntegerQ[q]] /;
FreeQ[{a,c,d,e},x] && LtQ[a,0] && GtQ[c,0]

Integrate[(d_+e_*x_^2)/Sqrt[a_+c_*x_^4],x_] := With[{q=Rt[-a*c,2]}, e*x*(q+c*x^2)/(c*Sqrt[a+c*x^4]) - Sqrt[2]*e*q*Sqrt[(a-q*x^2)/(a+q*x^2)]*Sqrt[(a+q*x^2)/q]/(c*Sqrt[a+c*x^4]*Sqrt[a/(a+q*x^2)])*     EllipticE[ArcSin[x/Sqrt[(a+q*x^2)/(2*q)]],1/2] /; EqQ[c*d+e*q,0]] /;
FreeQ[{a,c,d,e},x] && LtQ[a,0] && GtQ[c,0]

Integrate[(d_+e_*x_^2)/Sqrt[a_+b_*x_^2+c_*x_^4],x_] := With[{q=Rt[b^2-4*a*c,2]}, (2*c*d-e*(b-q))/(2*c)*Integrate[1/Sqrt[a+b*x^2+c*x^4],x] + e/(2*c)*Integrate[(b-q+2*c*x^2)/Sqrt[a+b*x^2+c*x^4],x] /; NeQ[2*c*d-e*(b-q),0]] /;
FreeQ[{a,b,c,d,e},x] && GtQ[b^2-4*a*c,0] && LtQ[a,0] && GtQ[c,0]

Integrate[(d_+e_*x_^2)/Sqrt[a_+c_*x_^4],x_] := With[{q=Rt[-a*c,2]}, (c*d+e*q)/c*Integrate[1/Sqrt[a+c*x^4],x] - e/c*Integrate[(q-c*x^2)/Sqrt[a+c*x^4],x] /; NeQ[c*d+e*q,0]] /;
FreeQ[{a,c,d,e},x] && LtQ[a,0] && GtQ[c,0]

Integrate[(d_+e_*x_^2)/Sqrt[a_+b_*x_^2+c_*x_^4],x_] := With[{q=Rt[b^2-4*a*c,2]}, d*Integrate[1/Sqrt[a+b*x^2+c*x^4],x] + e*Integrate[x^2/Sqrt[a+b*x^2+c*x^4],x] /; PosQ[(b+q)/a] || PosQ[(b-q)/a]] /;
FreeQ[{a,b,c,d,e},x] && GtQ[b^2-4*a*c,0]

Integrate[(d_+e_*x_^2)/Sqrt[a_+c_*x_^4],x_] := d*Integrate[1/Sqrt[a+c*x^4],x] + e*Integrate[x^2/Sqrt[a+c*x^4],x] /;
FreeQ[{a,c,d,e},x] && GtQ[-a*c,0]

Integrate[(d_+e_*x_^2)/Sqrt[a_+b_*x_^2+c_*x_^4],x_] := With[{q=Rt[b^2-4*a*c,2]}, -a*e*Rt[-(b+q)/(2*a),2]*Sqrt[1+(b+q)*x^2/(2*a)]*Sqrt[1+(b-q)*x^2/(2*a)]/(c*Sqrt[a+b*x^2+c*x^4])* EllipticE[ArcSin[Rt[-(b+q)/(2*a),2]*x],(b-q)/(b+q)] /; NegQ[(b+q)/a] && EqQ[2*c*d-e*(b+q),0] && Not[SimplerSqrtQ[-(b-q)/(2*a),-(b+q)/(2*a)]]] /;
FreeQ[{a,b,c,d,e},x] && GtQ[b^2-4*a*c,0]

Integrate[(d_+e_*x_^2)/Sqrt[a_+b_*x_^2+c_*x_^4],x_] := With[{q=Rt[b^2-4*a*c,2]}, (2*c*d-e*(b+q))/(2*c)*Integrate[1/Sqrt[a+b*x^2+c*x^4],x] + e/(2*c)*Integrate[(b+q+2*c*x^2)/Sqrt[a+b*x^2+c*x^4],x] /; NegQ[(b+q)/a] && NeQ[2*c*d-e*(b+q),0] && Not[SimplerSqrtQ[-(b-q)/(2*a),-(b+q)/(2*a)]]] /;
FreeQ[{a,b,c,d,e},x] && GtQ[b^2-4*a*c,0]

